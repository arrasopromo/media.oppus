          </div>
          <div class="summary-card">
            <div class="summary-label">LTV geral (recompra)</div>
            <div class="summary-value"><%= (typeof ltvGeneralCustomerRepeatPct !== 'undefined' ? Number(ltvGeneralCustomerRepeatPct || 0) : (typeof repeatCustomerPct !== 'undefined' ? Number(repeatCustomerPct || 0) : 0)).toFixed(1).replace('.', ',') %>%</div>
            <div class="summary-sub"><%= typeof repeatCustomers !== 'undefined' ? Number(repeatCustomers || 0) : 0 %> clientes recorrentes</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Pedidos (geral)</div>
            <div class="summary-value"><%= typeof totalTransactions !== 'undefined' ? totalTransactions : 0 %></div>
