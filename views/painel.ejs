                <div id="geoMap" style="height:420px;"></div>
              </div>
            </div>
          </div>
        </div>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/q19p1Z0wZyy3R0Xv0=" crossorigin="anonymous">
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="anonymous"></script>
        <script>
          (function(){
            var geoMapInstance = null;
            function q(id){ return document.getElementById(id); }
            function renderGeoTable(rows){
              var tb = q('geoCitiesTbody');
              if (!tb) return;
              if (!rows || !rows.length) {
                tb.innerHTML = '<tr><td colspan="4" style="padding:10px; color:#777;">Sem dados</td></tr>';
                return;
              }
              var html = '';
              rows.forEach(function(r){
                html += '<tr>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9;">'+ (r.city || '-') +'</td>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9;">'+ (r.region || '-') +'</td>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9;">'+ (r.country || '-') +'</td>'
                  + '<td style="padding:8px; border-bottom:1px solid #f1f5f9; text-align:right;">'+ (r.count || 0) +'</td>'
                  + '</tr>';
              });
              tb.innerHTML = html;
            }
            function initMap(pointsVisits, pointsProfiles){
              var el = q('geoMap');
              if (!el || typeof L === 'undefined') return;
              try {
                if (geoMapInstance && typeof geoMapInstance.remove === 'function') geoMapInstance.remove();
              } catch (_) {}
              geoMapInstance = null;
              try { el.innerHTML = ''; } catch (_) {}
              var map = L.map(el).setView([-15.78, -47.93], 4);
              geoMapInstance = map;
              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap',
                maxZoom: 18
              }).addTo(map);
              var bounds = [];
              (pointsVisits || []).forEach(function(p){
                if (typeof p.lat === 'number' && typeof p.lon === 'number') {
                  var m = L.circleMarker([p.lat, p.lon], { radius: 5, color: '#2563eb', fillColor: '#3b82f6', fillOpacity: 0.7, weight: 1 });
                  m.bindPopup('<strong>Visitas</strong><br>'+ (p.city||'-') +', '+ (p.region||'-') +' - '+ (p.country||'-') +'<br>Qtd: '+ (p.count||0));
                  m.addTo(map);
                  bounds.push([p.lat, p.lon]);
                }
              });
              (pointsProfiles || []).forEach(function(p){
                if (typeof p.lat === 'number' && typeof p.lon === 'number') {
                  var m = L.circleMarker([p.lat, p.lon], { radius: 6, color: '#7c3aed', fillColor: '#a78bfa', fillOpacity: 0.8, weight: 1.2 });
                  m.bindPopup('<strong>Perfis Validados</strong><br>'+ (p.city||'-') +', '+ (p.region||'-') +' - '+ (p.country||'-') +'<br>Qtd: '+ (p.count||0));
                  m.addTo(map);
                  bounds.push([p.lat, p.lon]);
                }
              });
              if (bounds.length) {
                try { map.fitBounds(bounds, { padding: [20,20] }); } catch(_) {}
              }
              try { setTimeout(function(){ try { map.invalidateSize(); } catch (_) {} }, 250); } catch (_) {}
            }
            fetch('/api/geo/aggregate')
              .then(function(r){ return r.json(); })
              .then(function(data){
                if (!data || data.ok !== true) throw new Error('sem dados');
                var visits = Array.isArray(data.visits) ? data.visits : [];
                var profiles = Array.isArray(data.profiles) ? data.profiles : [];
                var topCities = visits.slice().sort(function(a,b){ return (b.count||0)-(a.count||0); }).slice(0, 100);
                renderGeoTable(topCities);
                initMap(visits, profiles);
              })
              .catch(function(){
                renderGeoTable([]);
                initMap([], []);
              });
          })();
        </script>
        <% } %>
      </div>

