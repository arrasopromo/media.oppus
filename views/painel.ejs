                    %>
                    <% if (othersArr3.length) { %>
                      <div style="margin-top:8px; font-size:0.82rem; color:#6b7280; line-height:1.3;">Outros inclui: <%= othersText3 %><%= othersRest3 > 0 ? (' · +' + othersRest3 + ' tipos') : '' %></div>
