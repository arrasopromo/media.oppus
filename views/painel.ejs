                <script>
                  (function(){
                    try {
                      if (typeof Chart === 'undefined') return;
                      var payEl = document.getElementById('dashboardPaymentMethodData');
                      var payRaw = payEl ? String(payEl.textContent || '').trim() : '[]';
                      var pay = JSON.parse(payRaw || '[]');
                      var payCanvas = document.getElementById('dashboardPaymentMethodChart');
                      if (payCanvas) {
                        new Chart(payCanvas, {
                          type: 'doughnut',
                          data: {
                            labels: pay.map(function(x){ return String(x && x.label ? x.label : '-'); }),
                            datasets: [{
                              data: pay.map(function(x){ return Number(x && x.count ? x.count : 0); }),
                              backgroundColor: pay.map(function(x){ return String(x && x.color ? x.color : '#e5e7eb'); }),
                              borderWidth: 0
                            }]
                          },
                          options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                              legend: { position: 'right', align: 'center', labels: { boxWidth: 10, boxHeight: 10 } }
                            },
                            cutout: '60%'
                          }
                        });
                      }
                      var svcEl = document.getElementById('dashboardServiceTypePieData');
                      var svcRaw = svcEl ? String(svcEl.textContent || '').trim() : '[]';
                      var svc = JSON.parse(svcRaw || '[]');
                      var svcCanvas = document.getElementById('dashboardServiceTypePieChart');
                      var sliceValueLabels = {
                        id: 'sliceValueLabels',
                        afterDatasetDraw: function(chart, args) {
                          try {
                            if (!chart || !chart.ctx) return;
                            var ctx = chart.ctx;
                            var meta = chart.getDatasetMeta(args.index);
                            if (!meta || !meta.data) return;
                            var data = chart.data && chart.data.datasets && chart.data.datasets[args.index] ? chart.data.datasets[args.index].data : [];
                            ctx.save();
                            ctx.fillStyle = '#111827';
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'middle';
                            ctx.font = '600 12px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif';
                            for (var i = 0; i < meta.data.length; i++) {
                              var v = Number(data && data[i] ? data[i] : 0) || 0;
                              if (v <= 0) continue;
                              var el = meta.data[i];
                              if (!el) continue;
                              var p = (typeof el.getCenterPoint === 'function') ? el.getCenterPoint() : (typeof el.tooltipPosition === 'function' ? el.tooltipPosition() : null);
                              if (!p) continue;
                              ctx.fillText(String(Math.round(v)), p.x, p.y);
                            }
                            ctx.restore();
                          } catch (_) {}
                        }
                      };
                      if (svcCanvas) {
                        new Chart(svcCanvas, {
                          plugins: [sliceValueLabels],
                          type: 'doughnut',
                          data: {
                            labels: svc.map(function(x){ return String(x && x.label ? x.label : '-'); }),
                            datasets: [{
                              data: svc.map(function(x){ return Number(x && x.count ? x.count : 0); }),
                              backgroundColor: svc.map(function(x){ return String(x && x.color ? x.color : '#e5e7eb'); }),
                              borderWidth: 0
                            }]
                          },
                          options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                              legend: { position: 'right', align: 'center', labels: { boxWidth: 10, boxHeight: 10 } }
                            },
                            cutout: '60%'
                          }
                        });
                      }
                    } catch (_) {}
                  })();
                </script>
              </div>
            <div id="dashboardLtvWrap" style="margin-top: 14px; width:100%; border:1px solid #e5e7eb; border-radius:10px; background:#fff; padding:14px; box-sizing:border-box;">
              <%
