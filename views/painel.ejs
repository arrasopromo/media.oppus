            return (Number.isFinite(n) && n > 0) ? String(Math.trunc(n)) : '';
          } catch (_) { return ''; }
        };
        const getProvider = (ctx, key, fallback) => {
          try {
            const v = String(providers0 && providers0[ctx] && providers0[ctx][key] ? providers0[ctx][key] : '').trim();
            return v || String(fallback || '').trim();
          } catch (_) { return String(fallback || '').trim(); }
        };
        const allowedProviders = (ctx, key) => {
          const k = String(key || '').trim();
          if (ctx === 'curtidas' && k === 'organicos') return ['topfama', 'fornecedor_social'];
          if (ctx === 'seguidores' && k === 'organicos') return ['fornecedor_social'];
          return ['fama24h'];
        };
      %>
