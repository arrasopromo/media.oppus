                    <div style="border:1px solid #eee; border-radius: 8px; padding: 12px; background:#fff;">
                      <div style="font-weight: 700; margin-bottom: 8px; color:#111827;">Top 5 usuários (maior gasto)</div>
                      <table style="width:100%; border-collapse: collapse; font-size: 0.92rem;">
                        <thead>
                          <tr>
                            <th style="text-align:left; padding:6px 0; border-bottom:1px solid #f1f1f1;">Usuário</th>
                            <th style="text-align:right; padding:6px 0; border-bottom:1px solid #f1f1f1;">Gasto</th>
                            <th style="text-align:right; padding:6px 0; border-bottom:1px solid #f1f1f1;">Pedidos</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% ltvDashTopBySpend.slice(0,5).forEach(u => { %>
                            <tr>
                              <td style="padding:6px 0; border-bottom:1px solid #fafafa;"><%= String(u && u.label ? u.label : '-') %></td>
                              <td style="padding:6px 0; border-bottom:1px solid #fafafa; text-align:right;">R$ <%= Number(u && u.spend ? u.spend : 0).toFixed(2).replace('.', ',') %></td>
                              <td style="padding:6px 0; border-bottom:1px solid #fafafa; text-align:right;"><%= Number(u && u.orders ? u.orders : 0) %></td>
