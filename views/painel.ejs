          function computeFollowersReportFromTable(){
            try {
              var rows = getAllRows();
              var total = rows.length;
              var checked = 0;
              var checkedValid = 0;
              var ok = 0;
              var notOk = 0;
              var withDrop = 0;
              var buckets = [
                { key: '0_10', label: '0–10%', count: 0 },
                { key: '10_20', label: '10–20%', count: 0 },
                { key: '20_30', label: '20–30%', count: 0 },
                { key: '30_40', label: '30–40%', count: 0 },
                { key: '40_50', label: '40–50%', count: 0 },
                { key: '50_100', label: '50–100%', count: 0 },
                { key: '100_plus', label: '>100%', count: 0 }
              ];
              function bucketOf(v){
                if (v > 100) return 6;
                if (v >= 50) return 5;
                if (v >= 40) return 4;
                if (v >= 30) return 3;
                if (v >= 20) return 2;
                if (v >= 10) return 1;
                return 0;
              }
              for (var i=0;i<rows.length;i++){
                var tr = rows[i];
                var checkedMs = Number(tr.getAttribute('data-checkedatms') || 0) || 0;
                if (checkedMs > 0) checked += 1;
                var checkedMsRaw = Number(tr.getAttribute('data-checkedatmsraw') || 0) || 0;
                if (!(checkedMsRaw > 0)) continue;
                var pctCell = tr.querySelector('.cell-pct');
                var pctTxt = pctCell ? String(pctCell.textContent || '').trim() : '';
                if (pctTxt === 'OK') {
                  checkedValid += 1;
                  ok += 1;
                } else {
                  notOk += 1;
                  if (pctTxt && pctTxt.indexOf('%') > -1) {
                    var num = Number(pctTxt.replace('%','').replace(/\./g,'').replace(',', '.'));
                    if (isFinite(num) && num > 0) {
                      checkedValid += 1;
                      withDrop += 1;
                      var idx = bucketOf(num);
                      if (buckets[idx]) buckets[idx].count += 1;
                    }
                  }
                }
              }
              var base = Math.max(1, withDrop);
              var bucketsOut = buckets.map(function(b){
                return { key: b.key, label: b.label, count: b.count, pct: Math.round((b.count / base) * 1000) / 10 };
              });
              return {
                total: total,
                checked: checked,
                checkedValid: checkedValid,
                checkedPct: total ? (Math.round((checked / total) * 1000) / 10) : 0,
                withDrop: withDrop,
                ok: ok,
                notOk: notOk,
                okPct: checked ? (Math.round((ok / checked) * 1000) / 10) : 0,
                buckets: bucketsOut
              };
            } catch (_) {
              return null;
            }
          }

          function computePurchaseAgeDropReportFromTable(){
            try {
              var rows = getAllRows();
              var nowMs = Date.now();
              function brtDay(ms){
                var n = Number(ms || 0) || 0;
                var brtOffset = 3 * 60 * 60 * 1000;
                return Math.floor((n - brtOffset) / (24 * 60 * 60 * 1000));
              }
              var buckets = [
                { key: 'lt_3', label: '<3 dias', count: 0 },
                { key: '3_7', label: '3–7 dias', count: 0 },
                { key: '7_14', label: '7–14 dias', count: 0 },
                { key: '14_30', label: '14–30 dias', count: 0 },
                { key: 'gt_30', label: '>30 dias', count: 0 }
                ,{ key: 'no_date', label: 'Sem data', count: 0 }
              ];
              var total = 0;
              for (var i=0;i<rows.length;i++){
                var tr = rows[i];
                var checkedMsRaw = Number(tr.getAttribute('data-checkedatmsraw') || 0) || 0;
                if (!(checkedMsRaw > 0)) continue;
                var pctCell = tr.querySelector('.cell-pct');
                var pctTxt = pctCell ? String(pctCell.textContent || '').trim() : '';
                if (pctTxt === 'OK') continue;
                var purchaseAtMs = Number(tr.getAttribute('data-purchaseatms') || 0) || 0;
                total += 1;
                if (!(purchaseAtMs > 0)) {
                  buckets[5].count += 1;
                } else {
                  var ageDays = brtDay(nowMs) - brtDay(purchaseAtMs);
                  if (!isFinite(ageDays) || ageDays < 0) ageDays = 0;
                  if (ageDays < 3) buckets[0].count += 1;
                  else if (ageDays < 7) buckets[1].count += 1;
                  else if (ageDays < 14) buckets[2].count += 1;
                  else if (ageDays < 30) buckets[3].count += 1;
                  else buckets[4].count += 1;
                }
              }
              var base = Math.max(1, total);
              var out = buckets.map(function(b){
                var c = Math.max(0, Math.floor(Number(b.count || 0) || 0));
                return { key: b.key, label: b.label, count: c, pct: Math.round((c / base) * 1000) / 10 };
              });
              return { total: Math.max(0, Math.floor(Number(total || 0) || 0)), buckets: out };
            } catch (_) {
              return null;
            }
          }

          function computeAbsDiffThresholdReportFromTable(thresholdAbs){
            try {
              var thr = Number(thresholdAbs || 100) || 100;
              var rows = getAllRows();
              var base = 0;
              var gte = 0;
              var lt = 0;
              for (var i=0;i<rows.length;i++){
                var tr = rows[i];
                var checkedMsRaw = Number(tr.getAttribute('data-checkedatmsraw') || 0) || 0;
                if (!(checkedMsRaw > 0)) continue;
                var abs = Number(tr.getAttribute('data-diffabs') || 0);
                if (!isFinite(abs) || abs <= 0) continue;
                base += 1;
                if (abs >= thr) gte += 1;
                else lt += 1;
              }
              var denom = Math.max(1, base);
              return {
                thresholdAbs: thr,
                base: base,
                gteCount: gte,
                ltCount: lt,
                gtePct: Math.round((gte / denom) * 1000) / 10,
                ltPct: Math.round((lt / denom) * 1000) / 10
              };
            } catch (_) {
              return null;
            }
          }

          function drawPie(canvas, items){
            if (!canvas || !canvas.getContext) return;
            var ctx = canvas.getContext('2d');
            if (!ctx) return;
            var w = canvas.width || 260;
            var h = canvas.height || 260;
            var cx = Math.floor(w/2);
            var cy = Math.floor(h/2);
            var r = Math.floor(Math.min(w,h)/2) - 6;
            ctx.clearRect(0,0,w,h);
            var total = 0;
            for (var i=0;i<items.length;i++){ total += Number(items[i].count || 0) || 0; }
            if (!total) {
              ctx.beginPath();
              ctx.arc(cx, cy, r, 0, Math.PI*2);
              ctx.fillStyle = '#f3f4f6';
              ctx.fill();
              ctx.fillStyle = '#6b7280';
              ctx.font = 'bold 14px Arial';
              ctx.textAlign = 'center';
              ctx.textBaseline = 'middle';
              ctx.fillText('Sem dados', cx, cy);
              return;
            }
            var start = -Math.PI/2;
            for (var j=0;j<items.length;j++){
              var c = Number(items[j].count || 0) || 0;
              if (c <= 0) continue;
              var ang = (c / total) * Math.PI*2;
              ctx.beginPath();
              ctx.moveTo(cx, cy);
              ctx.arc(cx, cy, r, start, start + ang);
              ctx.closePath();
              ctx.fillStyle = String(items[j].color || '#111827');
              ctx.fill();
              start += ang;
            }
            ctx.beginPath();
            ctx.arc(cx, cy, Math.max(0, r - 70), 0, Math.PI*2);
            ctx.fillStyle = '#ffffff';
            ctx.fill();
            ctx.fillStyle = '#111827';
            ctx.font = 'bold 16px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(String(total), cx, cy - 10);
            ctx.fillStyle = '#6b7280';
            ctx.font = '12px Arial';
            ctx.fillText('com queda', cx, cy + 12);
          }

