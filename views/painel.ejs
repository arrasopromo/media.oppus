              </tbody>
            </table>
          </div>
        </div>

        <div style="display:flex; gap: 18px; align-items:flex-start; flex-wrap: wrap; margin-top: 14px;">
          <div style="flex: 1 1 520px; min-width: 320px;">
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px;">
              <div style="border:1px solid #eee; border-radius: 8px; padding: 12px; background:#fff;">
                <div style="font-weight: 700; margin-bottom: 8px; color:#111827;">Top 5 usuários (mais pedidos)</div>
                <table style="width:100%; border-collapse: collapse; font-size: 0.92rem;">
                  <thead>
                    <tr>
                      <th style="text-align:left; padding:6px 0; border-bottom:1px solid #f1f1f1;">Usuário</th>
                      <th style="text-align:right; padding:6px 0; border-bottom:1px solid #f1f1f1;">Pedidos</th>
                      <th style="text-align:right; padding:6px 0; border-bottom:1px solid #f1f1f1;">Gasto</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% (Array.isArray(topUsersByOrders) ? topUsersByOrders : []).slice(0,5).forEach(u => { %>
                      <tr>
                        <td style="padding:6px 0; border-bottom:1px solid #fafafa;"><%= String(u && u.label ? u.label : '-') %></td>
                        <td style="padding:6px 0; border-bottom:1px solid #fafafa; text-align:right;"><%= Number(u && u.orders ? u.orders : 0) %></td>
                        <td style="padding:6px 0; border-bottom:1px solid #fafafa; text-align:right;">R$ <%= Number(u && u.spend ? u.spend : 0).toFixed(2).replace('.', ',') %></td>
                      </tr>
                    <% }) %>
                    <% if (!(Array.isArray(topUsersByOrders) && topUsersByOrders.length)) { %>
                      <tr><td colspan="3" style="padding:8px 0; color:#6b7280;">Sem dados</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <div style="border:1px solid #eee; border-radius: 8px; padding: 12px; background:#fff;">
                <div style="font-weight: 700; margin-bottom: 8px; color:#111827;">Top 5 usuários (maior gasto)</div>
                <table style="width:100%; border-collapse: collapse; font-size: 0.92rem;">
                  <thead>
                    <tr>
                      <th style="text-align:left; padding:6px 0; border-bottom:1px solid #f1f1f1;">Usuário</th>
                      <th style="text-align:right; padding:6px 0; border-bottom:1px solid #f1f1f1;">Gasto</th>
                      <th style="text-align:right; padding:6px 0; border-bottom:1px solid #f1f1f1;">Pedidos</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% (Array.isArray(topUsersBySpend) ? topUsersBySpend : []).slice(0,5).forEach(u => { %>
                      <tr>
                        <td style="padding:6px 0; border-bottom:1px solid #fafafa;"><%= String(u && u.label ? u.label : '-') %></td>
                        <td style="padding:6px 0; border-bottom:1px solid #fafafa; text-align:right;">R$ <%= Number(u && u.spend ? u.spend : 0).toFixed(2).replace('.', ',') %></td>
                        <td style="padding:6px 0; border-bottom:1px solid #fafafa; text-align:right;"><%= Number(u && u.orders ? u.orders : 0) %></td>
                      </tr>
                    <% }) %>
                    <% if (!(Array.isArray(topUsersBySpend) && topUsersBySpend.length)) { %>
                      <tr><td colspan="3" style="padding:8px 0; color:#6b7280;">Sem dados</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div id="ltvCustomersModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:1000; align-items:center; justify-content:center; padding: 14px;">
          <div style="background:#fff; width:min(980px, 96vw); max-height: 90vh; border-radius: 10px; overflow:hidden; box-shadow:0 8px 24px rgba(0,0,0,0.15);">
            <div style="display:flex; align-items:center; justify-content:space-between; padding: 12px 14px; border-bottom:1px solid #e5e7eb; gap: 10px;">
              <strong id="ltvCustomersModalTitle" style="color:#111827;">Clientes</strong>
              <button type="button" id="ltvCustomersModalClose" style="padding:6px 10px; border:1px solid #e5e7eb; background:#fff; border-radius:8px; cursor:pointer;">Fechar</button>
            </div>
            <div style="padding: 12px 14px; overflow:auto; max-height: calc(90vh - 52px);">
              <div style="display:flex; gap: 10px; flex-wrap: wrap; align-items:center; margin-bottom: 10px;">
                <input id="ltvCustomersSearch" type="text" placeholder="Buscar por usuário/telefone/email" style="flex:1 1 280px; padding: 8px 10px; border:1px solid #e5e7eb; border-radius: 8px;" />
                <div id="ltvCustomersCount" style="font-size:0.9rem; color:#6b7280;"></div>
              </div>
              <div class="panel-table-scroll">
                <table style="width:100%; border-collapse: collapse; font-size: 0.92rem;">
                  <thead>
                    <tr>
                      <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Usuário</th>
                      <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Telefone</th>
                      <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Email</th>
                      <th style="text-align:right; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Pedidos</th>
                      <th style="text-align:right; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Gasto</th>
                    </tr>
                  </thead>
                  <tbody id="ltvCustomersTbody">
                    <tr><td colspan="5" style="padding:10px 6px; color:#6b7280;">Carregando...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <script type="application/json" id="ltvCustomersData"><%- JSON.stringify(Array.isArray(customerRows) ? customerRows : []) %></script>
        <script>
          (function(){
            function readJson(id, fallback) {
              try {
                var el = document.getElementById(id);
                if (!el) return fallback;
                var raw = String(el.textContent || '').trim();
                if (!raw) return fallback;
                return JSON.parse(raw);
              } catch (_) {
                return fallback;
              }
            }
            function fmtMoney(n) {
              var x = Number(n || 0);
              if (!isFinite(x)) x = 0;
              return 'R$ ' + x.toFixed(2).replace('.', ',');
            }
            function safeStr(v) { return String(v == null ? '' : v); }
            var all = readJson('ltvCustomersData', []);
            var modal = document.getElementById('ltvCustomersModal');
            var titleEl = document.getElementById('ltvCustomersModalTitle');
            var closeBtn = document.getElementById('ltvCustomersModalClose');
            var tbody = document.getElementById('ltvCustomersTbody');
            var searchEl = document.getElementById('ltvCustomersSearch');
            var countEl = document.getElementById('ltvCustomersCount');
            var cardAll = document.getElementById('ltvCardAllCustomers');
            var cardRepeat = document.getElementById('ltvCardRepeatCustomers');
            if (!modal || !tbody) return;

            var mode = 'all';

            function open(newMode) {
              mode = newMode || 'all';
              if (titleEl) titleEl.textContent = mode === 'repeat' ? 'Clientes recorrentes (2+)' : 'Clientes únicos';
              if (searchEl) searchEl.value = '';
              modal.style.display = 'flex';
              render();
              if (searchEl) searchEl.focus();
            }
            function close() {
              modal.style.display = 'none';
            }
            function matchesFilter(row, q) {
              if (!q) return true;
              var s = (safeStr(row.username) + ' ' + safeStr(row.phone) + ' ' + safeStr(row.email) + ' ' + safeStr(row.label)).toLowerCase();
              return s.indexOf(q) >= 0;
            }
            function render() {
              var q = searchEl ? String(searchEl.value || '').trim().toLowerCase() : '';
              var rows = Array.isArray(all) ? all.slice() : [];
              if (mode === 'repeat') rows = rows.filter(function(r){ return Number(r && r.orders ? r.orders : 0) > 1; });
              rows = rows.filter(function(r){ return matchesFilter(r, q); });

              if (countEl) countEl.textContent = rows.length + ' clientes';
              tbody.innerHTML = '';
              if (!rows.length) {
                var tr0 = document.createElement('tr');
                var td0 = document.createElement('td');
                td0.colSpan = 5;
                td0.style.padding = '10px 6px';
                td0.style.color = '#6b7280';
                td0.textContent = 'Sem dados';
                tr0.appendChild(td0);
                tbody.appendChild(tr0);
                return;
              }

              for (var i = 0; i < rows.length; i++) {
                var r = rows[i] || {};
                var tr = document.createElement('tr');
                var userTd = document.createElement('td');
                userTd.style.padding = '8px 6px';
                userTd.style.borderBottom = '1px solid #f3f4f6';
                userTd.textContent = safeStr(r.username || r.label || '-');

                var phoneTd = document.createElement('td');
                phoneTd.style.padding = '8px 6px';
                phoneTd.style.borderBottom = '1px solid #f3f4f6';
                phoneTd.textContent = safeStr(r.phone || '-');

                var emailTd = document.createElement('td');
                emailTd.style.padding = '8px 6px';
                emailTd.style.borderBottom = '1px solid #f3f4f6';
                emailTd.textContent = safeStr(r.email || '-');

                var ordersTd = document.createElement('td');
                ordersTd.style.padding = '8px 6px';
                ordersTd.style.borderBottom = '1px solid #f3f4f6';
                ordersTd.style.textAlign = 'right';
                ordersTd.textContent = String(Number(r.orders || 0));

                var spendTd = document.createElement('td');
                spendTd.style.padding = '8px 6px';
                spendTd.style.borderBottom = '1px solid #f3f4f6';
                spendTd.style.textAlign = 'right';
                spendTd.textContent = fmtMoney(r.spend || 0);

                tr.appendChild(userTd);
                tr.appendChild(phoneTd);
                tr.appendChild(emailTd);
                tr.appendChild(ordersTd);
                tr.appendChild(spendTd);
                tbody.appendChild(tr);
              }
            }

            if (cardAll) cardAll.addEventListener('click', function(){ open('all'); });
            if (cardRepeat) cardRepeat.addEventListener('click', function(){ open('repeat'); });
            if (closeBtn) closeBtn.addEventListener('click', close);
            if (searchEl) searchEl.addEventListener('input', render);
            modal.addEventListener('click', function(e){
              if (e && e.target === modal) close();
            });
            document.addEventListener('keydown', function(e){
              if (modal.style.display !== 'none' && e && e.key === 'Escape') close();
            });
          })();
        </script>
      </div>
    <% } %>

    <% if (!isLtvView && !isWhatsappSalesView && !isFollowersMgmtView) { %>
    <div class="dashboard-layout">
      <div class="dashboard-main">
        <% if (isUnknownOrderIdView) { %>
          <div style="display:flex; gap:10px; align-items:center; flex-wrap: wrap; margin-bottom: 10px;">
            <button type="button" class="unknown-btn" onclick="hideSelectedUnknown()">Ocultar selecionados</button>
            <button type="button" class="unknown-btn" style="background:#6c757d;" onclick="clearHiddenOrders()">Mostrar tudo</button>
            <button type="button" id="unknownRefreshBtn" class="unknown-btn" style="background:#111827;" onclick="refreshUnknownPrivatesAndLinks()">Atualizar privados/links</button>
