                      backgroundColor: 'rgba(22, 163, 74, 0.15)',
                      tension: 0.3,
                      fill: true,
                      pointRadius: 2
                    }]
                  },
                  options: {
                    responsive: true,
                    plugins: {
                      legend: { display: false },
                      tooltip: {
                        callbacks: {
                          label: function(ctx){
                            try {
                              var idx = Number(ctx.dataIndex || 0);
                              var paid = Array.isArray(pv.dailyPaid) ? Number(pv.dailyPaid[idx] || 0) : 0;
                              var val = Array.isArray(pv.dailyValidated) ? Number(pv.dailyValidated[idx] || 0) : 0;
                              return (Number(ctx.parsed && ctx.parsed.y ? ctx.parsed.y : 0).toFixed(1) + '% (' + paid + '/' + val + ')');
                            } catch (_) {
                              return (Number(ctx.parsed && ctx.parsed.y ? ctx.parsed.y : 0).toFixed(1) + '%');
                            }
                          }
                        }
                      }
                    },
                    scales: {
                      y: {
                        min: 0,
                        max: 100,
                        ticks: { callback: function(v){ return Number(v || 0).toFixed(0) + '%'; } }
                      }
                    }
                  }
                });
              }

              var brRawEl = document.getElementById('bumpRevenueSeriesData');
              var brRaw = brRawEl ? String(brRawEl.textContent || '').trim() : '';
              var br = brRaw ? JSON.parse(brRaw) : { labels: [], dailyPct: [], dailyTotalRevenue: [], dailyBumpRevenue: [] };
              var brLabels = Array.isArray(br.labels) ? br.labels : [];
              var brLabelShort = brLabels.map(fmt);
              var brCtx = document.getElementById('orderBumpPctTimelineChart');
              if (brCtx) {
                new Chart(brCtx, {
                  type: 'line',
                  data: {
                    labels: brLabelShort,
                    datasets: [{
                      label: '% orderbump',
                      data: Array.isArray(br.dailyPct) ? br.dailyPct : [],
                      borderColor: '#7c3aed',
                      backgroundColor: 'rgba(124, 58, 237, 0.15)',
                      tension: 0.3,
                      fill: true,
                      pointRadius: 2
                    }]
                  },
                  options: {
                    responsive: true,
                    plugins: {
                      legend: { display: false },
                      tooltip: {
                        callbacks: {
                          label: function(ctx){
                            try {
                              var idx = Number(ctx.dataIndex || 0);
                              var pct = Number(ctx.parsed && ctx.parsed.y ? ctx.parsed.y : 0);
                              var bump = Array.isArray(br.dailyBumpRevenue) ? Number(br.dailyBumpRevenue[idx] || 0) : 0;
                              var tot = Array.isArray(br.dailyTotalRevenue) ? Number(br.dailyTotalRevenue[idx] || 0) : 0;
                              return pct.toFixed(1) + '% (R$ ' + bump.toFixed(2).replace('.', ',') + ' de R$ ' + tot.toFixed(2).replace('.', ',') + ')';
                            } catch (_) {
                              return (Number(ctx.parsed && ctx.parsed.y ? ctx.parsed.y : 0).toFixed(1) + '%');
                            }
                          }
                        }
                      }
                    },
                    scales: {
                      y: { min: 0, max: 100, ticks: { callback: function(v){ return Number(v || 0).toFixed(0) + '%'; } } }
                    }
                  }
                });
              }
            } catch (_) {}
          })();
        </script>
      </div>
      <% } %>
