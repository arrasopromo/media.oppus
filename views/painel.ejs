                  <td><%= order.qty %></td>
                  <td>R$ <%= order.costPer1000.toFixed(2).replace('.', ',') %></td>
                  <td>R$ <%= (function(){ try { var n = Number(order && typeof order.paymentFee !== 'undefined' ? order.paymentFee : NaN); if (isFinite(n) && n > 0) return n.toFixed(2).replace('.', ','); var pm = String(order && (order.paymentMethod || order.payment_method || order.method) ? (order.paymentMethod || order.payment_method || order.method) : '').toLowerCase(); if (pm.indexOf('paghiper') >= 0) return '0,99'; return '0,85'; } catch(_) { return '0,85'; } })() %></td>
                  <td><%= (order.orderBumps || '-') %></td>
                  <td style="text-align:center;">
                    <button type="button" class="sale-delete-btn" data-sale-id="<%= String(order._id || '') %>" style="background:#dc3545; color:#fff; border:none; border-radius:8px; width:32px; height:32px; font-weight:900; cursor:pointer;">x</button>
                  </td>
                  <td>
                    R$ <%= (typeof order.bumpCost !== 'undefined' ? order.bumpCost : 0).toFixed(2).replace('.', ',') %>
                    <% if (order.orderBumpsTotal) { %>
                      <div><small style="color:#666;"><%= order.orderBumpsTotal %></small></div>
                    <% } %>
                  </td>
                  <td>R$ <%= order.cost.toFixed(2).replace('.', ',') %></td>
                  <td>R$ <%= (typeof order.totalPaid !== 'undefined' ? Number(order.totalPaid || 0) : 0).toFixed(2).replace('.', ',') %></td>
                </tr>
              <% }) %>
            </tbody>
