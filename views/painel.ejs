            </thead>
            <tbody>
              <%
                const formatDateTimeSP = (v) => {
                  try {
                    const d0 = (v instanceof Date) ? v : new Date(v || '');
                    if (!d0 || Number.isNaN(d0.getTime())) return '-';
                    const fmt = new Intl.DateTimeFormat('pt-BR', {
                      timeZone: 'America/Sao_Paulo',
                      year: 'numeric',
                      month: '2-digit',
                      day: '2-digit',
                      hour: '2-digit',
                      minute: '2-digit',
                      hour12: false
                    });
                    const parts = fmt.formatToParts(d0);
                    const get = (t) => {
                      const p = parts.find(x => x && x.type === t);
                      return p ? String(p.value || '') : '';
                    };
                    const dd = get('day');
                    const mm = get('month');
                    const yyyy = get('year');
                    const hh = get('hour');
                    const mn = get('minute');
                    if (!dd || !mm || !yyyy || !hh || !mn) return fmt.format(d0);
                    return `${dd}/${mm}/${yyyy} ${hh}:${mn}`;
                  } catch (_) {
                    return '-';
                  }
                };
              %>
              <% orders.forEach(order => { %>
                <% 
                   const dateStr = formatDateTimeSP(order.createdAt);
                   const userLabel = String(order.instagramUsername ? ('@' + String(order.instagramUsername).replace(/^@+/, '')) : (order.customerLabel || '-'));
                %>
                <tr>
                  <td><%= dateStr %></td>
                  <td><%= userLabel %></td>
