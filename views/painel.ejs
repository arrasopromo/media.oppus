                const ltvDashRepeatCustomers = ltvDash && typeof ltvDash.repeatCustomers !== 'undefined' ? ltvDash.repeatCustomers : 0;
                const ltvDashRepeatPct = ltvDash && typeof ltvDash.repeatCustomerPct !== 'undefined' ? ltvDash.repeatCustomerPct : 0;
                const ltvDashTotalTx = ltvDash && typeof ltvDash.totalTransactions !== 'undefined' ? ltvDash.totalTransactions : 0;
