                const ltvDashTopByOrders = ltvDash && Array.isArray(ltvDash.topUsersByOrders) ? ltvDash.topUsersByOrders : [];
                const ltvDashTopBySpend = ltvDash && Array.isArray(ltvDash.topUsersBySpend) ? ltvDash.topUsersBySpend : [];
