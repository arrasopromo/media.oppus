                  </div>
                </div>
                <script type="application/json" id="dashboardPaymentMethodData"><%- JSON.stringify(Array.isArray(paymentPie) ? paymentPie : []) %></script>
                <script type="application/json" id="dashboardServiceTypePieData"><%- JSON.stringify(Array.isArray(servicePie) ? servicePie : []) %></script>
                <script type="application/json" id="dashboardChannelPieData"><%- JSON.stringify(Array.isArray(channelPie) ? channelPie : []) %></script>
                <script type="application/json" id="dashboardPlatformPieData"><%- JSON.stringify(Array.isArray(platformPie) ? platformPie : []) %></script>
                <script>
                  (function(){
                    try {
                      if (typeof Chart === 'undefined') return;
                      function toNum(v) {
                        var n = Number(v);
                        return isFinite(n) ? n : 0;
                      }
                      function buildPie(items) {
                        var arr = Array.isArray(items) ? items : [];
                        var baseLabels = arr.map(function(x){ return String(x && x.label ? x.label : '-'); });
                        var values = arr.map(function(x){ return toNum(x && typeof x.count !== 'undefined' ? x.count : 0); });
                        var total = values.reduce(function(acc, v){ return acc + (toNum(v) || 0); }, 0);
                        var labels = baseLabels.map(function(lbl, idx){
                          var v = toNum(values[idx]);
                          var pct = (total > 0 && v > 0) ? ((v / total) * 100) : 0;
                          return String(lbl) + ' · ' + String(Math.round(v)) + ' · ' + pct.toFixed(1).replace('.', ',') + '%';
                        });
                        var colors = arr.map(function(x){ return String(x && x.color ? x.color : '#e5e7eb'); });
                        return { baseLabels: baseLabels, labels: labels, values: values, colors: colors, total: total };
                      }
                      var donutLabelsPlugin = {
                        id: 'donutLabelsPlugin',
                        afterDatasetDraw: function(chart, args) {
                          try {
                            if (!chart || !chart.ctx) return;
                            var ctx = chart.ctx;
                            var meta = chart.getDatasetMeta(args.index);
                            if (!meta || !meta.data) return;
                            var data = chart.data && chart.data.datasets && chart.data.datasets[args.index] ? chart.data.datasets[args.index].data : [];
                            var total = (data || []).reduce(function(acc, v){ return acc + (toNum(v) || 0); }, 0);
                            if (!(total > 0)) return;
                            var leftYs = [];
                            var rightYs = [];
                            function placeY(y, sideArr) {
                              var yy = Number(y) || 0;
                              var tries = 0;
                              while (tries < 40) {
                                var ok = true;
                                for (var i = 0; i < sideArr.length; i++) {
                                  if (Math.abs(sideArr[i] - yy) < 12) { ok = false; break; }
                                }
                                if (ok) break;
                                yy += 12;
                                tries++;
                              }
                              sideArr.push(yy);
                              return yy;
                            }
                            ctx.save();
                            ctx.fillStyle = '#111827';
                            ctx.strokeStyle = '#94a3b8';
                            ctx.lineWidth = 1;
                            ctx.textBaseline = 'middle';
                            ctx.font = '700 11px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif';
                            for (var i = 0; i < meta.data.length; i++) {
                              var v = toNum(data && typeof data[i] !== 'undefined' ? data[i] : 0);
                              if (!(v > 0)) continue;
                              var pct = (v / total) * 100;
                              var el = meta.data[i];
                              if (!el) continue;
                              var text = String(Math.round(v)) + ' (' + pct.toFixed(0) + '%)';
                              if (pct >= 3.5) {
                                ctx.textAlign = 'center';
                                var p = (typeof el.getCenterPoint === 'function') ? el.getCenterPoint() : null;
                                if (p) ctx.fillText(text, p.x, p.y);
                                continue;
                              }
                              var angle = (typeof el.startAngle === 'number' && typeof el.endAngle === 'number') ? ((el.startAngle + el.endAngle) / 2) : 0;
                              var cx = (typeof el.x === 'number') ? el.x : (chart.chartArea ? (chart.chartArea.left + chart.chartArea.right) / 2 : 0);
                              var cy = (typeof el.y === 'number') ? el.y : (chart.chartArea ? (chart.chartArea.top + chart.chartArea.bottom) / 2 : 0);
                              var or = (typeof el.outerRadius === 'number') ? el.outerRadius : 0;
                              var x0 = cx + Math.cos(angle) * or;
                              var y0 = cy + Math.sin(angle) * or;
                              var sideRight = Math.cos(angle) >= 0;
                              var x1 = cx + Math.cos(angle) * (or + 18);
                              var y1 = cy + Math.sin(angle) * (or + 18);
                              y1 = placeY(y1, sideRight ? rightYs : leftYs);
                              var x2 = x1 + (sideRight ? 18 : -18);
                              ctx.beginPath();
                              ctx.moveTo(x0, y0);
                              ctx.lineTo(x1, y1);
                              ctx.lineTo(x2, y1);
                              ctx.stroke();
                              ctx.textAlign = sideRight ? 'left' : 'right';
                              ctx.fillText(text, x2 + (sideRight ? 2 : -2), y1);
                            }
                            ctx.restore();
                          } catch (_) {}
                        }
                      };
                      var chEl = document.getElementById('dashboardChannelPieData');
                      var chRaw = chEl ? String(chEl.textContent || '').trim() : '[]';
                      var ch = JSON.parse(chRaw || '[]');
                      var chCanvas = document.getElementById('dashboardChannelPieChart');
                      if (chCanvas) {
                        var c = buildPie(ch);
                        new Chart(chCanvas, {
                          plugins: [donutLabelsPlugin],
                          type: 'doughnut',
                          data: { labels: c.labels, datasets: [{ data: c.values, backgroundColor: c.colors, borderWidth: 0 }] },
                          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', align: 'center', labels: { boxWidth: 10, boxHeight: 10 } }, tooltip: { callbacks: { label: function(ctx){ return String(ctx && ctx.label ? ctx.label : ''); } } } }, cutout: '60%' }
                        });
                      }
                      var platEl = document.getElementById('dashboardPlatformPieData');
                      var platRaw = platEl ? String(platEl.textContent || '').trim() : '[]';
                      var plat = JSON.parse(platRaw || '[]');
                      var platCanvas = document.getElementById('dashboardPlatformPieChart');
                      if (platCanvas) {
                        var pl = buildPie(plat);
                        new Chart(platCanvas, {
                          plugins: [donutLabelsPlugin],
                          type: 'doughnut',
                          data: { labels: pl.labels, datasets: [{ data: pl.values, backgroundColor: pl.colors, borderWidth: 0 }] },
                          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', align: 'center', labels: { boxWidth: 10, boxHeight: 10 } }, tooltip: { callbacks: { label: function(ctx){ return String(ctx && ctx.label ? ctx.label : ''); } } } }, cutout: '60%' }
                        });
                      }
                      var payEl = document.getElementById('dashboardPaymentMethodData');
                      var payRaw = payEl ? String(payEl.textContent || '').trim() : '[]';
                      var pay = JSON.parse(payRaw || '[]');
                      var payCanvas = document.getElementById('dashboardPaymentMethodChart');
                      if (payCanvas) {
                        var p = buildPie(pay);
                        new Chart(payCanvas, {
                          plugins: [donutLabelsPlugin],
                          type: 'doughnut',
                          data: {
                            labels: p.labels,
                            datasets: [{
                              data: p.values,
                              backgroundColor: p.colors,
                              borderWidth: 0
                            }]
                          },
                          options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                              legend: {
                                position: 'right',
                                align: 'center',
                                labels: {
                                  boxWidth: 10,
                                  boxHeight: 10
                                }
                              },
                              tooltip: {
                                callbacks: {
                                  label: function(ctx){
                                    try {
                                      var lbl = String(ctx && ctx.label ? ctx.label : '');
                                      return lbl;
                                    } catch (_) {
                                      return '';
                                    }
                                  }
                                }
                              }
                            },
                            cutout: '60%'
                          }
                        });
                      }
                      var svcEl = document.getElementById('dashboardServiceTypePieData');
                      var svcRaw = svcEl ? String(svcEl.textContent || '').trim() : '[]';
                      var svc = JSON.parse(svcRaw || '[]');
                      var svcCanvas = document.getElementById('dashboardServiceTypePieChart');
                      if (svcCanvas) {
                        var s = buildPie(svc);
                        new Chart(svcCanvas, {
                          plugins: [donutLabelsPlugin],
                          type: 'doughnut',
                          data: {
                            labels: s.labels,
                            datasets: [{
                              data: s.values,
                              backgroundColor: s.colors,
                              borderWidth: 0
                            }]
                          },
                          options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                              legend: {
                                position: 'right',
                                align: 'center',
                                labels: {
                                  boxWidth: 10,
                                  boxHeight: 10
                                }
                              },
                              tooltip: {
                                callbacks: {
                                  label: function(ctx){
                                    try {
                                      var lbl = String(ctx && ctx.label ? ctx.label : '');
                                      return lbl;
                                    } catch (_) {
                                      return '';
                                    }
                                  }
                                }
                              }
                            },
                            cutout: '60%'
                          }
                        });
                      }
                    } catch (_) {}
                  })();
                </script>
              </div>
            <div id="dashboardLtvWrap" style="margin-top: 14px; width:100%; border:1px solid #e5e7eb; border-radius:10px; background:#fff; padding:14px; box-sizing:border-box;">
              <%
                const ltvDash = (typeof ltvAllTime !== 'undefined' && ltvAllTime) ? ltvAllTime : null;
