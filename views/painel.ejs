      <% 
        const buildFollowersUrl = (targetPage) => {
          const parts = [];
          const ps = (pagination && pagination.pageSize) ? pagination.pageSize : 50;
          if (ps) parts.push(`pageSize=${encodeURIComponent(String(ps))}`);
          if (filters && filters.q) parts.push(`q=${encodeURIComponent(String(filters.q))}`);
          if (filters && filters.qType) parts.push(`qType=${encodeURIComponent(String(filters.qType))}`);
          if (filters && filters.filled) parts.push(`filled=1`);
          if (filters && filters.errors) parts.push(`errors=1`);
          if (filters && filters.emailFailed) parts.push(`emailFailed=1`);
          if (filters && filters.notifiedOnly) parts.push(`notified=1`);
          if (filters && filters.ok) parts.push(`ok=1`);
          if (filters && filters.warranty) parts.push(`warranty=${encodeURIComponent(String(filters.warranty))}`);
          else if (filters && filters.lifetime) parts.push(`lifetime=1`);
          if (filters && filters.startDate) parts.push(`startDate=${encodeURIComponent(String(filters.startDate))}`);
          if (filters && filters.endDate) parts.push(`endDate=${encodeURIComponent(String(filters.endDate))}`);
          if (filters && filters.dateField && String(filters.dateField) !== 'purchase') parts.push(`dateField=${encodeURIComponent(String(filters.dateField))}`);
          if (filters && filters.tipo) parts.push(`tipo=${encodeURIComponent(String(filters.tipo))}`);
          if (filters && typeof filters.minPct === 'number') parts.push(`minPct=${encodeURIComponent(String(filters.minPct))}`);
          if (filters && typeof filters.maxPct === 'number') parts.push(`maxPct=${encodeURIComponent(String(filters.maxPct))}`);
          if (filters && typeof filters.minDiffAbs === 'number') parts.push(`minDiffAbs=${encodeURIComponent(String(filters.minDiffAbs))}`);
          if (filters && filters.sortBy) parts.push(`sortBy=${encodeURIComponent(String(filters.sortBy))}`);
          if (filters && filters.sortDir) parts.push(`sortDir=${encodeURIComponent(String(filters.sortDir))}`);
          parts.push(`page=${encodeURIComponent(String(targetPage || 1))}`);
          return '/painel/gerenciamento-seguidores' + (parts.length ? ('?' + parts.join('&')) : '');
        };
        const curPage = (pagination && pagination.page) ? pagination.page : 1;
        const totalPages = (pagination && pagination.totalPages) ? pagination.totalPages : 1;
