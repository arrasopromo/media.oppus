                <% const r2a = (filters && filters.refil2Auto) ? String(filters.refil2Auto) : 'all'; %>
                <option value="all" <%= (!r2a || r2a === 'all') ? 'selected' : '' %>>Todos</option>
                <option value="yes" <%= (r2a === 'yes') ? 'selected' : '' %>>Solicitado</option>
                <option value="no" <%= (r2a === 'no') ? 'selected' : '' %>>Não solicitado</option>
              </select>
            </label>
            <label style="display:flex; align-items:center; gap:6px; font-size:0.9rem; color:#444; margin:0;">
              <span>Diferença mín:</span>
              <input id="followersMinDiffAbs" type="number" min="0" step="1" value="<%= (filters && typeof filters.minDiffAbs === 'number') ? String(filters.minDiffAbs) : '' %>" placeholder="ex: 100" style="width:120px; padding:6px; border:1px solid #ccc; border-radius:4px;" />
            </label>
            <label style="display:flex; align-items:center; gap:6px; font-size:0.9rem; color:#444; margin:0;">
              <span>Queda (%):</span>
              <%
                const fpMin = (filters && typeof filters.minPct === 'number') ? Number(filters.minPct) : null;
                const fpMax = (filters && typeof filters.maxPct === 'number') ? Number(filters.maxPct) : null;
                const bucket = (() => {
                  if (fpMin == null && fpMax == null) return '';
                  if (fpMin != null && fpMin >= 100 && fpMax == null) return '100plus';
                  const candidates = [10,20,30,40,50,60,70,80,90];
                  for (const b of candidates) {
                    if (fpMin != null && fpMax != null && Math.abs(fpMin - b) < 0.0001 && fpMax >= (b + 9.5) && fpMax <= (b + 10)) return String(b);
                  }
                  return 'custom';
                })();
              %>
              <select id="followersPctBucket" style="padding:6px; border:1px solid #ccc; border-radius:4px;">
                <option value="" <%= (!bucket) ? 'selected' : '' %>>Todos</option>
                <option value="custom" <%= (bucket === 'custom') ? 'selected' : '' %>>Personalizado</option>
                <option value="10" <%= (bucket === '10') ? 'selected' : '' %>>10–19%</option>
                <option value="20" <%= (bucket === '20') ? 'selected' : '' %>>20–29%</option>
                <option value="30" <%= (bucket === '30') ? 'selected' : '' %>>30–39%</option>
                <option value="40" <%= (bucket === '40') ? 'selected' : '' %>>40–49%</option>
                <option value="50" <%= (bucket === '50') ? 'selected' : '' %>>50–59%</option>
                <option value="60" <%= (bucket === '60') ? 'selected' : '' %>>60–69%</option>
                <option value="70" <%= (bucket === '70') ? 'selected' : '' %>>70–79%</option>
                <option value="80" <%= (bucket === '80') ? 'selected' : '' %>>80–89%</option>
                <option value="90" <%= (bucket === '90') ? 'selected' : '' %>>90–99%</option>
                <option value="100plus" <%= (bucket === '100plus') ? 'selected' : '' %>>≥ 100%</option>
              </select>
            </label>
            <button type="button" id="followersApplyFilterBtn" style="padding: 6px 12px; background: #111827; color: white; border: none; border-radius: 4px; cursor: pointer;">Aplicar</button>
            <button type="button" id="followersClearFiltersBtn" style="padding: 6px 12px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;">Limpar</button>
            <select id="followersPageSize" style="padding:6px; border:1px solid #ccc; border-radius:4px;">
              <option value="25" <%= (pagination && pagination.pageSize === 25) ? 'selected' : '' %>>25</option>
              <option value="50" <%= (!pagination || pagination.pageSize === 50) ? 'selected' : '' %>>50</option>
              <option value="100" <%= (pagination && pagination.pageSize === 100) ? 'selected' : '' %>>100</option>
              <option value="200" <%= (pagination && pagination.pageSize === 200) ? 'selected' : '' %>>200</option>
            </select>
          </div>
          <div id="followersStatus" style="font-size: 0.9rem; color:#555;"></div>
          <div style="margin-left:auto; font-size:0.9rem; color:#555;">
            <% const p = (pagination && pagination.page) ? pagination.page : 1; %>
            <% const tp = (pagination && pagination.totalPages) ? pagination.totalPages : 1; %>
            <% const tr = (pagination && typeof pagination.totalRows === 'number') ? pagination.totalRows : 0; %>
            Página <%= p %> de <%= tp %> (<%= tr %> registros)
          </div>
        </div>
      </div>

      <div id="followersTableScrollTop" class="dashboard-table-wrap panel-table-scroll" style="margin-top: 14px; margin-bottom: -6px; height: 16px; overflow-x:auto; overflow-y:hidden;">
        <div id="followersTableScrollTopInner" style="height:1px; width:0;"></div>
      </div>
      <div id="followersTableScrollBottom" class="dashboard-table-wrap panel-table-scroll" style="margin-top: 0;">
        <table class="dashboard-table" style="min-width: 1820px; font-size: 0.92rem;">
          <thead>
            <tr>
              <th style="width: 42px; text-align:center;">
                <input id="followersSelectAll" type="checkbox" />
              </th>
              <th>OrderID</th>
              <th>Usuário</th>
              <th>Dias</th>
              <th>Reposição</th>
              <th>Tipo</th>
              <th>Fornecedor</th>
              <th style="text-align:right;">Inicial</th>
              <th style="text-align:right;">Contratado</th>
              <th style="text-align:right;">Resultado</th>
              <th style="text-align:right;">Atual</th>
              <th style="text-align:right;">
                <a href="#" class="followers-sort" data-sort="diffAbs" style="color:inherit; text-decoration:none;">Diferença<span id="followersSortIconAbs" style="margin-left:6px; color:#6b7280;"></span></a>
              </th>
              <th style="text-align:right;">
                <a href="#" class="followers-sort" data-sort="diffPct" style="color:inherit; text-decoration:none;">% Dif.<span id="followersSortIconDiff" style="margin-left:6px; color:#6b7280;"></span></a>
              </th>
              <th>
                <a href="#" class="followers-sort" data-sort="lastPurchaseAtMs" style="color:inherit; text-decoration:none;">Compra<span id="followersSortIconCompra" style="margin-left:6px; color:#6b7280;"></span></a>
              </th>
              <th>
                <a href="#" class="followers-sort" data-sort="currentCheckedAtMs" style="color:inherit; text-decoration:none;">Checado em<span id="followersSortIconChecked" style="margin-left:6px; color:#6b7280;"></span></a>
              </th>
              <th>Erro</th>
              <th>Email Recuperação</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <% (followersOrders || []).forEach(row => { %>
              <% 
                const username = String(row.username || '').trim();
                const init = (typeof row.initialFollowersCount === 'number') ? row.initialFollowersCount : null;
                const contracted = (typeof row.contracted === 'number') ? row.contracted : 0;
                const computedResultado = (init !== null && typeof contracted === 'number' && Number.isFinite(contracted)) ? (init + contracted) : null;
                const resultado = (computedResultado !== null) ? computedResultado : ((typeof row.resultado === 'number') ? row.resultado : null);
                const current = (typeof row.currentFollowersCount === 'number') ? row.currentFollowersCount : null;
                const diff = (resultado !== null && current !== null) ? (resultado - current) : null;
                const pct = (typeof row.diffPct === 'number') ? row.diffPct : ((diff !== null && contracted) ? ((diff / contracted) * 100) : null);
                const oid = row.orderId ? String(row.orderId) : '';
                const fid = row.fornecedorOrderId ? String(row.fornecedorOrderId) : '';
                const diffAbs = (typeof diff === 'number' && Number.isFinite(diff)) ? Math.max(0, diff) : null;
                const pctNum = (typeof pct === 'number' && Number.isFinite(pct)) ? pct : null;
                const hasDrop = (resultado !== null && current !== null && current < resultado && diffAbs !== null && diffAbs >= 100);
                let lastPurchase = '-';
                try {
                  const t = Number(row.lastPurchaseAtMs || 0);
                  if (t) {
                    const d = new Date(t - 3 * 60 * 60 * 1000);
                    const dd = String(d.getUTCDate()).padStart(2,'0');
                    const mm = String(d.getUTCMonth()+1).padStart(2,'0');
                    const yyyy = String(d.getUTCFullYear());
                    const hh = String(d.getUTCHours()).padStart(2,'0');
                    const mn = String(d.getUTCMinutes()).padStart(2,'0');
                    lastPurchase = `${dd}/${mm}/${yyyy} ${hh}:${mn}`;
                  }
                } catch(_) {}
                let checkedAtFmt = '-';
                try {
                  if (row.currentCheckedAt) {
                    const t2 = new Date(String(row.currentCheckedAt)).getTime();
                    if (Number.isFinite(t2) && t2) {
                      const d2 = new Date(t2 - 3 * 60 * 60 * 1000);
                      const dd2 = String(d2.getUTCDate()).padStart(2,'0');
                      const mm2 = String(d2.getUTCMonth()+1).padStart(2,'0');
                      const yyyy2 = String(d2.getUTCFullYear());
                      const hh2 = String(d2.getUTCHours()).padStart(2,'0');
                      const mn2 = String(d2.getUTCMinutes()).padStart(2,'0');
                      checkedAtFmt = `${dd2}/${mm2}/${yyyy2} ${hh2}:${mn2}`;
                    }
                  }
                } catch(_) {}
                const lastErr = row.lastError ? String(row.lastError) : '';
                const emailNotifyStatus = String(row.recoveryEmailStatus || '').trim().toLowerCase();
                const emailNotifyError = String(row.recoveryEmailError || '').trim();
                const emailNotifyResponse = String(row.recoveryEmailResponse || '').trim();
                const emailNotifyRaw = (emailNotifyError || emailNotifyResponse || emailNotifyStatus) ? (emailNotifyError || emailNotifyResponse || emailNotifyStatus) : '';
                const emailNotifyView = emailNotifyStatus === 'sent'
                  ? 'Enviado'
                  : (emailNotifyStatus === 'failed'
                    ? 'Falhou'
                    : (emailNotifyStatus === 'skipped_limit'
                      ? 'Limite atingido'
                      : (emailNotifyStatus === 'skipped_same_day'
                        ? 'Já enviado hoje'
                        : '-')));
                const refilIsLifetime = row.refilIsLifetime === true;
                const refilMode = String(row.refilWarrantyMode || '').trim().toLowerCase();
                const refilDaysLeft = (typeof row.refilDaysLeft === 'number') ? row.refilDaysLeft : null;
                const refilPlanLabel = (function () {
                  if (refilIsLifetime || refilMode === 'life') return 'Vitalícia';
                  if (refilMode === '12m') return '1 ano';
                  if (refilMode === '6m') return '6 meses';
                  if (refilDaysLeft !== null) return '30 dias';
                  return '-';
                })();
              %>
              <tr data-username="<%= username %>" data-tipo="<%= row.tipo ? String(row.tipo) : '' %>" data-orderid="<%= oid %>" data-fornecedororderid="<%= fid ? fid : '' %>" data-checkedatms="<%= (row.currentCheckedAtMs ? row.currentCheckedAtMs : 0) %>" data-checkedatmsraw="<%= (row.currentCheckedAtMsRaw ? row.currentCheckedAtMsRaw : 0) %>" data-purchaseatms="<%= (row.lastPurchaseAtMs ? row.lastPurchaseAtMs : 0) %>" data-diffabs="<%= (diffAbs !== null ? diffAbs : '') %>" data-diffpct="<%= (pctNum !== null ? pctNum : '') %>" data-hidden="<%= row.hidden === true ? '1' : '0' %>" data-resultado="<%= (resultado !== null ? resultado : '') %>" data-contracted="<%= (contracted ? contracted : '') %>">
                <td style="text-align:center; width:42px;">
                  <input type="checkbox" class="followersSelectRow" />
                </td>
                <td style="white-space: nowrap;">
                  <div style="font-size:0.85rem; color:#111;"><%= fid ? fid : '-' %></div>
                </td>
                <td style="white-space: nowrap;" class="cell-username">
                  <% if (row.hidden === true) { %>
                    <span class="unknown-badge unknown-badge--hidden">Oculto</span>
                  <% } %>
                  <% if (row.isPrivate === true) { %>
                    <span class="unknown-badge unknown-badge--private">Privado</span>
                  <% } %>
                  <% if (row.vip === true) { %>
                    <span class="unknown-badge unknown-badge--vip">VIP</span>
                  <% } %>
                  <% if (refilMode === 'life') { %>
                    <span class="unknown-badge unknown-badge--lifetime">Vitalício</span>
                  <% } else if (refilMode === '12m') { %>
                    <span class="unknown-badge unknown-badge--lifetime">1 ano</span>
                  <% } else if (refilMode === '6m') { %>
                    <span class="unknown-badge unknown-badge--lifetime">6 meses</span>
                  <% } %>
                  <%
                    const uRaw = String(username || '').trim();
                    const uClean = uRaw.replace(/^@/, '').replace(/\/+$/, '').split('/').pop().trim();
                    const uHref = uClean ? ('https://instagram.com/' + encodeURIComponent(uClean)) : '';
                  %>
                  <% if (uClean) { %>
                    <a href="<%= uHref %>" target="_blank" rel="noopener noreferrer">@<%= uClean %></a>
                  <% } else { %>
                    @<%= username %>
                  <% } %>
                </td>
                <td style="white-space: nowrap;">
                  <% if (refilMode === 'life') { %>
                    <span style="color:#16a34a; font-weight:700;">VITALÍCIO</span>
                  <% } else if (refilDaysLeft !== null) { %>
                    <% if (refilDaysLeft <= 0) { %>
                      <span style="color:#dc2626; font-weight:700;">EXPIRADO</span>
                    <% } else { %>
                      <%= refilDaysLeft %> <%= (refilDaysLeft === 1 ? 'dia' : 'dias') %>
                    <% } %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td style="white-space: nowrap;"><%= refilPlanLabel %></td>
                <td style="white-space: nowrap;"><%= row.tipo ? String(row.tipo) : '-' %></td>
                <td style="white-space: nowrap;"><%= row.fornecedor ? String(row.fornecedor) : '-' %></td>
                <td style="text-align:right;" class="cell-initial"><%= (init !== null ? init : '-') %></td>
                <td style="text-align:right;"><%= contracted %></td>
                <td style="text-align:right;" class="cell-resultado"><%= (resultado !== null ? resultado : '-') %></td>
                <td style="text-align:right;" class="cell-current"><%= (current !== null ? current : '-') %></td>
                <td style="text-align:right;" class="cell-diff"><%= (diff !== null ? diff : '-') %></td>
                <td style="text-align:right;" class="cell-pct">
                  <% if (resultado !== null && current !== null) { %>
                    <% if (current >= resultado) { %>
                      <span style="color:#16a34a; font-weight:700;">OK</span>
                    <% } else if (pct !== null) { %>
                      <span style="color:#dc2626; font-weight:700;"><%= (pct.toFixed(2).replace('.', ',') + '%') %></span>
                    <% } else { %>
                      -
                    <% } %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td style="white-space: nowrap;"><%= lastPurchase %></td>
                <td style="white-space: nowrap;" class="cell-checkedat"><%= checkedAtFmt %></td>
                <td style="white-space: nowrap; max-width: 320px; overflow:hidden; text-overflow: ellipsis; color:#dc2626;" class="cell-error" title="<%= lastErr %>"><%= lastErr ? lastErr : '-' %></td>
                <td class="<%= (emailNotifyStatus === 'failed') ? 'followers-email--failed' : ((emailNotifyStatus === 'sent') ? 'followers-email--sent' : '') %>" style="white-space: nowrap; max-width: 280px; overflow:hidden; text-overflow: ellipsis;" title="<%= emailNotifyRaw %>"><%= emailNotifyView %></td>
                <td style="white-space: nowrap;">
                  <button type="button" class="unknown-btn btn-refresh" data-force="1">Atualizar</button>
                  <% if (hasDrop) { %>
                    <button type="button" class="unknown-btn btn-notify" style="background:#0ea5e9;">Enviar Email+SMS</button>
                    <span class="followersNotifyStatus" style="margin-left:8px; font-size:0.85rem; color:#64748b;"></span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div id="followersReportModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:99999; align-items:center; justify-content:center; padding:16px;">
        <div style="width:880px; max-width:calc(100vw - 32px); max-height:calc(100vh - 48px); overflow:auto; background:#ffffff; border-radius:12px; border:1px solid #e5e7eb; font-family: Arial,Helvetica,sans-serif;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding:14px 16px; background:#111827; color:#ffffff;">
            <div style="font-weight:800; letter-spacing:0.02em;">Relatório - Gerenciamento de Seguidores</div>
            <button type="button" id="followersReportCloseBtn" style="padding:6px 10px; border-radius:8px; border:1px solid rgba(255,255,255,0.25); background:transparent; color:#ffffff; cursor:pointer;">Fechar</button>
          </div>
          <div style="padding:14px 16px; color:#111827;">
            <div style="display:flex; gap:14px; flex-wrap:wrap;">
              <div style="flex:1; min-width:240px; border:1px solid #e5e7eb; border-radius:10px; padding:12px; background:#f9fafb;">
                <div style="font-size:12px; color:#6b7280;">Total (com filtros)</div>
                <div id="followersReportTotal" style="font-size:22px; font-weight:800; margin-top:2px;">-</div>
                <div style="height:10px;"></div>
                <div style="font-size:12px; color:#6b7280;">Checados</div>
                <div id="followersReportChecked" style="font-size:18px; font-weight:800; margin-top:2px;">-</div>
                <div style="font-size:12px; color:#6b7280; margin-top:4px;" id="followersReportCheckedPct"></div>
                <div style="height:10px;"></div>
                <div style="font-size:12px; color:#6b7280;">Com queda</div>
                <div id="followersReportWithDrop" style="font-size:18px; font-weight:800; margin-top:2px;">-</div>
              </div>

              <div style="flex:1; min-width:240px; border:1px solid #e5e7eb; border-radius:10px; padding:12px; background:#ffffff;">
                <div style="font-size:12px; color:#6b7280;">Distribuição de queda (%)</div>
                <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-top:10px;">
                  <canvas id="followersReportPie" width="260" height="260" style="width:260px; height:260px; border-radius:999px; background:#ffffff;"></canvas>
                  <div id="followersReportLegend" style="flex:1; min-width:160px; font-size:13px; line-height:1.6;"></div>
                </div>
                <div style="height:14px;"></div>
                <div style="font-size:12px; color:#6b7280;">OK x Não OK (validados)</div>
                <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-top:10px;">
                  <canvas id="followersReportOkPie" width="220" height="220" style="width:220px; height:220px; border-radius:999px; background:#ffffff;"></canvas>
                  <div id="followersReportOkLegend" style="flex:1; min-width:160px; font-size:13px; line-height:1.6;"></div>
                </div>

                <div style="height:14px;"></div>
                <div style="font-size:12px; color:#6b7280;">Não OK x idade da compra</div>
                <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-top:10px;">
                  <canvas id="followersReportPurchaseAgePie" width="260" height="260" style="width:260px; height:260px; border-radius:999px; background:#ffffff;"></canvas>
                  <div id="followersReportPurchaseAgeLegend" style="flex:1; min-width:160px; font-size:13px; line-height:1.6;"></div>
                </div>

                <div style="height:14px;"></div>
                <div style="font-size:12px; color:#6b7280;">Diferença (abs) ≥ 100 x &lt; 100 (com queda)</div>
                <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-top:10px;">
                  <canvas id="followersReportAbsDiffPie" width="220" height="220" style="width:220px; height:220px; border-radius:999px; background:#ffffff;"></canvas>
                  <div id="followersReportAbsDiffLegend" style="flex:1; min-width:160px; font-size:13px; line-height:1.6;"></div>
                </div>

                <div style="height:14px;"></div>
                <div style="font-size:12px; color:#6b7280;">OK x NOK (diferença ≥ 100) por tipo de reposição</div>
                <div id="followersReportWarrantyBars" style="margin-top:10px; font-size:13px; line-height:1.5;"></div>
              </div>
            </div>
            <div style="margin-top:12px; font-size:12px; color:#6b7280;">
              Percentuais do gráfico são calculados apenas em cima dos pedidos com queda.
            </div>
          </div>
        </div>
      </div>

      <script type="application/json" id="followersReportJson"><%- JSON.stringify(followersReport || {}).replace(/</g, '\\u003c') %></script>
      <script type="application/json" id="followersFilteredTargetsJson"><%- JSON.stringify(followersFilteredTargets || []).replace(/</g, '\\u003c') %></script>

      <script>
        (function(){
          function el(id){ return document.getElementById(id); }
          function setStatus(t){ var s = el('followersStatus'); if (s) s.textContent = t || ''; }
          function toNum(v){ var n = Number(v); return Number.isFinite(n) ? n : null; }
          function sleep(ms){ return new Promise(function(r){ setTimeout(r, ms); }); }
          function fmtBr(iso){
            try {
              if (!iso) return '-';
              var t = new Date(String(iso)).getTime();
              if (!t || !isFinite(t)) return '-';
              var d = new Date(t - 3 * 60 * 60 * 1000);
              var dd = String(d.getUTCDate()).padStart(2,'0');
              var mm = String(d.getUTCMonth()+1).padStart(2,'0');
              var yyyy = String(d.getUTCFullYear());
              var hh = String(d.getUTCHours()).padStart(2,'0');
              var mn = String(d.getUTCMinutes()).padStart(2,'0');
              return dd + '/' + mm + '/' + yyyy + ' ' + hh + ':' + mn;
            } catch (_) {
              return '-';
            }
          }

          async function refreshRow(tr, force) {
            if (!tr) return;
            var username = String(tr.getAttribute('data-username') || '').trim();
            if (!username) return;

            var btns = tr.querySelectorAll('button');
            for (var i=0;i<btns.length;i++){ try { btns[i].disabled = true; } catch(_) {} }

            try {
              var data = null;
              for (var attempt = 1; attempt <= 3; attempt++) {
                var url = '/api/painel/gerenciamento-seguidores/current?username=' + encodeURIComponent(username) + '&force=' + (force ? '1' : '0');
                var resp = await fetch(url, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' });
                if (resp && resp.status === 401) {
                  window.location.href = '/painel';
                  return;
                }
                data = await resp.json().catch(function(){ return null; });
                if (data && data.ok) break;
                if (attempt < 3) await sleep(900 * attempt);
              }
              if (!data || !data.ok) throw new Error((data && data.error) ? data.error : 'request_failed');

              var current = (typeof data.followersCount === 'number') ? data.followersCount : null;
              var resultadoRaw = tr.getAttribute('data-resultado');
              var resultado = resultadoRaw === '' ? null : toNum(resultadoRaw);
              var contractedRaw = tr.getAttribute('data-contracted');
              var contracted = contractedRaw === '' ? null : toNum(contractedRaw);
              var diff = (resultado !== null && current !== null) ? (resultado - current) : null;
              var pct = (diff !== null && contracted) ? ((diff / contracted) * 100) : null;

              try {
                var cellUsername = tr.querySelector('.cell-username');
                var isPrivate = !!(data && data.isPrivate === true);
                if (cellUsername) {
                  var curPrivateBadge = cellUsername.querySelector('.unknown-badge--private');
                  if (isPrivate && !curPrivateBadge) {
                    var b = document.createElement('span');
                    b.className = 'unknown-badge unknown-badge--private';
                    b.textContent = 'Privado';
                    cellUsername.insertBefore(b, cellUsername.firstChild);
                    cellUsername.insertBefore(document.createTextNode(' '), b.nextSibling);
                  } else if (!isPrivate && curPrivateBadge) {
                    curPrivateBadge.remove();
                  }
                }
              } catch (_) {}

              var cellCurrent = tr.querySelector('.cell-current');
              var cellDiff = tr.querySelector('.cell-diff');
              var cellPct = tr.querySelector('.cell-pct');
              var cellCheckedAt = tr.querySelector('.cell-checkedat');
              var cellError = tr.querySelector('.cell-error');
