<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel de Gerenciamento</title>
  <link href="/css/style.css" rel="stylesheet" />
  <style>
    body { font-family: sans-serif; padding: 20px; background: #f0f2f5; color: #333; }
    .container { max-width: 1000px; margin: 0 auto; background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    h1 { margin-bottom: 20px; }
    .filters { margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; }
    .filters a { text-decoration: none; padding: 8px 16px; background: #eee; color: #333; border-radius: 4px; }
    .filters a.active { background: #007bff; color: #fff; }
    table { width: 1000px; border-collapse: collapse; width: 100%; }
    th, td { padding: 10px; text-align: left; border-bottom: 1px solid #ddd; }
    th { background: #f9f9f9; }
    .total-box { font-size: 1.2em; font-weight: bold; margin-top: 20px; text-align: right; }
  </style>
</head>
<body>
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1 style="margin:0;">Painel de Gerenciamento de Custos</h1>
        <a href="/logout" style="color: #dc3545; text-decoration: none; font-weight: 500; border: 1px solid #dc3545; padding: 5px 10px; border-radius: 4px;">Sair</a>
    </div>
    
    <div class="filters">
      <a href="/painel?period=today" class="<%= period === 'today' ? 'active' : '' %>">Hoje</a>
      <a href="/painel?period=last3days" class="<%= period === 'last3days' ? 'active' : '' %>">Últimos 3 dias</a>
      <a href="/painel?period=last7days" class="<%= period === 'last7days' ? 'active' : '' %>">Últimos 7 dias</a>
      <a href="/painel?period=thismonth" class="<%= period === 'thismonth' ? 'active' : '' %>">Este mês</a>
      <a href="/painel?period=lastmonth" class="<%= period === 'lastmonth' ? 'active' : '' %>">Mês passado</a>
      <a href="javascript:window.location.reload();" style="background: #28a745; color: white;">Atualizar</a>
    </div>

    <div style="margin-bottom: 20px; background: #fff; padding: 15px; border-radius: 4px; border: 1px solid #ddd; display: flex; align-items: center; gap: 10px;">
        <strong>Filtrar por data:</strong>
        <input type="date" id="startDate" style="padding: 5px; border: 1px solid #ccc; border-radius: 4px;">
        <span>até</span>
        <input type="date" id="endDate" style="padding: 5px; border: 1px solid #ccc; border-radius: 4px;">
        <button onclick="applyCustomFilter()" style="padding: 6px 12px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">Filtrar</button>
    </div>

    <script>
        function applyCustomFilter() {
            const start = document.getElementById('startDate').value;
            const end = document.getElementById('endDate').value;
            if (!start || !end) {
                alert('Por favor, selecione as datas de início e fim.');
                return;
            }
            window.location.href = `/painel?period=custom&startDate=${start}&endDate=${end}`;
        }
        
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('period') === 'custom') {
            document.getElementById('startDate').value = urlParams.get('startDate') || '';
            document.getElementById('endDate').value = urlParams.get('endDate') || '';
        }
    </script>

    <div class="total-box">
      Total de Vendas: R$ <%= totalRevenue.toFixed(2).replace('.', ',') %>
      <br>
      Custo Total no Período: R$ <%= totalCost.toFixed(2).replace('.', ',') %>
      <br>
      Total de Transações: <%= totalTransactions %>
    </div>

    <div style="display:flex; gap:24px; align-items:flex-start; margin-top:16px;">
      <div style="flex:2; min-width:0;">
        <table>
          <thead>
            <tr>
              <th>Data (SP)</th>
              <th>Serviço</th>
              <th>Qtd</th>
              <th>Custo/1k</th>
              <th>Taxa</th>
              <th>Total Item</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => { %>
              <% 
                 let d;
                 if (order.createdAt instanceof Date) {
                    d = new Date(order.createdAt);
                 } else {
                    d = new Date(order.createdAt || new Date());
                 }
                 d = new Date(d.getTime() - 3 * 60 * 60 * 1000);
                 
                 const dateStr = d.getUTCDate().toString().padStart(2, '0') + '/' + 
                                 (d.getUTCMonth() + 1).toString().padStart(2, '0') + '/' + 
                                 d.getUTCFullYear() + ' ' + 
                                 d.getUTCHours().toString().padStart(2, '0') + ':' + 
                                 d.getUTCMinutes().toString().padStart(2, '0');
              %>
              <tr>
                <td><%= dateStr %></td>
                <td><%= order.type %></td>
                <td><%= order.qty %></td>
                <td>R$ <%= order.costPer1000.toFixed(2).replace('.', ',') %></td>
                <td>R$ 0,85</td>
                <td>R$ <%= order.cost.toFixed(2).replace('.', ',') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div style="flex:1; max-width:320px;">
        <div style="border:1px solid #ddd; border-radius:8px; padding:16px; background:#fafafa; position:sticky; top:16px;">
          <h2 style="margin:0 0 8px; font-size:1rem;">Custos por 1.000</h2>
          <p style="margin:0 0 12px; font-size:0.85rem; color:#555;">
            Ajuste o custo de cada produto. Os valores são usados no cálculo do custo total do painel.
          </p>
          <form id="costSettingsForm" method="POST" action="/painel/custos">
            <div style="display:flex; flex-direction:column; gap:8px; font-size:0.9rem;">
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Seg. Mistos</span>
                <input type="number" step="0.01" name="seguidores_mistos" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.seguidores_mistos) ? costSettings.seguidores_mistos : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Seg. Brasileiros</span>
                <input type="number" step="0.01" name="seguidores_brasileiros" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.seguidores_brasileiros) ? costSettings.seguidores_brasileiros : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Seg. Orgânicos</span>
                <input type="number" step="0.01" name="seguidores_organicos" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.seguidores_organicos) ? costSettings.seguidores_organicos : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Curtidas Mistos</span>
                <input type="number" step="0.01" name="curtidas_mistos" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.curtidas_mistos) ? costSettings.curtidas_mistos : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Outras Curtidas</span>
                <input type="number" step="0.01" name="curtidas" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.curtidas) ? costSettings.curtidas : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Comentários</span>
                <input type="number" step="0.01" name="comentarios" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.comentarios) ? costSettings.comentarios : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Visualizações</span>
                <input type="number" step="0.01" name="visualizacoes" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.visualizacoes) ? costSettings.visualizacoes : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
            </div>
            <div style="margin-top:12px; text-align:right;">
              <button type="submit" style="padding:6px 12px; background:#28a745; color:#fff; border:none; border-radius:4px; cursor:pointer; font-size:0.9rem;">
                Salvar
              </button>
            </div>
          </form>
          <script>
            (function(){
              var form = document.getElementById('costSettingsForm');
              if (!form) return;
              form.addEventListener('submit', function(ev){
                try {
                  ev.preventDefault();
                } catch(_) {}
                try {
                  var fd = new FormData(form);
                  var params = new URLSearchParams();
                  fd.forEach(function(value, key){
                    params.append(key, value);
                  });
                  fetch(form.action, {
                    method: 'POST',
                    body: params.toString(),
                    headers: {
                      'Accept': 'application/json',
                      'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    }
                  }).then(function(resp){
                    if (!resp.ok) return resp.text().then(function(t){ throw new Error(t || ('HTTP ' + resp.status)); });
                    return resp.json();
                  }).then(function(data){
                    alert('Custos atualizados com sucesso.');
                    try { window.location.reload(); } catch(_) {}
                  }).catch(function(err){
                    alert('Erro ao salvar custos: ' + (err && err.message ? err.message : err));
                  });
                } catch(e) {
                  alert('Erro inesperado ao enviar: ' + (e && e.message ? e.message : e));
                }
              });
            })();
          </script>
        </div>

        <div style="border:1px solid #ddd; border-radius:8px; padding:16px; background:#fafafa; margin-top: 16px;">
          <h2 style="margin:0 0 8px; font-size:1rem;">Cupons de Desconto</h2>
          <div style="display:flex; gap:8px; margin-bottom:12px;">
            <input type="text" id="couponCodeInput" placeholder="CÓDIGO" style="flex:1; padding:6px; border:1px solid #ccc; border-radius:4px; text-transform:uppercase;">
            <input type="number" id="couponDiscountInput" placeholder="%" style="width:60px; padding:6px; border:1px solid #ccc; border-radius:4px;" min="1" max="100">
            <button onclick="addCoupon()" style="padding:6px 12px; background:#28a745; color:#fff; border:none; border-radius:4px; cursor:pointer;">Add</button>
          </div>
          <ul id="couponsList" style="list-style:none; padding:0; margin:0; max-height: 200px; overflow-y: auto;">
            <!-- Items via JS -->
          </ul>
          <script>
            async function loadCoupons() {
              try {
                const res = await fetch('/api/admin/coupons');
                const data = await res.json();
                if(data.success) {
                  renderCoupons(data.coupons);
                }
              } catch(e) { console.error(e); }
            }

            function renderCoupons(list) {
              const ul = document.getElementById('couponsList');
              ul.innerHTML = '';
              if (list.length === 0) {
                ul.innerHTML = '<li style="color:#777; font-size:0.9rem; text-align:center;">Nenhum cupom ativo</li>';
                return;
              }
              list.forEach(item => {
                const li = document.createElement('li');
                li.style.display = 'flex';
                li.style.justifyContent = 'space-between';
                li.style.alignItems = 'center';
                li.style.padding = '6px 0';
                li.style.borderBottom = '1px solid #eee';
                
                const span = document.createElement('span');
                span.innerHTML = `<strong>${item.code}</strong> (${item.discountPercentage}%)`;
                span.style.fontWeight = '500';
                
                const btn = document.createElement('button');
                btn.textContent = '✕';
                btn.style.background = 'transparent';
                btn.style.border = 'none';
                btn.style.color = '#dc3545';
                btn.style.cursor = 'pointer';
                btn.style.fontSize = '1.1rem';
                btn.title = 'Remover';
                btn.onclick = () => removeCoupon(item._id);
                
                li.appendChild(span);
                li.appendChild(btn);
                ul.appendChild(li);
              });
            }

            async function addCoupon() {
              const codeInput = document.getElementById('couponCodeInput');
              const discountInput = document.getElementById('couponDiscountInput');
              const code = codeInput.value.trim().toUpperCase();
              const discountPercentage = discountInput.value;
              
              if(!code || !discountPercentage) {
                  alert('Preencha código e porcentagem');
                  return;
              }
              
              try {
                const res = await fetch('/api/admin/coupons', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ code, discountPercentage })
                });
                const data = await res.json();
                if(data.success) {
                  codeInput.value = '';
                  discountInput.value = '';
                  loadCoupons();
                } else {
                  alert('Erro ao criar cupom: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            async function removeCoupon(id) {
              if(!confirm('Remover este cupom?')) return;
              try {
                const res = await fetch('/api/admin/coupons/' + id, {
                  method: 'DELETE'
                });
                const data = await res.json();
                if(data.success) {
                  loadCoupons();
                } else {
                  alert('Erro ao remover: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            loadCoupons();
          </script>
        </div>

        <div style="border:1px solid #ddd; border-radius:8px; padding:16px; background:#fafafa; margin-top: 16px; position: sticky; top: 400px;">
          <h2 style="margin:0 0 8px; font-size:1rem;">Usuários Bloqueados</h2>
          <div style="display:flex; gap:8px; margin-bottom:12px;">
            <input type="text" id="blacklistInput" placeholder="Usuário (sem @)" style="flex:1; padding:6px; border:1px solid #ccc; border-radius:4px;">
            <button onclick="addToBlacklist()" style="padding:6px 12px; background:#dc3545; color:#fff; border:none; border-radius:4px; cursor:pointer;">Bloquear</button>
          </div>
          <ul id="blacklistList" style="list-style:none; padding:0; margin:0; max-height: 200px; overflow-y: auto;">
            <!-- Items via JS -->
          </ul>
          <script>
            async function loadBlacklist() {
              try {
                const res = await fetch('/api/blacklist');
                const data = await res.json();
                if(data.success) {
                  renderBlacklist(data.blacklist);
                }
              } catch(e) { console.error(e); }
            }

            function renderBlacklist(list) {
              const ul = document.getElementById('blacklistList');
              ul.innerHTML = '';
              if (list.length === 0) {
                ul.innerHTML = '<li style="color:#777; font-size:0.9rem; text-align:center;">Nenhum usuário bloqueado</li>';
                return;
              }
              list.forEach(item => {
                const li = document.createElement('li');
                li.style.display = 'flex';
                li.style.justifyContent = 'space-between';
                li.style.alignItems = 'center';
                li.style.padding = '6px 0';
                li.style.borderBottom = '1px solid #eee';
                
                const span = document.createElement('span');
                span.textContent = item.username;
                span.style.fontWeight = '500';
                
                const btn = document.createElement('button');
                btn.textContent = '✕';
                btn.style.background = 'transparent';
                btn.style.border = 'none';
                btn.style.color = '#dc3545';
                btn.style.cursor = 'pointer';
                btn.style.fontSize = '1.1rem';
                btn.title = 'Desbloquear';
                btn.onclick = () => removeFromBlacklist(item.username);
                
                li.appendChild(span);
                li.appendChild(btn);
                ul.appendChild(li);
              });
            }

            async function addToBlacklist() {
              const input = document.getElementById('blacklistInput');
              const username = input.value.trim();
              if(!username) return;
              
              try {
                const res = await fetch('/api/blacklist/add', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ username })
                });
                const data = await res.json();
                if(data.success) {
                  input.value = '';
                  loadBlacklist();
                } else {
                  alert('Erro ao bloquear: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            async function removeFromBlacklist(username) {
              if(!confirm('Desbloquear ' + username + '?')) return;
              try {
                const res = await fetch('/api/blacklist/remove', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ username })
                });
                const data = await res.json();
                if(data.success) {
                  loadBlacklist();
                } else {
                  alert('Erro ao desbloquear: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            loadBlacklist();
          </script>
        </div>
    </div>
  </div>
</body>
</html>
