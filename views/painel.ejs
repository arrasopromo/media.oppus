            <div style="font-size:0.85rem; color:#666;">Ocultos: <span id="unknownHiddenCount">0</span></div>
          </div>
          <div class="unknown-table-wrap">
          <table class="unknown-table">
            <colgroup>
              <col style="width: 44px;">
              <col style="width: 130px;">
              <col style="width: 240px;">
              <col style="width: 130px;">
              <col style="width: 80px;">
              <col style="width: 190px;">
              <col style="width: 190px;">
              <col style="width: 220px;">
              <col style="width: 220px;">
              <col style="width: 220px;">
              <col style="width: 200px;">
            </colgroup>
            <thead>
              <tr>
                <th style="text-align:center;">
                  <input id="unknownSelectAll" type="checkbox" style="transform:scale(1.1);" />
                </th>
                <th>Data (SP)</th>
                <th>Usuário</th>
                <th>Serviço</th>
                <th>Qtd</th>
                <th>Fama24h</th>
                <th>Fornecedor Social</th>
                <th>WorldSMM (Bump Comentários)</th>
                <th>Fama24h (Bump Views)</th>
                <th>Fama24h (Bump Curtidas)</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% (unknownOrders || []).forEach(order => { %>
                <% 
                   let d;
                   if (order.createdAt instanceof Date) d = new Date(order.createdAt);
                   else d = new Date(order.createdAt || new Date());
                   d = new Date(d.getTime() - 3 * 60 * 60 * 1000);
                   
                   const dateStr = d.getUTCDate().toString().padStart(2, '0') + '/' + 
                                   (d.getUTCMonth() + 1).toString().padStart(2, '0') + '/' + 
                                   d.getUTCFullYear() + ' ' + 
                                   d.getUTCHours().toString().padStart(2, '0') + ':' + 
                                   d.getUTCMinutes().toString().padStart(2, '0');

                   const famaStatusStr = String(order.famaStatus || '');
                   const famaOrderIdStr = String(order.famaOrderId || '');
                   const famaOrderIdDisplay = (famaOrderIdStr && famaOrderIdStr !== 'null') ? famaOrderIdStr : '-';
                   const fsStatusStr = String(order.fsStatus || '');
                   const fsOrderIdStr = String(order.fsOrderId || '');
                   const fsOrderIdDisplay = (fsOrderIdStr && fsOrderIdStr !== 'null') ? fsOrderIdStr : '-';
                   const wStatusStr = String(order.worldsmmCommentsStatus || '');
                   const wOrderIdStr = String(order.worldsmmCommentsOrderId || '');
                   const wOrderIdDisplay = (wOrderIdStr && wOrderIdStr !== 'null') ? wOrderIdStr : '-';
                   const wQtyStr = String(order.worldsmmCommentsQty || '').trim();
                   const vStatusStr = String(order.famaViewsStatus || '');
                   const vOrderIdStr = String(order.famaViewsOrderId || '');
                   const vOrderIdDisplay = (vOrderIdStr && vOrderIdStr !== 'null') ? vOrderIdStr : '-';
                   const vQtyStr = String(order.famaViewsQty || '').trim();
                   const lStatusStr = String(order.famaLikesStatus || '');
                   const lOrderIdStr = String(order.famaLikesOrderId || '');
                   const lOrderIdDisplay = (lOrderIdStr && lOrderIdStr !== 'null') ? lOrderIdStr : '-';
                   const lQtyStr = String(order.famaLikesQty || '').trim();
                   const expectedProvider = String(order.expectedMainProvider || '').trim();
                   const defaultProvider = expectedProvider || ((
                     famaStatusStr === 'unknown' ||
                     famaOrderIdStr === 'unknown' ||
                     famaOrderIdStr === 'unknow' ||
                     famaOrderIdStr === 'null' ||
                     famaOrderIdStr === ''
                   ) ? 'fama24h' : 'fornecedor_social');
                   const lockProvider = expectedProvider ? '1' : '';
                   const showFama = (!expectedProvider || expectedProvider === 'fama24h');
                   const showFS = (!expectedProvider || expectedProvider === 'fornecedor_social');
                   const showW = true;
                   const isUnknownToken = (v) => {
                     const s = String(v || '').toLowerCase().trim();
                     return s === 'unknown' || s === 'unknow' || s === '';
                   };
                   const mainNeeds = !expectedProvider || (
                     expectedProvider === 'fama24h'
                       ? (isUnknownToken(famaStatusStr) || isUnknownToken(famaOrderIdStr) || famaOrderIdStr === 'null')
                       : (isUnknownToken(fsStatusStr) || isUnknownToken(fsOrderIdStr) || fsOrderIdStr === 'null')
                   );
                   const worldNeeds = String(order.needsWorldsmmComments || '') === 'true' || order.needsWorldsmmComments === true;
                %>
                <tr data-id="<%= order._id %>">
                  <td style="text-align:center;">
                    <input class="unknown-hide-cb" type="checkbox" data-id="<%= order._id %>" style="transform:scale(1.1);" />
                  </td>
                  <td><%= dateStr %></td>
                  <td>
                    <div>
                      <% if (order.isPrivate) { %><span class="unknown-badge unknown-badge--private">PRIVADO</span><% } %>
                      <%= order.instaUser || '-' %>
                    </div>
                    <small>
                      <%= order.phone || '-' %>
                    </small>
                  </td>
                  <td><%= order.serviceLabel || order.type || '-' %></td>
                  <td><%= (typeof order.qty !== 'undefined' ? order.qty : '-') %></td>
                  <td>
                    <% if (showFama) { %>
                      <div><%= famaOrderIdDisplay %></div>
                      <small>(<%= famaStatusStr || 'unknown' %>)</small>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% if (showFS) { %>
                      <div><%= fsOrderIdDisplay %></div>
                      <small>(<%= fsStatusStr || 'unknown' %>)</small>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% if (showW && (wOrderIdStr || wStatusStr)) { %>
                      <div><%= wOrderIdDisplay %></div>
                      <small>(<%= wStatusStr || 'unknown' %>)</small>
                      <% if (wQtyStr) { %>
                        <div><small style="color:#666;">Qtd comentários: <%= wQtyStr %></small></div>
                      <% } %>
                      <% if (order.postLinkComments) { %>
                        <div><small><a class="unknown-link" href="<%= order.postLinkComments %>" target="_blank" rel="noopener noreferrer">Link post</a></small></div>
                      <% } %>
                      <% if (order.worldsmmCommentsError) { %>
                        <div><small style="color:#b00020;"><%= order.worldsmmCommentsError %></small></div>
                      <% } %>
                    <% } else { %>
                      -
                      <% if (order.postLinkComments) { %>
                        <div><small><a class="unknown-link" href="<%= order.postLinkComments %>" target="_blank" rel="noopener noreferrer">Link post</a></small></div>
                      <% } %>
                    <% } %>
                  </td>
                  <td>
                    <% if (vOrderIdStr || vStatusStr || vQtyStr || order.famaViewsError) { %>
                      <div><%= vOrderIdDisplay %></div>
                      <small>(<%= vStatusStr || 'unknown' %>)</small>
                      <% if (vQtyStr) { %>
                        <div><small style="color:#666;">Qtd views: <%= vQtyStr %></small></div>
                      <% } %>
                      <% if (order.postLinkViews) { %>
                        <div><small><a class="unknown-link" href="<%= order.postLinkViews %>" target="_blank" rel="noopener noreferrer">Link post</a></small></div>
                      <% } %>
                      <% if (order.famaViewsError) { %>
                        <div><small style="color:#b00020;"><%= order.famaViewsError %></small></div>
                      <% } %>
                    <% } else { %>
                      -
                      <% if (order.postLinkViews) { %>
                        <div><small><a class="unknown-link" href="<%= order.postLinkViews %>" target="_blank" rel="noopener noreferrer">Link post</a></small></div>
                      <% } %>
                    <% } %>
                  </td>
                  <td>
                    <% if (lOrderIdStr || lStatusStr || lQtyStr || order.famaLikesError) { %>
                      <div><%= lOrderIdDisplay %></div>
                      <small>(<%= lStatusStr || 'unknown' %>)</small>
                      <% if (lQtyStr) { %>
                        <div><small style="color:#666;">Qtd curtidas: <%= lQtyStr %></small></div>
                      <% } %>
                      <% if (order.postLinkLikes) { %>
                        <div><small><a class="unknown-link" href="<%= order.postLinkLikes %>" target="_blank" rel="noopener noreferrer">Link post</a></small></div>
                      <% } %>
                      <% if (order.famaLikesError) { %>
                        <div><small style="color:#b00020;"><%= order.famaLikesError %></small></div>
                      <% } %>
                    <% } else { %>
                      -
                      <% if (order.postLinkLikes) { %>
                        <div><small><a class="unknown-link" href="<%= order.postLinkLikes %>" target="_blank" rel="noopener noreferrer">Link post</a></small></div>
                      <% } %>
                    <% } %>
                  </td>
                  <td>
                    <% if (mainNeeds) { %>
                      <button class="unknown-btn" onclick='openUnknownOrderModal("<%= order._id %>", "<%= defaultProvider %>", "<%= lockProvider %>")'>Cadastrar OrderID</button>
                    <% } %>
                    <% if (worldNeeds) { %>
                      <button class="unknown-btn" style="margin-top:6px;" onclick='openUnknownOrderModal("<%= order._id %>", "worldsmm_comments", "1")'>Cadastrar Comentários<%= wQtyStr ? (" (" + wQtyStr + ")") : "" %></button>
                    <% } %>
                    <% if (order.needsFamaViewsBump) { %>
                      <button class="unknown-btn" style="margin-top:6px;" onclick='openUnknownOrderModal("<%= order._id %>", "fama24h_views", "1")'>Cadastrar Views Bump<%= vQtyStr ? (" (" + vQtyStr + ")") : "" %></button>
                    <% } %>
                    <% if (order.needsFamaLikesBump) { %>
                      <button class="unknown-btn" style="margin-top:6px;" onclick='openUnknownOrderModal("<%= order._id %>", "fama24h_likes", "1")'>Cadastrar Curtidas Bump<%= lQtyStr ? (" (" + lQtyStr + ")") : "" %></button>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } else { %>
          <div class="dashboard-table-wrap">
          <table class="dashboard-table">
            <thead>
              <tr>
                <th>Data (SP)</th>
                <th>Serviço</th>
                <th>Qtd</th>
                <th>Custo/1k</th>
                <th>Taxa</th>
                <th>Orderbump</th>
                <th>Custo Bump</th>
                <th>Total Item</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(order => { %>
                <% 
                   let d;
                   if (order.createdAt instanceof Date) {
                      d = new Date(order.createdAt);
                   } else {
                      d = new Date(order.createdAt || new Date());
                   }
                   d = new Date(d.getTime() - 3 * 60 * 60 * 1000);
                   
                   const dateStr = d.getUTCDate().toString().padStart(2, '0') + '/' + 
                                   (d.getUTCMonth() + 1).toString().padStart(2, '0') + '/' + 
                                   d.getUTCFullYear() + ' ' + 
                                   d.getUTCHours().toString().padStart(2, '0') + ':' + 
                                   d.getUTCMinutes().toString().padStart(2, '0');
                %>
                <tr>
                  <td><%= dateStr %></td>
                  <td><%= order.type %></td>
                  <td><%= order.qty %></td>
                  <td>R$ <%= order.costPer1000.toFixed(2).replace('.', ',') %></td>
                  <td>R$ 0,85</td>
                  <td><%= (order.orderBumps || '-') %></td>
                  <td>
                    R$ <%= (typeof order.bumpCost !== 'undefined' ? order.bumpCost : 0).toFixed(2).replace('.', ',') %>
                    <% if (order.orderBumpsTotal) { %>
                      <div><small style="color:#666;"><%= order.orderBumpsTotal %></small></div>
                    <% } %>
                  </td>
                  <td>R$ <%= order.cost.toFixed(2).replace('.', ',') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } %>
      </div>

      <% if (!isUnknownOrderIdView) { %>
      <div class="cost-panel-wrap">
        <div class="cost-panel">
          <h2 style="margin:0 0 8px; font-size:1rem;">Custos por 1.000</h2>
          <p style="margin:0 0 12px; font-size:0.85rem; color:#555;">
            Ajuste o custo de cada produto. Os valores são usados no cálculo do custo total do painel.
          </p>
          <form id="costSettingsForm" method="POST" action="/painel/custos">
            <div style="display:flex; flex-direction:column; gap:8px; font-size:0.9rem;">
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Seg. Mistos</span>
                <input type="number" step="0.01" name="seguidores_mistos" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.seguidores_mistos) ? costSettings.seguidores_mistos : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Seg. Brasileiros</span>
                <input type="number" step="0.01" name="seguidores_brasileiros" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.seguidores_brasileiros) ? costSettings.seguidores_brasileiros : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Seg. Orgânicos</span>
                <input type="number" step="0.01" name="seguidores_organicos" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.seguidores_organicos) ? costSettings.seguidores_organicos : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Curtidas Mistos</span>
                <input type="number" step="0.01" name="curtidas_mistos" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.curtidas_mistos) ? costSettings.curtidas_mistos : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Outras Curtidas</span>
                <input type="number" step="0.01" name="curtidas" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.curtidas) ? costSettings.curtidas : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Comentários</span>
                <input type="number" step="0.01" name="comentarios" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.comentarios) ? costSettings.comentarios : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
              <label style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span>Visualizações</span>
                <input type="number" step="0.01" name="visualizacoes" value="<%= ((typeof costSettings !== 'undefined' && costSettings && costSettings.visualizacoes) ? costSettings.visualizacoes : 0).toFixed(2) %>" style="width:110px; padding:4px;" />
              </label>
            </div>
            <div style="margin-top:12px; text-align:right;">
              <button type="submit" style="padding:6px 12px; background:#28a745; color:#fff; border:none; border-radius:4px; cursor:pointer; font-size:0.9rem;">
                Salvar
              </button>
            </div>
          </form>
          <script>
            (function(){
              var form = document.getElementById('costSettingsForm');
              if (!form) return;
              form.addEventListener('submit', function(ev){
                try {
                  ev.preventDefault();
                } catch(_) {}
                try {
                  var fd = new FormData(form);
                  var params = new URLSearchParams();
                  fd.forEach(function(value, key){
                    params.append(key, value);
                  });
                  fetch(form.action, {
                    method: 'POST',
                    body: params.toString(),
                    headers: {
                      'Accept': 'application/json',
                      'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    }
                  }).then(function(resp){
                    if (!resp.ok) return resp.text().then(function(t){ throw new Error(t || ('HTTP ' + resp.status)); });
                    return resp.json();
                  }).then(function(data){
                    alert('Custos atualizados com sucesso.');
                    try { window.location.reload(); } catch(_) {}
                  }).catch(function(err){
                    alert('Erro ao salvar custos: ' + (err && err.message ? err.message : err));
                  });
                } catch(e) {
                  alert('Erro inesperado ao enviar: ' + (e && e.message ? e.message : e));
                }
              });
            })();
          </script>
        </div>

        <div style="border:1px solid #ddd; border-radius:8px; padding:16px; background:#fafafa; margin-top: 16px; position: sticky; top: 400px;">
          <h2 style="margin:0 0 8px; font-size:1rem;">Usuários Bloqueados</h2>
          <div style="display:flex; gap:8px; margin-bottom:12px;">
            <input type="text" id="blacklistInput" placeholder="Usuário (sem @)" style="flex:1; padding:6px; border:1px solid #ccc; border-radius:4px;">
            <button onclick="addToBlacklist()" style="padding:6px 12px; background:#dc3545; color:#fff; border:none; border-radius:4px; cursor:pointer;">Bloquear</button>
          </div>
          <ul id="blacklistList" style="list-style:none; padding:0; margin:0; max-height: 200px; overflow-y: auto;">
            <!-- Items via JS -->
          </ul>
          <script>
            async function loadBlacklist() {
              try {
                const res = await fetch('/api/blacklist');
                const data = await res.json();
                if(data.success) {
                  renderBlacklist(data.blacklist);
                }
              } catch(e) { console.error(e); }
            }

            function renderBlacklist(list) {
              const ul = document.getElementById('blacklistList');
              ul.innerHTML = '';
              if (list.length === 0) {
                ul.innerHTML = '<li style="color:#777; font-size:0.9rem; text-align:center;">Nenhum usuário bloqueado</li>';
                return;
              }
              list.forEach(item => {
                const li = document.createElement('li');
                li.style.display = 'flex';
                li.style.justifyContent = 'space-between';
                li.style.alignItems = 'center';
                li.style.padding = '6px 0';
                li.style.borderBottom = '1px solid #eee';
                
                const span = document.createElement('span');
                span.textContent = item.username;
                span.style.fontWeight = '500';
                
                const btn = document.createElement('button');
                btn.textContent = '✕';
                btn.style.background = 'transparent';
                btn.style.border = 'none';
                btn.style.color = '#dc3545';
                btn.style.cursor = 'pointer';
                btn.style.fontSize = '1.1rem';
                btn.title = 'Desbloquear';
                btn.onclick = () => removeFromBlacklist(item.username);
                
                li.appendChild(span);
                li.appendChild(btn);
                ul.appendChild(li);
              });
            }

            async function addToBlacklist() {
              const input = document.getElementById('blacklistInput');
              const username = input.value.trim();
              if(!username) return;
              
              try {
                const res = await fetch('/api/blacklist/add', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ username })
                });
                const data = await res.json();
                if(data.success) {
                  input.value = '';
                  loadBlacklist();
                } else {
                  alert('Erro ao bloquear: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            async function removeFromBlacklist(username) {
              if(!confirm('Desbloquear ' + username + '?')) return;
              try {
                const res = await fetch('/api/blacklist/remove', {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ username })
                });
                const data = await res.json();
                if(data.success) {
                  loadBlacklist();
                } else {
                  alert('Erro ao desbloquear: ' + (data.message || data.error));
                }
              } catch(e) { alert('Erro: ' + e.message); }
            }

            loadBlacklist();
          </script>
        </div>
    </div>
      <% } %>
    <% } %>

      <% if (isUnknownOrderIdView) { %>
      <div id="unknownOrderModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
        <div style="background:white; padding:20px; border-radius:8px; width:320px; box-shadow:0 4px 6px rgba(0,0,0,0.1);">
          <h3 style="margin-top:0; margin-bottom:15px;">Registrar OrderID</h3>
          <div style="margin-bottom:15px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">Fornecedor:</label>
            <select id="unknownModalProvider" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:4px;">
              <option value="fama24h">Fama24h</option>
              <option value="fama24h_views">Fama24h (Bump Views)</option>
              <option value="fama24h_likes">Fama24h (Bump Curtidas)</option>
              <option value="fornecedor_social">Fornecedor Social</option>
              <option value="worldsmm_comments">WorldSMM (Comentários)</option>
            </select>
          </div>
          <div style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">Order ID:</label>
            <input type="text" id="unknownModalOrderId" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:4px;" placeholder="Ex: 123456">
          </div>
          <div style="display:flex; justify-content:flex-end; gap:10px;">
            <button onclick="closeUnknownOrderModal()" style="padding:8px 16px; background:#6c757d; color:white; border:none; border-radius:4px; cursor:pointer;">Cancelar</button>
            <button onclick="saveUnknownOrderInfo()" style="padding:8px 16px; background:#28a745; color:white; border:none; border-radius:4px; cursor:pointer;">Salvar</button>
          </div>
        </div>
      </div>
      <script>
        let currentUnknownOrderId = null;
        const HIDDEN_ORDERS_KEY = 'oppus_hidden_orders_v1';

        function openUnknownOrderModal(orderId, defaultProvider, lockProvider) {
          currentUnknownOrderId = orderId;
          const modal = document.getElementById('unknownOrderModal');
          const providerEl = document.getElementById('unknownModalProvider');
          const orderIdEl = document.getElementById('unknownModalOrderId');
          if (providerEl && defaultProvider) providerEl.value = defaultProvider;
          if (providerEl) providerEl.disabled = (String(lockProvider || '') === '1');
          if (orderIdEl) orderIdEl.value = '';
          if (modal) modal.style.display = 'flex';
          if (orderIdEl) orderIdEl.focus();
        }

        function closeUnknownOrderModal() {
          const modal = document.getElementById('unknownOrderModal');
          if (modal) modal.style.display = 'none';
          const providerEl = document.getElementById('unknownModalProvider');
          if (providerEl) providerEl.disabled = false;
          currentUnknownOrderId = null;
        }

        async function saveUnknownOrderInfo() {
          const provider = document.getElementById('unknownModalProvider').value;
          const orderIdVal = document.getElementById('unknownModalOrderId').value.trim();
          if (!orderIdVal) {
            alert('Por favor, informe o Order ID do fornecedor.');
            return;
          }
          if (!currentUnknownOrderId) return;

          try {
            const res = await fetch('/api/admin/update-private-order', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({
                id: currentUnknownOrderId,
                field: 'supplierInfo',
                value: { provider, orderId: orderIdVal }
              })
            });
            const contentType = String(res.headers.get('content-type') || '');
            let data = null;
            if (contentType.includes('application/json')) {
              try { data = await res.json(); } catch (_) { data = null; }
            } else {
              const raw = await res.text();
              if (res.status === 401) {
                window.location.href = '/login';
                return;
              }
              throw new Error(raw || `HTTP ${res.status}`);
            }
            if (res.ok && data && data.ok) {
              window.location.reload();
            } else {
              if (res.status === 401) {
                window.location.href = '/login';
                return;
              }
              alert('Erro ao salvar: ' + ((data && data.error) || `HTTP ${res.status}`));
            }
          } catch (e) {
            alert('Erro de conexão: ' + (e && e.message ? e.message : e));
          } finally {
            closeUnknownOrderModal();
          }
        }

        function getHiddenOrdersSet() {
          try {
            const raw = localStorage.getItem(HIDDEN_ORDERS_KEY);
            const arr = raw ? JSON.parse(raw) : [];
            return new Set(Array.isArray(arr) ? arr.map(String) : []);
          } catch (_) {
            return new Set();
          }
        }

        function saveHiddenOrdersSet(set) {
          try {
            const arr = Array.from(set);
            localStorage.setItem(HIDDEN_ORDERS_KEY, JSON.stringify(arr));
          } catch (_) {}
        }

        function applyHiddenOrdersToUnknownTable() {
          const hidden = getHiddenOrdersSet();
          const rows = document.querySelectorAll('tr[data-id]');
          let hiddenCountOnPage = 0;
          rows.forEach(tr => {
            const id = String(tr.getAttribute('data-id') || '');
            if (id && hidden.has(id)) {
              tr.style.display = 'none';
              hiddenCountOnPage += 1;
            } else {
              tr.style.display = '';
            }
          });
          const el = document.getElementById('unknownHiddenCount');
          if (el) el.textContent = String(hiddenCountOnPage);
        }

        function hideSelectedUnknown() {
          const hidden = getHiddenOrdersSet();
          const cbs = document.querySelectorAll('.unknown-hide-cb:checked');
          cbs.forEach(cb => {
            const id = String(cb.getAttribute('data-id') || '');
            if (id) hidden.add(id);
            cb.checked = false;
          });
          const selAll = document.getElementById('unknownSelectAll');
          if (selAll) selAll.checked = false;
          saveHiddenOrdersSet(hidden);
          applyHiddenOrdersToUnknownTable();
        }

        function clearHiddenOrders() {
          try { localStorage.removeItem(HIDDEN_ORDERS_KEY); } catch (_) {}
          applyHiddenOrdersToUnknownTable();
        }

        document.addEventListener('DOMContentLoaded', function () {
          const selAll = document.getElementById('unknownSelectAll');
          if (selAll) {
            selAll.addEventListener('change', function () {
              const checked = !!selAll.checked;
              const cbs = document.querySelectorAll('.unknown-hide-cb');
              cbs.forEach(cb => {
                const tr = cb.closest('tr[data-id]');
                const isVisible = !tr || tr.style.display !== 'none';
                if (isVisible) cb.checked = checked;
              });
            });
          }
          applyHiddenOrdersToUnknownTable();
        });
      </script>
      <% } %>
  </div>
  </div>
</body>
</html>
