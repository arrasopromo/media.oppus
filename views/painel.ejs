            <tbody>
              <% 
                const r2 = Array.isArray(refil2Requests) ? refil2Requests : [];
                const fmtDate = (v) => {
                  try {
                    const d = (v instanceof Date) ? v : new Date(v || 0);
                    if (!Number.isFinite(d.getTime())) return '-';
                    try { return d.toLocaleString('pt-BR'); } catch (_) {}
                    const y = d.getFullYear();
                    const m = String(d.getMonth() + 1).padStart(2, '0');
                    const day = String(d.getDate()).padStart(2, '0');
                    const hh = String(d.getHours()).padStart(2, '0');
                    const mm = String(d.getMinutes()).padStart(2, '0');
                    const ss = String(d.getSeconds()).padStart(2, '0');
                    return `${day}/${m}/${y} ${hh}:${mm}:${ss}`;
                  } catch (_) { return '-'; }
                };
                const resolveStatus = (it) => {
                  const exec = String(it && (it.execStatus || it.exec || '') || '').toLowerCase().trim();
                  const decision = String(it && (it.decisionStatus || it.decision || it.status || '') || '').toLowerCase().trim();
                  const reason = String(it && (it.decisionReason || it.reason || '') || '').toLowerCase().trim();
                  const err = String(it && (it.errorMessage || it.error || it.webhookMessage || it.statusMessage || '') || '').trim();
                  const minDrop = (it && it.computed && typeof it.computed.min_drop === 'number') ? it.computed.min_drop : 100;
                  if (reason === 'add_reorder_ok') return { kind: 'success', label: 'Iniciado', cls: 'refil2-badge--green', msg: 'add_reorder_ok' };
                  if (reason === 'below_min_drop') return { kind: 'info', label: 'Sem queda', cls: 'refil2-badge--gray', msg: `Abaixo de ${minDrop}` };
                  if (reason === 'paid_today') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Pago hoje' };
                  if (reason === 'no_orders') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Sem pedidos' };
                  if (reason === 'no_followers_purchase') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Sem compra de seguidores' };
                  if (reason === 'reorder_expired') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Prazo expirado' };
                  if (exec === 'success' && (decision === 'initiated' || decision === 'no_drop')) {
                    return { kind: (decision === 'no_drop' ? 'info' : 'success'), label: (decision === 'no_drop' ? 'Sem queda' : 'Iniciado'), cls: (decision === 'no_drop' ? 'refil2-badge--gray' : 'refil2-badge--green'), msg: reason || 'OK' };
                  }
                  if (exec === 'error' || decision === 'error') return { kind: 'error', label: 'Erro', cls: 'refil2-badge--red', msg: err || reason || '-' };
                  if (exec === 'success' && decision === 'blocked') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: reason || err || '-' };
                  return { kind: 'error', label: 'Erro', cls: 'refil2-badge--red', msg: err || reason || '-' };
                };
              %>
              <% if (r2.length) { %>
                <% r2.forEach(it => { 
                  const rid = String(it && it._id ? it._id : '').trim();
                  const when = fmtDate(it && (it.requestedAt || it.createdAt) ? (it.requestedAt || it.createdAt) : '');
                  const purchase = String(it && (it.purchaseAtLabel || it.purchaseAt) ? (it.purchaseAtLabel || fmtDate(it.purchaseAt)) : '-');
                  const reqRaw = it && (it.requestedAt || it.createdAt) ? (it.requestedAt || it.createdAt) : null;
                  const reqMs = reqRaw ? new Date(reqRaw).getTime() : 0;
                  const purRaw = it && it.purchaseAt ? it.purchaseAt : null;
                  const purMs = purRaw ? new Date(purRaw).getTime() : 0;
                  const dayDiff = (() => {
                    try {
                      if (!Number.isFinite(reqMs) || !reqMs) return null;
                      if (!Number.isFinite(purMs) || !purMs) return null;
                      const days = Math.floor((reqMs - purMs) / (24 * 60 * 60 * 1000));
                      if (!Number.isFinite(days)) return null;
                      return days;
                    } catch (_) { return null; }
                  })();
                  const user = String(it && it.username ? it.username : '-').trim();
                  const userSlug = String(user || '').trim().replace(/^@+/, '');
                  const userHref = (userSlug && userSlug !== '-') ? (`https://www.instagram.com/${encodeURIComponent(userSlug)}/`) : '';
                  const tipoLabel = String(it && (it.lastFollowersTipoLabel || it.lastFollowersTipo) ? (it.lastFollowersTipoLabel || it.lastFollowersTipo) : '-').trim() || '-';
                  const sum = (it && (it.summary || it.computed || it.data) && typeof (it.summary || it.computed || it.data) === 'object') ? (it.summary || it.computed || it.data) : {};
                  const initialQty = (typeof sum.initial === 'number') ? sum.initial : (typeof sum.quantidade_inicial === 'number' ? sum.quantidade_inicial : null);
                  const currentQty = (typeof sum.current === 'number') ? sum.current : (typeof sum.quantidade_atual === 'number' ? sum.quantidade_atual : null);
                  const dropQty = (typeof sum.drop === 'number') ? sum.drop : (typeof sum.deficit === 'number' ? sum.deficit : (typeof sum.quantidade_de_queda === 'number' ? sum.quantidade_de_queda : null));
                  const finalQty = (typeof sum.final === 'number') ? sum.final : ((currentQty != null && dropQty != null) ? (currentQty + dropQty) : (initialQty != null ? initialQty : null));
                  const st = resolveStatus(it);
                  const auditObj = (it && it.audit && typeof it.audit === 'object') ? it.audit : {};
                  const auditCurrent = (typeof auditObj.currentFollowers === 'number') ? auditObj.currentFollowers : null;
                  const auditResult = (typeof auditObj.result === 'string') ? auditObj.result : '';
                  const forceObj = (it && it.forceRefil && typeof it.forceRefil === 'object') ? it.forceRefil : {};
                  const forceOrderId = (forceObj && (forceObj.orderId !== null && typeof forceObj.orderId !== 'undefined')) ? String(forceObj.orderId).trim() : '';
                  const forceChargeRaw = (forceObj && (forceObj.charge !== null && typeof forceObj.charge !== 'undefined')) ? forceObj.charge : null;
                  const forceCharge = (forceChargeRaw === null || typeof forceChargeRaw === 'undefined') ? '' : String(forceChargeRaw).trim();
                  const forceAt = (forceOrderId && forceObj && (forceObj.forcedAt || forceObj.finishedAt || forceObj.requestedAt)) ? fmtDate(forceObj.forcedAt || forceObj.finishedAt || forceObj.requestedAt) : '-';
                  const forceStatus = String(forceObj && forceObj.status ? forceObj.status : '').toLowerCase().trim();
                  const hasForced = !!forceOrderId || forceStatus === 'processing' || forceStatus === 'created';
                  const forceCharged = !!(forceObj && (forceObj.charged === true || forceObj.chargedAt));
                %>
                  <tr data-refil2-id="<%= rid %>" data-refil2-days="<%= (dayDiff !== null ? String(dayDiff) : '') %>" data-refil2-whenms="<%= (Number.isFinite(reqMs) ? String(reqMs) : '') %>" data-refil2-kind="<%= String(st.kind || '') %>" data-refil2-charged="<%= forceCharged ? '1' : '0' %>">
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; text-align:center;">
                      <input type="checkbox" class="refil2SelectRow" <%= rid ? '' : 'disabled' %> />
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= when %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= purchase %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (dayDiff !== null ? String(dayDiff) : '-') %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;">
                      <% if (userHref) { %>
                        <a href="<%= userHref %>" target="_blank" rel="noopener" style="color:#111827; text-decoration:underline;"><%= ('@' + userSlug) %></a>
                      <% } else { %>
                        <%= user ? ('@' + user.replace(/^@+/, '')) : '-' %>
                      <% } %>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= tipoLabel %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (currentQty != null ? String(currentQty) : '-') %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (dropQty != null ? String(dropQty) : '-') %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (finalQty != null ? String(finalQty) : (initialQty != null ? String(initialQty) : '-')) %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; text-align:right;">
                      <div style="display:flex; align-items:center; justify-content:flex-end; gap:8px;">
                        <input type="number" class="refil2AuditCurrent" value="<%= (auditCurrent != null ? String(auditCurrent) : '') %>" placeholder="-" style="width:92px; padding:6px 2px; border:0; border-radius:0; text-align:right; outline:none; background:transparent;" />
                        <button type="button" class="refil2AuditVerifyOne" style="padding:5px 8px; border:1px solid #e5e7eb; background:#fff; color:#111827; border-radius:8px; cursor:pointer; font-size:0.85rem;">Verificar</button>
                      </div>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6;">
                      <input type="text" class="refil2AuditResult" value="<%= String(auditResult || '') %>" placeholder="" style="width:90px; max-width: 90px; padding:6px 8px; border:1px solid #e5e7eb; border-radius:8px; text-transform: uppercase;" />
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6;"><span class="refil2-badge <%= st.cls %>"><%= st.label %></span></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#374151;"><%= st.msg %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6;">
                      <button type="button" class="refil2ForceRefilOne" style="padding:5px 8px; border:1px solid #e5e7eb; background:#111827; color:#fff; border-radius:8px; cursor:pointer; font-size:0.85rem;">Forçar refil</button>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;">
                      <span class="refil2ForceAt"><%= forceAt %></span>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; font-family: monospace; color:#111827;">
                      <span class="refil2ForceOrderId"><%= forceOrderId || '-' %></span>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; font-family: monospace; color:#111827;">
                      <span class="refil2ForceCharge"><%= forceCharge || '-' %></span>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; text-align:center;">
                      <span class="refil2ChargedOk" style="font-weight:800; color:#16a34a;"><%= forceCharged ? 'OK' : '' %></span>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="18" style="padding:10px 6px; color:#6b7280; text-align:center;">Sem solicitações ainda</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <div id="refil2ChargeModal" style="display:none; position:fixed; inset:0; background: rgba(0,0,0,0.45); z-index: 9999; align-items:center; justify-content:center; padding: 18px;">
        <div style="width: 100%; max-width: 920px; background:#fff; border-radius: 12px; box-shadow: 0 18px 60px rgba(0,0,0,0.25); overflow:hidden;">
          <div style="padding: 12px 14px; border-bottom: 1px solid #e5e7eb; display:flex; align-items:center; justify-content:space-between; gap: 10px;">
            <div style="font-weight: 900; color:#111827;">Cobrança (copiar)</div>
            <button type="button" id="refil2ChargeClose" style="padding:6px 10px; border:1px solid #e5e7eb; background:#fff; border-radius:8px; cursor:pointer;">Fechar</button>
          </div>
          <div style="padding: 12px 14px;">
            <div id="refil2ChargeMeta" style="font-size:0.9rem; color:#6b7280; margin-bottom: 10px;"></div>
            <pre id="refil2ChargeText" style="white-space: pre-wrap; word-break: break-word; border:1px solid #e5e7eb; background:#f9fafb; padding: 12px; border-radius: 10px; max-height: 420px; overflow:auto; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace; font-size: 0.9rem;"></pre>
            <div style="display:flex; gap:10px; justify-content:flex-end; margin-top: 12px;">
              <button type="button" id="refil2ChargeCopy" style="padding:8px 12px; border:1px solid #e5e7eb; background:#111827; color:#fff; border-radius:10px; cursor:pointer;">Copiar e marcar OK</button>
            </div>
          </div>
        </div>
      </div>
      <script>
        (function(){
          function el(id){ return document.getElementById(id); }
          try {
            var topScroll = el('refil2ScrollTop');
            var topInner = el('refil2ScrollTopInner');
            var bottomScroll = el('refil2ScrollBottom');
            var table = bottomScroll ? bottomScroll.querySelector('table') : null;
            var syncing = false;
            function syncTopWidth(){
              try {
                if (!topInner || !table) return;
                topInner.style.width = String(table.scrollWidth || 0) + 'px';
              } catch (_) {}
            }
            if (topScroll && bottomScroll) {
              topScroll.addEventListener('scroll', function(){
                try {
                  if (syncing) return;
                  syncing = true;
                  bottomScroll.scrollLeft = topScroll.scrollLeft;
                } catch (_) {} finally { syncing = false; }
              });
              bottomScroll.addEventListener('scroll', function(){
                try {
                  if (syncing) return;
                  syncing = true;
                  topScroll.scrollLeft = bottomScroll.scrollLeft;
                } catch (_) {} finally { syncing = false; }
              });
            }
            syncTopWidth();
            window.addEventListener('resize', function(){ syncTopWidth(); });
            setTimeout(syncTopWidth, 50);
          } catch (_) {}
          function readJsonResp(resp){
            try { return resp && typeof resp.json === 'function' ? resp.json() : Promise.resolve(null); } catch (_) { return Promise.resolve(null); }
          }
          function sortRows(dir){
            try {
              var wrap = el('refil2RequestsWrap');
              if (!wrap) return;
              var tbody = wrap.querySelector('tbody');
              if (!tbody) return;
              var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
              if (!rows.length) return;
              rows.sort(function(a, b){
                var da = String(a.getAttribute('data-refil2-days') || '').trim();
                var db = String(b.getAttribute('data-refil2-days') || '').trim();
                var na = da === '' ? null : Number(da);
                var nb = db === '' ? null : Number(db);
                var aOk = (na !== null && isFinite(na));
                var bOk = (nb !== null && isFinite(nb));
                if (!aOk && !bOk) return 0;
                if (!aOk) return 1;
                if (!bOk) return -1;
                return (na - nb) * dir;
              });
              rows.forEach(function(r){ tbody.appendChild(r); });
            } catch (_) {}
          }
          var state = { dir: 'desc', page: 1, pageSize: 50, totalMatched: 0, totalPages: 1 };
          function parsePtBrDateTime(s){
            try {
              var t = String(s || '').trim();
              if (!t || t === '-') return null;
              var m = t.match(/(\d{2})\/(\d{2})\/(\d{4})(?:,\s*|\s+)?(\d{2}):(\d{2})(?::(\d{2}))?/);
              if (!m) {
                var m2 = t.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                if (!m2) return null;
                var dd2 = Number(m2[1]), mm2 = Number(m2[2]), yy2 = Number(m2[3]);
                var d2 = new Date(yy2, mm2 - 1, dd2, 0, 0, 0, 0);
                return Number.isFinite(d2.getTime()) ? d2.getTime() : null;
              }
              var dd = Number(m[1]), mm = Number(m[2]), yy = Number(m[3]);
              var hh = Number(m[4] || '0'), mi = Number(m[5] || '0'), ss = Number(m[6] || '0');
              var d = new Date(yy, mm - 1, dd, hh, mi, ss, 0);
              return Number.isFinite(d.getTime()) ? d.getTime() : null;
            } catch (_) { return null; }
          }
          function parseDateInputStart(v){
            try {
              var s = String(v || '').trim();
              if (!s) return null;
              var d = new Date(s + 'T00:00:00');
              return Number.isFinite(d.getTime()) ? d.getTime() : null;
            } catch (_) { return null; }
          }
          function parseDateInputEnd(v){
            try {
              var s = String(v || '').trim();
              if (!s) return null;
              var d = new Date(s + 'T23:59:59');
              return Number.isFinite(d.getTime()) ? d.getTime() : null;
            } catch (_) { return null; }
          }
          function applyFilters(){
            try {
              var cb = el('refil2OnlyErrors');
              var sel = el('refil2StatusFilter');
              var dateCol = el('refil2DateColumn');
              var dateFromEl = el('refil2DateFrom');
              var dateToEl = el('refil2DateTo');
              var onlyOidEl = el('refil2OnlyWithRefilId');
              var wrap = el('refil2RequestsWrap');
              if (!wrap) return;
              var tbody = wrap.querySelector('tbody');
              if (!tbody) return;
              var onlyErrors = cb ? !!cb.checked : false;
              var kindFilter = sel ? String(sel.value || 'all').trim() : 'all';
              var colKey = dateCol ? String(dateCol.value || 'requested').trim() : 'requested';
              var fromMs = parseDateInputStart(dateFromEl ? dateFromEl.value : '');
              var toMs = parseDateInputEnd(dateToEl ? dateToEl.value : '');
              var onlyWithOid = onlyOidEl ? !!onlyOidEl.checked : false;
              var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
              rows.forEach(function(r){
                var kind = String(r.getAttribute('data-refil2-kind') || '').trim();
                var show = true;
                if (onlyErrors && kind !== 'error') show = false;
                if (kindFilter && kindFilter !== 'all' && kind !== kindFilter) show = false;
                if (show && onlyWithOid) {
                  try {
                    var oidEl = r.querySelector('.refil2ForceOrderId');
                    var oidTxt = oidEl ? String(oidEl.textContent || '').trim() : '';
                    if (!oidTxt || oidTxt === '-') show = false;
                  } catch (_) { show = false; }
                }
                if (show && (fromMs !== null || toMs !== null)) {
                  var rowMs = null;
                  try {
                    if (colKey === 'purchase') {
                      var td = r.querySelector('td:nth-child(3)');
                      rowMs = parsePtBrDateTime(td ? td.textContent : '');
                    } else if (colKey === 'forced') {
                      var f = r.querySelector('.refil2ForceAt');
                      rowMs = parsePtBrDateTime(f ? f.textContent : '');
                    } else {
                      var td2 = r.querySelector('td:nth-child(2)');
                      rowMs = parsePtBrDateTime(td2 ? td2.textContent : '');
                    }
                  } catch (_) { rowMs = null; }
                  if (rowMs === null) show = false;
                  if (show && fromMs !== null && rowMs < fromMs) show = false;
                  if (show && toMs !== null && rowMs > toMs) show = false;
                }
                try { r.setAttribute('data-refil2-match', show ? '1' : '0'); } catch (_) {}
              });
            } catch (_) {}
          }

          function applyPagination(){
            try {
              var wrap = el('refil2RequestsWrap');
              if (!wrap) return;
              var tbody = wrap.querySelector('tbody');
              if (!tbody) return;
              var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
              var total = 0;
              for (var i0 = 0; i0 < rows.length; i0++) {
                if (String(rows[i0].getAttribute('data-refil2-match') || '') === '1') total++;
              }
              state.totalMatched = total;
              var pages = Math.max(1, Math.ceil(total / state.pageSize));
              state.totalPages = pages;
              if (state.page > pages) state.page = pages;
              if (state.page < 1) state.page = 1;
              var start = (state.page - 1) * state.pageSize;
              var end = start + state.pageSize;
              var seen = 0;
              for (var i = 0; i < rows.length; i++) {
                var r = rows[i];
                var isMatch = String(r.getAttribute('data-refil2-match') || '') === '1';
                if (!isMatch) { r.style.display = 'none'; continue; }
                var idx = seen;
                seen++;
                r.style.display = (idx >= start && idx < end) ? '' : 'none';
              }
              try {
                var info = el('refil2PaginationInfo');
                if (info) info.textContent = 'Página ' + String(state.page) + ' / ' + String(pages) + ' · ' + String(total) + ' linhas';
              } catch (_) {}
              try {
                var prev = el('refil2PrevPageBtn');
                var next = el('refil2NextPageBtn');
                if (prev) prev.disabled = state.page <= 1;
                if (next) next.disabled = state.page >= pages;
              } catch (_) {}
            } catch (_) {}
          }
          try {
            var cb = el('refil2OnlyErrors');
            if (cb) cb.addEventListener('change', function(){ state.page = 1; applyFilters(); applyPagination(); });
            var sel = el('refil2StatusFilter');
            if (sel) sel.addEventListener('change', function(){ state.page = 1; applyFilters(); applyPagination(); });
            var dcol = el('refil2DateColumn');
            if (dcol) dcol.addEventListener('change', function(){ state.page = 1; applyFilters(); applyPagination(); });
            var dfrom = el('refil2DateFrom');
            if (dfrom) dfrom.addEventListener('change', function(){ state.page = 1; applyFilters(); applyPagination(); });
            var dto = el('refil2DateTo');
            if (dto) dto.addEventListener('change', function(){ state.page = 1; applyFilters(); applyPagination(); });
            var onlyOidEl = el('refil2OnlyWithRefilId');
            if (onlyOidEl) onlyOidEl.addEventListener('change', function(){ state.page = 1; applyFilters(); applyPagination(); });
            applyFilters();
            applyPagination();
            var clearBtn = el('refil2ClearFiltersBtn');
            if (clearBtn) clearBtn.addEventListener('click', function(){
              try {
                var cb2 = el('refil2OnlyErrors');
                if (cb2) cb2.checked = false;
                var sel2 = el('refil2StatusFilter');
                if (sel2) sel2.value = 'all';
                var dcol2 = el('refil2DateColumn');
                if (dcol2) dcol2.value = 'requested';
                var df2 = el('refil2DateFrom');
                if (df2) df2.value = '';
                var dt2 = el('refil2DateTo');
                if (dt2) dt2.value = '';
                var oid2 = el('refil2OnlyWithRefilId');
                if (oid2) oid2.checked = false;
                try {
                  var selAll2 = el('refil2SelectAll');
                  if (selAll2) selAll2.checked = false;
                } catch (_) {}
                state.page = 1;
                applyFilters();
                applyPagination();
              } catch (_) {}
            });
          } catch (_) {}
          function csvEscape(v){
            var s = (v === null || typeof v === 'undefined') ? '' : String(v);
            if (s.includes('"')) s = s.replace(/"/g, '""');
            if (/[;\n\r"]/.test(s)) s = '"' + s + '"';
            return s;
          }
          function downloadCsv(filename, header, rows){
            try {
              var lines = [];
              if (header && header.length) lines.push(header.map(csvEscape).join(';'));
              for (var i = 0; i < rows.length; i++) lines.push(rows[i].map(csvEscape).join(';'));
              var csv = '\ufeff' + lines.join('\r\n');
              var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
              var url = URL.createObjectURL(blob);
              var a = document.createElement('a');
              a.href = url;
              a.download = filename;
              document.body.appendChild(a);
              a.click();
              setTimeout(function(){ try { URL.revokeObjectURL(url); } catch(_) {} try { a.remove(); } catch(_) {} }, 200);
            } catch (e) {
              alert('Erro ao exportar: ' + (e && e.message ? e.message : e));
            }
          }
          function parseNumberLoose(v){
            try {
              var s = String(v == null ? '' : v).trim();
              if (!s || s === '-') return null;
              var s2 = s.replace(/[^\d,.-]/g, '').replace(',', '.');
              if (!s2) return null;
              var n = Number(s2);
              return Number.isFinite(n) ? n : null;
            } catch (_) { return null; }
          }
          function getVisibleRows(){
            var wrap = el('refil2RequestsWrap');
            if (!wrap) return [];
            var tbody = wrap.querySelector('tbody');
            if (!tbody) return [];
            var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
            return rows.filter(function(r){ return r && r.style && r.style.display !== 'none'; });
          }
          function getMatchedRows(){
            var wrap = el('refil2RequestsWrap');
            if (!wrap) return [];
            var tbody = wrap.querySelector('tbody');
            if (!tbody) return [];
            var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
            return rows.filter(function(r){ return String(r.getAttribute('data-refil2-match') || '') === '1'; });
          }
          function isChargedOkRow(r){
            try { return String(r.getAttribute('data-refil2-charged') || '') === '1'; } catch (_) { return false; }
          }
          try {
            var exportAllBtn = el('refil2ExportAllBtn');
            if (exportAllBtn) {
              exportAllBtn.addEventListener('click', function(){
                var rows = getMatchedRows();
                if (!rows.length) { alert('Nenhuma linha para exportar.'); return; }
                var header = ['Solicitação', 'Compra', 'Dias', 'Usuário', 'Tipo', 'Atual', 'Repor', 'Final', 'Quantidade antes da reposição', 'Audit Resultado', 'Status', 'Mensagem', 'Forçado em', 'Refil ID', 'Custo', 'Cobrado OK'];
                var out = rows.map(function(r){
                  var tds = r.querySelectorAll('td');
                  var requested = tds[1] ? String(tds[1].textContent || '').trim() : '';
                  var purchase = tds[2] ? String(tds[2].textContent || '').trim() : '';
                  var days = tds[3] ? String(tds[3].textContent || '').trim() : '';
                  var user = tds[4] ? String(tds[4].textContent || '').trim() : '';
                  var tipo = tds[5] ? String(tds[5].textContent || '').trim() : '';
                  var atual = tds[6] ? String(tds[6].textContent || '').trim() : '';
                  var repor = tds[7] ? String(tds[7].textContent || '').trim() : '';
                  var finalV = tds[8] ? String(tds[8].textContent || '').trim() : '';
                  var auditCurEl = r.querySelector('input.refil2AuditCurrent');
                  var auditCur = auditCurEl ? String(auditCurEl.value || '').trim() : '';
                  var auditResEl = r.querySelector('input.refil2AuditResult');
                  var auditRes = auditResEl ? String(auditResEl.value || '').trim() : '';
                  var st = tds[11] ? String(tds[11].textContent || '').trim() : '';
                  var msg = tds[12] ? String(tds[12].textContent || '').trim() : '';
                  var forcedAt = (r.querySelector('.refil2ForceAt') ? String(r.querySelector('.refil2ForceAt').textContent || '').trim() : '');
                  var oid = (r.querySelector('.refil2ForceOrderId') ? String(r.querySelector('.refil2ForceOrderId').textContent || '').trim() : '');
                  var cost = (r.querySelector('.refil2ForceCharge') ? String(r.querySelector('.refil2ForceCharge').textContent || '').trim() : '');
                  var charged = isChargedOkRow(r) ? 'OK' : '';
                  return [requested, purchase, days, user, tipo, atual, repor, finalV, auditCur, auditRes, st, msg, forcedAt, oid, cost, charged];
                });
                var ts = new Date();
                var name = 'refil2_export_' + ts.toISOString().slice(0,19).replace(/[:T]/g,'-') + '.csv';
                downloadCsv(name, header, out);
              });
            }
          } catch (_) {}
          try {
            var exportChargeBtn = el('refil2ExportChargeBtn');
            if (exportChargeBtn) {
              exportChargeBtn.addEventListener('click', function(){
                var rows = getMatchedRows();
                if (!rows.length) { alert('Nenhuma linha para exportar.'); return; }
                var header = ['Usuário', 'Quantidade antes da reposição', 'Quantidade reposta', 'Refil ID', 'Custo', 'Cobrado OK'];
                var out = [];
                var total = 0;
                for (var i = 0; i < rows.length; i++) {
                  var r = rows[i];
                  var oid = (r.querySelector('.refil2ForceOrderId') ? String(r.querySelector('.refil2ForceOrderId').textContent || '').trim() : '');
                  if (!oid || oid === '-') continue;
                  var tds = r.querySelectorAll('td');
                  var user = tds[4] ? String(tds[4].textContent || '').trim() : '';
                  var auditCurEl = r.querySelector('input.refil2AuditCurrent');
                  var auditCur = auditCurEl ? String(auditCurEl.value || '').trim() : '';
                  var repor = tds[7] ? String(tds[7].textContent || '').trim() : '';
                  var costTxt = (r.querySelector('.refil2ForceCharge') ? String(r.querySelector('.refil2ForceCharge').textContent || '').trim() : '');
                  var costN = parseNumberLoose(costTxt);
                  if (costN !== null) total += costN;
                  var charged = isChargedOkRow(r) ? 'OK' : '';
                  out.push([user, auditCur, repor, oid, costTxt, charged]);
                }
                if (!out.length) { alert('Nenhuma linha com Refil ID para exportar.'); return; }
                out.push(['TOTAL', '', '', '', String(total.toFixed(2)).replace('.', ','), '']);
                var ts = new Date();
                var name = 'refil2_cobrar_orderids_' + ts.toISOString().slice(0,19).replace(/[:T]/g,'-') + '.csv';
                downloadCsv(name, header, out);
              });
            }
          } catch (_) {}
          try {
            var chargeBtn = el('refil2ChargeBtn');
            var modal = el('refil2ChargeModal');
            var closeBtn = el('refil2ChargeClose');
            var copyBtn = el('refil2ChargeCopy');
            var pre = el('refil2ChargeText');
            var meta = el('refil2ChargeMeta');
            var pendingChargeIds = [];
            function openModal(){ if (modal) { modal.style.display = 'flex'; } }
            function closeModal(){ if (modal) { modal.style.display = 'none'; } pendingChargeIds = []; }
            if (closeBtn) closeBtn.addEventListener('click', closeModal);
            try {
              if (modal) modal.addEventListener('click', function(ev){ if (ev && ev.target === modal) closeModal(); });
            } catch (_) {}
            if (chargeBtn) chargeBtn.addEventListener('click', function(){
              try {
                var wrap = el('refil2RequestsWrap');
                if (!wrap) return;
                var rows = Array.prototype.slice.call(wrap.querySelectorAll('tbody tr'));
                var selected = rows.filter(function(r){
                  try {
                    if (r.style.display === 'none') return false;
                    var cb = r.querySelector('input.refil2SelectRow');
                    return cb && cb.checked;
                  } catch (_) { return false; }
                });
                if (!selected.length) { alert('Selecione pelo menos 1 linha.'); return; }
                var lines = [];
                var total = 0;
                var skippedOk = 0;
                var skippedNoOid = 0;
                pendingChargeIds = [];
                try {
                  lines.push('*Cobrança Refil*');
                  lines.push('Gerado em: ' + (new Date()).toLocaleString('pt-BR'));
                  lines.push('');
                } catch (_) {}
                for (var i = 0; i < selected.length; i++) {
                  var r = selected[i];
                  if (isChargedOkRow(r)) { skippedOk++; continue; }
                  var id = String(r.getAttribute('data-refil2-id') || '').trim();
                  if (!id) continue;
                  var oid = (r.querySelector('.refil2ForceOrderId') ? String(r.querySelector('.refil2ForceOrderId').textContent || '').trim() : '');
                  if (!oid || oid === '-') { skippedNoOid++; continue; }
                  var tds = r.querySelectorAll('td');
                  var user = tds[4] ? String(tds[4].textContent || '').trim() : '';
                  var auditCurEl = r.querySelector('input.refil2AuditCurrent');
                  var auditCur = auditCurEl ? String(auditCurEl.value || '').trim() : '';
                  var repor = tds[7] ? String(tds[7].textContent || '').trim() : '';
                  var costTxt = (r.querySelector('.refil2ForceCharge') ? String(r.querySelector('.refil2ForceCharge').textContent || '').trim() : '');
                  var costN = parseNumberLoose(costTxt);
                  if (costN !== null) total += costN;
                  lines.push('• ' + (user || '-'));
                  lines.push('  Antes da reposição: ' + (auditCur || '-'));
                  lines.push('  Quantidade reposta: ' + (repor || '-'));
                  lines.push('  Refil ID: ' + (oid || '-'));
                  lines.push('  Custo: ' + (costTxt || '-'));
                  lines.push('');
                  pendingChargeIds.push(id);
                }
                if (!lines.length) {
                  var m = 'Nenhuma linha elegível para cobrar.';
                  if (skippedOk) m += ' ' + skippedOk + ' já estavam OK.';
                  if (skippedNoOid) m += ' ' + skippedNoOid + ' sem Refil ID.';
                  alert(m);
                  return;
                }
                try {
                  lines.push('*TOTAL CUSTO:* ' + String(total.toFixed(2)).replace('.', ','));
                } catch (_) {
                  lines.push('TOTAL: ' + String(total));
                }
                if (pre) pre.textContent = lines.join('\n');
                if (meta) {
                  var msg = 'Linhas: ' + String(pendingChargeIds.length);
                  if (skippedOk) msg += ' · Ignoradas (já OK): ' + String(skippedOk);
                  if (skippedNoOid) msg += ' · Ignoradas (sem Refil ID): ' + String(skippedNoOid);
                  meta.textContent = msg;
                }
                openModal();
              } catch (e) {
                alert('Erro ao preparar cobrança: ' + (e && e.message ? e.message : e));
              }
            });
            if (copyBtn) copyBtn.addEventListener('click', async function(){
              try {
                var text = pre ? String(pre.textContent || '').trim() : '';
                if (!text) return;
                try {
                  if (navigator && navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                    await navigator.clipboard.writeText(text);
                  } else {
                    throw new Error('clipboard_unavailable');
                  }
                } catch (_) {
                  try {
                    var ta = document.createElement('textarea');
                    ta.value = text;
                    ta.style.position = 'fixed';
                    ta.style.left = '-9999px';
                    document.body.appendChild(ta);
                    ta.focus();
                    ta.select();
                    document.execCommand('copy');
                    ta.remove();
                  } catch (e2) {
                    alert('Não foi possível copiar automaticamente.');
                    return;
                  }
                }
                if (!pendingChargeIds.length) { closeModal(); return; }
                copyBtn.disabled = true;
                copyBtn.style.opacity = '0.7';
                var resp = await fetch('/api/painel/refil2/force-refil/charged-bulk', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ ids: pendingChargeIds, charged: true })
                });
                var data = await readJsonResp(resp);
                if (!resp.ok || !(data && data.ok)) {
                  var msg = (data && (data.message || data.error)) ? String(data.message || data.error) : ('HTTP ' + resp.status);
                  alert('Copiado, mas erro ao marcar OK: ' + msg);
                  return;
                }
                try {
                  var wrap = el('refil2RequestsWrap');
                  var rows = wrap ? Array.prototype.slice.call(wrap.querySelectorAll('tbody tr')) : [];
                  rows.forEach(function(r){
                    var id = String(r.getAttribute('data-refil2-id') || '').trim();
                    if (!id) return;
                    if (pendingChargeIds.indexOf(id) < 0) return;
                    try { r.setAttribute('data-refil2-charged', '1'); } catch (_) {}
                    try {
                      var okEl = r.querySelector('.refil2ChargedOk');
                      if (okEl) okEl.textContent = 'OK';
                    } catch (_) {}
                    try {
                      var cb = r.querySelector('input.refil2SelectRow');
                      if (cb) cb.checked = false;
                    } catch (_) {}
                  });
                  try {
                    var selAll = el('refil2SelectAll');
                    if (selAll) selAll.checked = false;
                  } catch (_) {}
                } catch (_) {}
                closeModal();
              } catch (e) {
                alert('Erro ao copiar/marcar: ' + (e && e.message ? e.message : e));
              } finally {
                try { copyBtn.disabled = false; copyBtn.style.opacity = '1'; } catch (_) {}
              }
            });
          } catch (_) {}

          try {
            var prevBtn = el('refil2PrevPageBtn');
            if (prevBtn) {
              prevBtn.addEventListener('click', function(){
                if (state.page > 1) { state.page--; applyPagination(); }
              });
            }
            var nextBtn = el('refil2NextPageBtn');
            if (nextBtn) {
              nextBtn.addEventListener('click', function(){
                if (state.page < state.totalPages) { state.page++; applyPagination(); }
              });
            }
          } catch (_) {}
          try {
            var selAll = el('refil2SelectAll');
            if (selAll) {
              selAll.addEventListener('change', function(){
                try {
                  var wrap = el('refil2RequestsWrap');
                  if (!wrap) return;
                  var rows = Array.prototype.slice.call(wrap.querySelectorAll('tbody tr'));
                  rows.forEach(function(r){
                    if (r.style.display === 'none') return;
                    var id = String(r.getAttribute('data-refil2-id') || '').trim();
                    if (!id) return;
                    var cb = r.querySelector('input.refil2SelectRow');
                    if (cb && !cb.disabled) cb.checked = !!selAll.checked;
                  });
                } catch (_) {}
              });
            }
          } catch (_) {}
          try {
            var fetchBtn = el('refil2AuditFetchBtn');
            if (fetchBtn) {
              fetchBtn.addEventListener('click', async function(){
                try {
                  var wrap = el('refil2RequestsWrap');
                  if (!wrap) return;
                  var rows = Array.prototype.slice.call(wrap.querySelectorAll('tbody tr'));
                  var ids = [];
                  rows.forEach(function(r){
                    try {
                      var cb = r.querySelector('input.refil2SelectRow');
                      if (!cb || !cb.checked) return;
                      var id = String(r.getAttribute('data-refil2-id') || '').trim();
                      if (!id) return;
                      ids.push(id);
                    } catch (_) {}
                  });
                  if (!ids.length) { alert('Selecione pelo menos 1 linha.'); return; }
                  fetchBtn.disabled = true;
                  fetchBtn.style.opacity = '0.7';
                  var resp = await fetch('/api/painel/refil2/audit-verify-current', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: ids })
                  });
                  var data = await readJsonResp(resp);
                  if (!resp.ok || !(data && data.ok)) {
                    var msg = (data && (data.message || data.error)) ? String(data.message || data.error) : ('HTTP ' + resp.status);
                    alert('Erro ao verificar audit atual: ' + msg);
                    return;
                  }
                  var results = Array.isArray(data.results) ? data.results : [];
                  var map = {};
                  results.forEach(function(it){
                    if (!it || !it.id) return;
                    map[String(it.id)] = it;
                  });
                  var updated = 0;
                  rows.forEach(function(r){
                    try {
                      var id = String(r.getAttribute('data-refil2-id') || '').trim();
                      if (!id) return;
                      var item = map[id];
                      if (!item) return;
                      var curEl = r.querySelector('input.refil2AuditCurrent');
                      if (curEl && typeof item.currentFollowers === 'number' && isFinite(item.currentFollowers)) {
                        curEl.value = String(Math.trunc(item.currentFollowers));
                        try {
                          var resEl = r.querySelector('input.refil2AuditResult');
                          if (resEl && item.auditResult) resEl.value = String(item.auditResult);
                        } catch (_) {}
                        try {
                          var tdFinal = r.querySelector('td:nth-child(9)');
                          var tdRepor = r.querySelector('td:nth-child(8)');
                          var finalTxt = tdFinal ? String(tdFinal.textContent || '').trim() : '';
                          var finalN = finalTxt ? Number(String(finalTxt).replace(/[^\d-]/g, '')) : NaN;
                          if (isFinite(finalN) && tdRepor) {
                            var needed = Math.max(0, Math.trunc(finalN) - Math.trunc(item.currentFollowers));
                            tdRepor.textContent = needed ? String(needed) : '0';
                          }
                        } catch (_) {}
                        updated++;
                      }
                    } catch (_) {}
                  });
                  var failed = results.filter(function(x){ return x && x.error; }).length;
                  alert('Verificação concluída: ' + updated + ' atualizado(s)' + (failed ? (' · ' + failed + ' falha(s)') : '') + '.');
                } catch (e) {
                  alert('Erro ao verificar audit atual: ' + (e && e.message ? e.message : e));
                } finally {
                  try { fetchBtn.disabled = false; fetchBtn.style.opacity = '1'; } catch (_) {}
                }
              });
            }
          } catch (_) {}
          try {
            var forceBulkBtn = el('refil2ForceBulkBtn');
            if (forceBulkBtn) {
              forceBulkBtn.addEventListener('click', async function(){
                var wrap = el('refil2RequestsWrap');
                if (!wrap) return;
                var rows = Array.prototype.slice.call(wrap.querySelectorAll('tbody tr'));
                var ids = [];
                var skippedForced = 0;
                rows.forEach(function(r){
                  try {
                    if (r.style.display === 'none') return;
                    var cb = r.querySelector('input.refil2SelectRow');
                    if (!cb || !cb.checked) return;
                    var id = String(r.getAttribute('data-refil2-id') || '').trim();
                    if (!id) return;
                    var oid = (r.querySelector('.refil2ForceOrderId') ? String(r.querySelector('.refil2ForceOrderId').textContent || '').trim() : '');
                    if (oid && oid !== '-') { skippedForced++; return; }
                    ids.push(id);
                  } catch (_) {}
                });
                if (!ids.length) {
                  alert(skippedForced ? 'Nenhuma linha elegível (as selecionadas já estão forçadas).' : 'Selecione pelo menos 1 linha.');
                  return;
                }
                if (!confirm('Forçar refil para ' + ids.length + ' item(ns)?' + (skippedForced ? (' (' + skippedForced + ' já estavam forçados)') : ''))) return;
                forceBulkBtn.disabled = true;
                forceBulkBtn.style.opacity = '0.7';
                try {
                  var resp = await fetch('/api/painel/refil2/force-refil-bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: ids })
                  });
                  var data = await readJsonResp(resp);
                  if (!resp.ok || !(data && data.ok)) {
                    var msg = (data && (data.message || data.error)) ? String(data.message || data.error) : ('HTTP ' + resp.status);
                    alert('Erro ao forçar em massa: ' + msg);
                    return;
                  }
                  var results = Array.isArray(data.results) ? data.results : [];
                  var map = {};
                  results.forEach(function(it){ if (it && it.id) map[String(it.id)] = it; });
                  var ok = 0;
                  var skipped = 0;
                  var failed = 0;
                  rows.forEach(function(r){
                    try {
                      var id = String(r.getAttribute('data-refil2-id') || '').trim();
                      if (!id) return;
                      var item = map[id];
                      if (!item) return;
                      if (item.ok) {
                        ok++;
                        try {
                          var oidEl = r.querySelector('.refil2ForceOrderId');
                          if (oidEl) oidEl.textContent = item.orderId ? String(item.orderId) : '-';
                        } catch (_) {}
                        try {
                          var atEl = r.querySelector('.refil2ForceAt');
                          if (atEl) atEl.textContent = (new Date()).toLocaleString('pt-BR');
                        } catch (_) {}
                        try {
                          var cEl = r.querySelector('.refil2ForceCharge');
                          if (cEl) cEl.textContent = (item.charge !== null && typeof item.charge !== 'undefined' && String(item.charge).trim() !== '') ? String(item.charge) : '-';
                        } catch (_) {}
                        try {
                          var btn = r.querySelector('button.refil2ForceRefilOne');
                          if (btn) {
                            btn.textContent = item.orderId ? ('Enviado (' + String(item.orderId) + ')') : 'Enviado';
                            btn.disabled = true;
                            btn.style.opacity = '0.7';
                          }
                        } catch (_) {}
                        try {
                          r.setAttribute('data-refil2-charged', '0');
                          var okEl = r.querySelector('.refil2ChargedOk');
                          if (okEl) okEl.textContent = '';
                        } catch (_) {}
                      } else if (item.skipped) {
                        skipped++;
                      } else if (item.error) {
                        failed++;
                      }
                    } catch (_) {}
                  });
                  if (skippedForced) skipped += skippedForced;
                  alert('Forçar em massa concluído: ' + ok + ' enviado(s)' + (skipped ? (' · ' + skipped + ' ignorado(s)') : '') + (failed ? (' · ' + failed + ' erro(s)') : '') + '.');
                } catch (e) {
                  alert('Erro ao forçar em massa: ' + (e && e.message ? e.message : e));
                } finally {
                  try { forceBulkBtn.disabled = false; forceBulkBtn.style.opacity = '1'; } catch (_) {}
                }
              });
            }
          } catch (_) {}
          var refil2AuditSaveTimers = {};
          async function saveRowAudit(row) {
            try {
              if (!row) return;
              var id = String(row.getAttribute('data-refil2-id') || '').trim();
              if (!id) return;
              var curEl = row.querySelector('input.refil2AuditCurrent');
              var resEl = row.querySelector('input.refil2AuditResult');
              var curRaw = curEl ? String(curEl.value || '').trim() : '';
              var cur = null;
              if (curRaw !== '') {
                var n = Number(curRaw);
                if (isFinite(n)) cur = Math.trunc(n);
              }
              var result = resEl ? String(resEl.value || '').trim() : '';
              var resp = await fetch('/api/painel/refil2/audit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: [{ id: id, currentFollowers: cur, result: result }] })
              });
              await readJsonResp(resp);
            } catch (_) {}
          }
          document.addEventListener('input', function(ev){
            try {
              var t = ev && ev.target ? ev.target : null;
              if (!t) return;
              if (!t.classList || !t.classList.contains('refil2AuditResult')) return;
              var row = (t.closest && t.closest('tr')) ? t.closest('tr') : null;
              if (!row) return;
              var id = String(row.getAttribute('data-refil2-id') || '').trim();
              if (!id) return;
              if (refil2AuditSaveTimers[id]) { try { clearTimeout(refil2AuditSaveTimers[id]); } catch (_) {} }
              refil2AuditSaveTimers[id] = setTimeout(function(){
                try { saveRowAudit(row); } catch (_) {}
              }, 700);
            } catch (_) {}
          }, true);
          document.addEventListener('click', async function(ev){
            try {
              var t = ev && ev.target ? ev.target : null;
              if (!t) return;
              var forceBtn = (t.closest && t.closest('.refil2ForceRefilOne')) ? t.closest('.refil2ForceRefilOne') : null;
              if (forceBtn) {
                ev.preventDefault();
                var rowF = (forceBtn.closest && forceBtn.closest('tr')) ? forceBtn.closest('tr') : null;
                if (!rowF) return;
                var idF = String(rowF.getAttribute('data-refil2-id') || '').trim();
                if (!idF) return;
                var forceOk = false;
                var qtyToSend = null;
                try {
                  var auditEl = rowF.querySelector('input.refil2AuditCurrent');
                  var auditRaw = auditEl ? String(auditEl.value || '').trim() : '';
                  var auditN = auditRaw === '' ? NaN : Number(auditRaw);
                  if (!isFinite(auditN) || auditN <= 0) {
                    alert('Faça a verificação do audit atual antes de forçar refil.');
                    return;
                  }
                } catch (_) {
                  alert('Faça a verificação do audit atual antes de forçar refil.');
                  return;
                }
                var msg = 'Forçar refil agora?';
                try {
                  var userTd = rowF.querySelector('td:nth-child(5)');
                  var reporTd = rowF.querySelector('td:nth-child(8)');
                  var finalTd = rowF.querySelector('td:nth-child(9)');
                  var auditTd = rowF.querySelector('td:nth-child(10)');
                  var userTxt = userTd ? String(userTd.textContent || '').trim() : '';
                  var finalTxt2 = finalTd ? String(finalTd.textContent || '').trim() : '';
                  var auditTxt2 = (auditTd && auditTd.querySelector('input.refil2AuditCurrent')) ? String(auditTd.querySelector('input.refil2AuditCurrent').value || '').trim() : '';
                  var finalN2 = finalTxt2 ? Number(String(finalTxt2).replace(/[^\d-]/g, '')) : NaN;
                  var auditN2 = auditTxt2 ? Number(String(auditTxt2).replace(/[^\d-]/g, '')) : NaN;
                  if (isFinite(finalN2) && isFinite(auditN2)) {
                    qtyToSend = Math.max(0, Math.trunc(finalN2) - Math.trunc(auditN2));
                    try { if (reporTd) reporTd.textContent = String(qtyToSend); } catch (_) {}
                  }
                  var parts = [];
                  if (userTxt) parts.push('para ' + userTxt);
                  if (qtyToSend !== null && isFinite(qtyToSend)) parts.push('Enviar: ' + String(qtyToSend));
                  if (auditTxt2) parts.push('Audit: ' + auditTxt2);
                  if (finalTxt2) parts.push('Final: ' + finalTxt2);
                  msg = 'Forçar refil agora' + (parts.length ? (' (' + parts.join(' · ') + ')') : '') + '?';
                } catch (_) {}
                if (!confirm(msg)) return;
                forceBtn.disabled = true;
                forceBtn.style.opacity = '0.7';
                try {
                  var respF = await fetch('/api/painel/refil2/force-refil', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: idF })
                  });
                  var dataF = await readJsonResp(respF);
                  if (!respF.ok || !(dataF && dataF.ok)) {
                    var msgF = (dataF && (dataF.message || dataF.error)) ? String(dataF.message || dataF.error) : ('HTTP ' + respF.status);
                    alert('Erro ao forçar refil: ' + msgF);
                    return;
                  }
                  var oid = (dataF && (dataF.orderId || (dataF.data && (dataF.data.order || dataF.data.id)))) ? String(dataF.orderId || dataF.data.order || dataF.data.id) : '';
                  if (!oid) {
                    var st0 = (dataF && (dataF.message || dataF.error)) ? String(dataF.message || dataF.error) : 'Fornecedor não retornou Refil ID';
                    alert('Erro ao forçar refil: ' + st0);
                    return;
                  }
                  try {
                    var oidEl = rowF.querySelector('.refil2ForceOrderId');
                    if (oidEl) oidEl.textContent = oid ? oid : '-';
                  } catch (_) {}
                  try {
                    var atEl = rowF.querySelector('.refil2ForceAt');
                    if (atEl) atEl.textContent = (new Date()).toLocaleString('pt-BR');
                  } catch (_) {}
                  try {
                    var c = (dataF && dataF.charge !== null && typeof dataF.charge !== 'undefined') ? String(dataF.charge).trim() : '';
                    var cEl = rowF.querySelector('.refil2ForceCharge');
                    if (cEl) cEl.textContent = c ? c : '-';
                  } catch (_) {}
                  try {
                    rowF.setAttribute('data-refil2-charged', '0');
                    var okEl = rowF.querySelector('.refil2ChargedOk');
                    if (okEl) okEl.textContent = '';
                  } catch (_) {}
                  if (oid) {
                    forceBtn.textContent = 'Enviado (' + oid + ')';
                    forceBtn.title = 'Pedido Fama24h: ' + oid;
                  } else {
                    forceBtn.textContent = 'Enviado';
                  }
                  forceOk = true;
                } catch (e) {
                  alert('Erro ao forçar refil: ' + (e && e.message ? e.message : e));
                } finally {
                  try {
                    if (!forceOk) { forceBtn.disabled = false; forceBtn.style.opacity = '1'; }
                  } catch (_) {}
                }
                return;
              }
              var oneBtn = (t.closest && t.closest('.refil2AuditVerifyOne')) ? t.closest('.refil2AuditVerifyOne') : null;
              if (oneBtn) {
                ev.preventDefault();
                var row = (oneBtn.closest && oneBtn.closest('tr')) ? oneBtn.closest('tr') : null;
                if (!row) return;
                var id = String(row.getAttribute('data-refil2-id') || '').trim();
                if (!id) return;
                oneBtn.disabled = true;
                oneBtn.style.opacity = '0.7';
                try {
                  var resp = await fetch('/api/painel/refil2/audit-verify-current', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: [id] })
                  });
                  var data = await readJsonResp(resp);
                  var results = Array.isArray(data && data.results) ? data.results : [];
                  var item = results && results.length ? results[0] : null;
                  if (!resp.ok || !(data && data.ok) || !(item && typeof item.currentFollowers === 'number')) {
                    var msg = (data && (data.message || data.error)) ? String(data.message || data.error) : ('HTTP ' + resp.status);
                    alert('Erro ao verificar audit atual: ' + msg);
                    return;
                  }
                  var curEl = row.querySelector('input.refil2AuditCurrent');
                  if (curEl) curEl.value = String(Math.trunc(item.currentFollowers));
                  try {
                    var resEl = row.querySelector('input.refil2AuditResult');
                    if (resEl && item.auditResult) resEl.value = String(item.auditResult);
                  } catch (_) {}
                  try {
                    var tdFinal = row.querySelector('td:nth-child(9)');
                    var tdRepor = row.querySelector('td:nth-child(8)');
                    var finalTxt = tdFinal ? String(tdFinal.textContent || '').trim() : '';
                    var finalN = finalTxt ? Number(String(finalTxt).replace(/[^\d-]/g, '')) : NaN;
                    if (isFinite(finalN) && tdRepor) {
                      var needed = Math.max(0, Math.trunc(finalN) - Math.trunc(item.currentFollowers));
                      tdRepor.textContent = needed ? String(needed) : '0';
                    }
                  } catch (_) {}
                } finally {
                  try { oneBtn.disabled = false; oneBtn.style.opacity = '1'; } catch (_) {}
                }
                return;
              }
              var a = (t.closest && t.closest('.refil2-sort')) ? t.closest('.refil2-sort') : null;
              if (!a) return;
              ev.preventDefault();
              var next = (state.dir === 'asc') ? 'desc' : 'asc';
              state.dir = next;
              sortRows(next === 'asc' ? 1 : -1);
              var icon = el('refil2SortIconDays');
              if (icon) icon.textContent = (next === 'asc') ? '▲' : '▼';
            } catch (_) {}
          });
          try {
            var icon = el('refil2SortIconDays');
            if (icon) icon.textContent = '';
          } catch (_) {}
        })();
      </script>
    <% } %>

    <% if (isLtvView) { %>
      <div style="margin-top: 12px; border:1px solid #e5e7eb; border-radius: 10px; padding: 14px; background: #fff;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap: wrap;">
          <strong style="font-size: 1rem; color:#111827;">LTV</strong>
          <div style="font-size:0.85rem; color:#6b7280;">Base: pedidos pagos (geral)</div>
