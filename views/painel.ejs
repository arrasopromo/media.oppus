          async function pollVerifyFilteredStatus(){
            try {
              var resp = await fetch('/api/painel/gerenciamento-seguidores/verify-filtered/status', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' });
              var data = await resp.json().catch(function(){ return null; });
              var job = data && data.ok ? data.job : null;
              verifyFilteredLastJob = job || verifyFilteredLastJob;
              if (!job) return;
              var done = Number(job.done || 0);
              var total = Number(job.total || 0);
              var ok = Number(job.ok || 0);
              var failed = Number(job.failed || 0);
              var lastU = job.lastUsername ? ('@' + String(job.lastUsername)) : '';
              setStatus('Verificando (backend) ' + String(done) + '/' + String(total) + ' | ok=' + String(ok) + ' falhas=' + String(failed) + ' ' + lastU);
              if (job.status === 'running') {
                if (!verifyFilteredPollTimer) {
                  verifyFilteredPollTimer = setInterval(function(){ pollVerifyFilteredStatus().catch(function(){}); }, 1500);
                }
              } else {
                if (verifyFilteredPollTimer) { clearInterval(verifyFilteredPollTimer); verifyFilteredPollTimer = null; }
                try { if (verifyFilteredBtn) verifyFilteredBtn.disabled = false; } catch (_) {}
                try { if (verifySelectedBtn) verifySelectedBtn.disabled = false; } catch (_) {}
                if (job.status === 'done') {
                  setStatus('Verificação concluída.');
                  window.location.reload();
                } else {
                  setStatus('Verificação terminou com erro.');
                }
              }
            } catch (_) {}
