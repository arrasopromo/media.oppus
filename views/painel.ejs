        <script type="application/json" id="ltvCustomersData"><%- JSON.stringify(Array.isArray(customerRows) ? customerRows : []) %></script>
        <script>
          (function(){
            function readJson(id, fallback) {
              try {
                var el = document.getElementById(id);
                if (!el) return fallback;
                var raw = String(el.textContent || '').trim();
                if (!raw) return fallback;
                return JSON.parse(raw);
              } catch (_) {
                return fallback;
              }
            }
            function fmtMoney(n) {
              var x = Number(n || 0);
              if (!isFinite(x)) x = 0;
              return 'R$ ' + x.toFixed(2).replace('.', ',');
            }
            function safeStr(v) { return String(v == null ? '' : v); }
            var all = readJson('ltvCustomersData', []);
            var modal = document.getElementById('ltvCustomersModal');
            var titleEl = document.getElementById('ltvCustomersModalTitle');
            var closeBtn = document.getElementById('ltvCustomersModalClose');
            var tbody = document.getElementById('ltvCustomersTbody');
            var searchEl = document.getElementById('ltvCustomersSearch');
            var countEl = document.getElementById('ltvCustomersCount');
            var cardAll = document.getElementById('ltvCardAllCustomers');
            var cardRepeat = document.getElementById('ltvCardRepeatCustomers');
            if (!modal || !tbody) return;

            var mode = 'all';

            function open(newMode) {
              mode = newMode || 'all';
              if (titleEl) titleEl.textContent = mode === 'repeat' ? 'Clientes recorrentes (2+)' : 'Clientes únicos';
              if (searchEl) searchEl.value = '';
              modal.style.display = 'flex';
              render();
              if (searchEl) searchEl.focus();
            }
            function close() {
              modal.style.display = 'none';
            }
            function matchesFilter(row, q) {
              if (!q) return true;
              var s = (safeStr(row.username) + ' ' + safeStr(row.phone) + ' ' + safeStr(row.email) + ' ' + safeStr(row.label)).toLowerCase();
              return s.indexOf(q) >= 0;
            }
            function render() {
              var q = searchEl ? String(searchEl.value || '').trim().toLowerCase() : '';
              var rows = Array.isArray(all) ? all.slice() : [];
              if (mode === 'repeat') rows = rows.filter(function(r){ return Number(r && r.orders ? r.orders : 0) > 1; });
              rows = rows.filter(function(r){ return matchesFilter(r, q); });

              if (countEl) countEl.textContent = rows.length + ' clientes';
              tbody.innerHTML = '';
              if (!rows.length) {
                var tr0 = document.createElement('tr');
                var td0 = document.createElement('td');
                td0.colSpan = 5;
                td0.style.padding = '10px 6px';
                td0.style.color = '#6b7280';
                td0.textContent = 'Sem dados';
                tr0.appendChild(td0);
                tbody.appendChild(tr0);
                return;
              }

              for (var i = 0; i < rows.length; i++) {
                var r = rows[i] || {};
                var tr = document.createElement('tr');
                var userTd = document.createElement('td');
                userTd.style.padding = '8px 6px';
                userTd.style.borderBottom = '1px solid #f3f4f6';
                userTd.textContent = safeStr(r.username || r.label || '-');

                var phoneTd = document.createElement('td');
                phoneTd.style.padding = '8px 6px';
                phoneTd.style.borderBottom = '1px solid #f3f4f6';
                phoneTd.textContent = safeStr(r.phone || '-');

                var emailTd = document.createElement('td');
                emailTd.style.padding = '8px 6px';
                emailTd.style.borderBottom = '1px solid #f3f4f6';
                emailTd.textContent = safeStr(r.email || '-');

                var ordersTd = document.createElement('td');
                ordersTd.style.padding = '8px 6px';
                ordersTd.style.borderBottom = '1px solid #f3f4f6';
                ordersTd.style.textAlign = 'right';
                ordersTd.textContent = String(Number(r.orders || 0));

                var spendTd = document.createElement('td');
                spendTd.style.padding = '8px 6px';
                spendTd.style.borderBottom = '1px solid #f3f4f6';
                spendTd.style.textAlign = 'right';
                spendTd.textContent = fmtMoney(r.spend || 0);

                tr.appendChild(userTd);
                tr.appendChild(phoneTd);
                tr.appendChild(emailTd);
                tr.appendChild(ordersTd);
                tr.appendChild(spendTd);
                tbody.appendChild(tr);
              }
            }

            if (cardAll) cardAll.addEventListener('click', function(){ open('all'); });
            if (cardRepeat) cardRepeat.addEventListener('click', function(){ open('repeat'); });
            if (closeBtn) closeBtn.addEventListener('click', close);
            if (searchEl) searchEl.addEventListener('input', render);
            modal.addEventListener('click', function(e){
              if (e && e.target === modal) close();
            });
            document.addEventListener('keydown', function(e){
              if (modal.style.display !== 'none' && e && e.key === 'Escape') close();
            });
          })();
        </script>
      </div>
    <% } %>

