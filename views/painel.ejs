          function parseRangeInput(raw, max){
            try {
              var s = String(raw || '').trim();
              if (!s) return null;
              var m = max || 0;
              if (/^\d+$/.test(s)) {
                var n = parseInt(s, 10);
                if (!isFinite(n) || n <= 0) return null;
                var end = Math.min(m || n, n);
                return { startIndex: 0, endExclusive: end };
              }
              var parts = s.split('-').map(function(x){ return String(x || '').trim(); }).filter(Boolean);
              if (parts.length !== 2) return null;
              var a = parseInt(parts[0], 10);
              var b = parseInt(parts[1], 10);
              if (!isFinite(a) || !isFinite(b) || a <= 0 || b <= 0) return null;
              var start = Math.min(a, b);
              var end2 = Math.max(a, b);
              var startIndex = Math.max(0, start - 1);
              var endExclusive = Math.min(m || end2, end2);
              if (endExclusive <= startIndex) return null;
              return { startIndex, endExclusive };
            } catch (_) {
              return null;
            }
          }
