                  <a href="#" class="refil2-sort" data-sort="days" style="color:inherit; text-decoration:none;">Dias<span id="refil2SortIconDays" style="margin-left:6px; color:#6b7280;"></span></a>
                </th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Perfil</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Tipo</th>
                <th style="text-align:right; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Atual</th>
                <th style="text-align:right; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Repor</th>
                <th style="text-align:right; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Final <span style="color:#6b7280;">(rec.)</span></th>
                <th style="text-align:right; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Audit Atual</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Audit Resultado</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Status</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Mensagem</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Ações</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Forçado em</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Refil ID</th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Custo</th>
                <th style="text-align:center; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Cobrado OK</th>
              </tr>
            </thead>
            <tbody>
              <% 
                const r2 = Array.isArray(refil2Requests) ? refil2Requests : [];
                const fmtDate = (v) => {
                  try {
                    const d = (v instanceof Date) ? v : new Date(v || 0);
                    if (!Number.isFinite(d.getTime())) return '-';
                    try { return d.toLocaleString('pt-BR'); } catch (_) {}
                    const y = d.getFullYear();
                    const m = String(d.getMonth() + 1).padStart(2, '0');
                    const day = String(d.getDate()).padStart(2, '0');
                    const hh = String(d.getHours()).padStart(2, '0');
                    const mm = String(d.getMinutes()).padStart(2, '0');
                    const ss = String(d.getSeconds()).padStart(2, '0');
                    return `${day}/${m}/${y} ${hh}:${mm}:${ss}`;
                  } catch (_) { return '-'; }
                };
                const resolveStatus = (it) => {
                  const exec = String(it && (it.execStatus || it.exec || '') || '').toLowerCase().trim();
                  const decision = String(it && (it.decisionStatus || it.decision || it.status || '') || '').toLowerCase().trim();
                  const reason = String(it && (it.decisionReason || it.reason || '') || '').toLowerCase().trim();
                  const err = String(it && (it.errorMessage || it.error || it.webhookMessage || it.statusMessage || '') || '').trim();
                  const minDrop = (it && it.computed && typeof it.computed.min_drop === 'number') ? it.computed.min_drop : 100;
                  if (reason === 'add_reorder_ok') return { kind: 'success', label: 'Iniciado', cls: 'refil2-badge--green', msg: 'add_reorder_ok' };
                  if (reason === 'below_min_drop') return { kind: 'info', label: 'Sem queda', cls: 'refil2-badge--gray', msg: `Abaixo de ${minDrop}` };
                  if (reason === 'paid_today') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Pago hoje' };
                  if (reason === 'no_orders') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Sem pedidos' };
                  if (reason === 'no_followers_purchase') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Sem compra de seguidores' };
                  if (reason === 'reorder_expired') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: 'Prazo expirado' };
                  if (exec === 'success' && (decision === 'initiated' || decision === 'no_drop')) {
                    return { kind: (decision === 'no_drop' ? 'info' : 'success'), label: (decision === 'no_drop' ? 'Sem queda' : 'Iniciado'), cls: (decision === 'no_drop' ? 'refil2-badge--gray' : 'refil2-badge--green'), msg: reason || 'OK' };
                  }
                  if (exec === 'error' || decision === 'error') return { kind: 'error', label: 'Erro', cls: 'refil2-badge--red', msg: err || reason || '-' };
                  if (exec === 'success' && decision === 'blocked') return { kind: 'blocked', label: 'Bloqueado', cls: 'refil2-badge--yellow', msg: reason || err || '-' };
                  return { kind: 'error', label: 'Erro', cls: 'refil2-badge--red', msg: err || reason || '-' };
                };
              %>
              <% if (r2.length) { %>
                <% r2.forEach(it => { 
                  const rid = String(it && it._id ? it._id : '').trim();
                  const when = fmtDate(it && (it.requestedAt || it.createdAt) ? (it.requestedAt || it.createdAt) : '');
                  const purchase = String(it && (it.purchaseAtLabel || it.purchaseAt) ? (it.purchaseAtLabel || fmtDate(it.purchaseAt)) : '-');
                  const reqRaw = it && (it.requestedAt || it.createdAt) ? (it.requestedAt || it.createdAt) : null;
                  const reqMs = reqRaw ? new Date(reqRaw).getTime() : 0;
                  const purRaw = it && it.purchaseAt ? it.purchaseAt : null;
                  const purMs = purRaw ? new Date(purRaw).getTime() : 0;
                  const dayDiff = (() => {
                    try {
                      if (!Number.isFinite(reqMs) || !reqMs) return null;
                      if (!Number.isFinite(purMs) || !purMs) return null;
                      const days = Math.floor((reqMs - purMs) / (24 * 60 * 60 * 1000));
                      if (!Number.isFinite(days)) return null;
                      return days;
                    } catch (_) { return null; }
                  })();
                  const user = String(it && it.username ? it.username : '-').trim();
                  const userSlug = String(user || '').trim().replace(/^@+/, '');
                  const userHref = (userSlug && userSlug !== '-') ? (`https://www.instagram.com/${encodeURIComponent(userSlug)}/`) : '';
                  const postCode = String(it && (it.latestPostShortcode || it.latestPostCode) ? (it.latestPostShortcode || it.latestPostCode) : '').trim();
                  const postHref = postCode ? (`https://www.instagram.com/p/${encodeURIComponent(postCode)}/`) : '';
                  const tipoLabel = String(it && (it.lastFollowersTipoLabel || it.lastFollowersTipo) ? (it.lastFollowersTipoLabel || it.lastFollowersTipo) : '-').trim() || '-';
                  const sum = (it && (it.summary || it.computed || it.data) && typeof (it.summary || it.computed || it.data) === 'object') ? (it.summary || it.computed || it.data) : {};
                  const initialQty = (typeof sum.initial === 'number') ? sum.initial : (typeof sum.quantidade_inicial === 'number' ? sum.quantidade_inicial : null);
                  const sourcesArr = Array.isArray(sum.followersSources) ? sum.followersSources : (Array.isArray(sum.followers_sources) ? sum.followers_sources : []);
                  const minPositiveFromSources = (function(){
                    try {
                      if (!sourcesArr || !sourcesArr.length) return null;
                      let best = null;
                      for (const s0 of sourcesArr) {
                        const n = Number(s0 && (s0.followers ?? s0.followerCount ?? s0.followersCount));
                        if (!Number.isFinite(n)) continue;
                        const v = Math.trunc(n);
                        if (v <= 0) continue;
                        if (best == null || v < best) best = v;
                      }
                      return best;
                    } catch (_) { return null; }
                  })();
                  const baseCurrentQty = (typeof sum.current === 'number') ? sum.current : (typeof sum.quantidade_atual === 'number' ? sum.quantidade_atual : null);
                  const currentQty = (baseCurrentQty != null && baseCurrentQty > 0) ? baseCurrentQty : (minPositiveFromSources != null ? minPositiveFromSources : baseCurrentQty);
                  const dropQty = (typeof sum.drop === 'number') ? sum.drop : (typeof sum.deficit === 'number' ? sum.deficit : (typeof sum.quantidade_de_queda === 'number' ? sum.quantidade_de_queda : null));
                  const computedFinalQty = (currentQty != null && dropQty != null) ? (Number(currentQty) + Number(dropQty)) : null;
                  const rawFinalQty = (typeof sum.final === 'number') ? sum.final : (typeof sum.quantidade_final === 'number' ? sum.quantidade_final : null);
                  const finalQty = (computedFinalQty != null) ? computedFinalQty : (rawFinalQty != null ? rawFinalQty : (initialQty != null ? initialQty : null));
                  const finalMismatch = (computedFinalQty != null && rawFinalQty != null) ? (Math.trunc(Number(computedFinalQty)) !== Math.trunc(Number(rawFinalQty))) : false;
                  const st = resolveStatus(it);
                  const auditObj = (it && it.audit && typeof it.audit === 'object') ? it.audit : {};
                  const auditCurrent = (typeof auditObj.currentFollowers === 'number') ? auditObj.currentFollowers : null;
                  const auditResult = (typeof auditObj.result === 'string') ? auditObj.result : '';
                  const auditKey = (function(){
                    try {
                      const raw = String(auditResult || '').trim().toLowerCase();
                      if (!raw) return '';
                      const k = raw.replace(/[^a-z]/g, '');
                      if (k === 'ok' || k.indexOf('ok') === 0) return 'ok';
                      if (k === 'nok' || k.indexOf('nok') === 0) return 'nok';
                      return 'other';
                    } catch (_) { return ''; }
                  })();
                  const forceObj = (it && it.forceRefil && typeof it.forceRefil === 'object') ? it.forceRefil : {};
                  const forceOrderId = (forceObj && (forceObj.orderId !== null && typeof forceObj.orderId !== 'undefined')) ? String(forceObj.orderId).trim() : '';
                  const forceChargeRaw = (forceObj && (forceObj.charge !== null && typeof forceObj.charge !== 'undefined')) ? forceObj.charge : null;
                  const forceCharge = (forceChargeRaw === null || typeof forceChargeRaw === 'undefined') ? '' : String(forceChargeRaw).trim();
                  const forceAt = (forceOrderId && forceObj && (forceObj.forcedAt || forceObj.finishedAt || forceObj.requestedAt)) ? fmtDate(forceObj.forcedAt || forceObj.finishedAt || forceObj.requestedAt) : '-';
                  const forceStatus = String(forceObj && forceObj.status ? forceObj.status : '').toLowerCase().trim();
                  const hasForced = !!forceOrderId || forceStatus === 'processing' || forceStatus === 'created';
                  const forceCharged = !!(forceObj && (forceObj.charged === true || forceObj.chargedAt));
                  const isProxyOrLookupError = (function(){
                    try {
                      if (!st || st.kind !== 'error') return false;
                      const m = String(st.msg || '').toLowerCase();
                      return (m.includes('instagram_proxy') || m.includes('proxy') || m.includes('rocket') || m.includes('timeout') || m.includes('consultar seguidores') || m.includes('followers') || m.includes('profile_lookup_failed'));
                    } catch (_) { return false; }
                  })();
                %>
                  <tr data-refil2-id="<%= rid %>" data-refil2-days="<%= (dayDiff !== null ? String(dayDiff) : '') %>" data-refil2-whenms="<%= (Number.isFinite(reqMs) ? String(reqMs) : '') %>" data-refil2-kind="<%= String(st.kind || '') %>" data-refil2-charged="<%= forceCharged ? '1' : '0' %>" data-refil2-audit="<%= String(auditKey || '') %>" data-refil2-hasrefilid="<%= (forceOrderId ? '1' : '0') %>" data-refil2-auto="<%= (it && it.automated === true) ? '1' : '0' %>">
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; text-align:center;">
                      <input type="checkbox" class="refil2SelectRow" <%= rid ? '' : 'disabled' %> />
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= when %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= purchase %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (dayDiff !== null ? String(dayDiff) : '-') %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;">
                      <% if (userHref) { %>
                        <a href="<%= userHref %>" target="_blank" rel="noopener" style="color:#111827; text-decoration:underline;"><%= ('@' + userSlug) %></a>
                      <% } else { %>
                        <%= user ? ('@' + user.replace(/^@+/, '')) : '-' %>
                      <% } %>
                      <% if (it && it.automated === true) { %>
                        <span title="Solicitado automaticamente" style="margin-left:8px; display:inline-block; padding:2px 6px; border:1px solid #e5e7eb; border-radius:999px; font-size:0.72rem; line-height:1.2; color:#111827; background:#f3f4f6; font-weight:700;">AUTO</span>
                      <% } %>
                      <% if (isProxyOrLookupError && postHref) { %>
                        <a href="<%= postHref %>" target="_blank" rel="noopener" title="Abrir último post conhecido (ver usuário atual)" style="margin-left:8px; display:inline-block; padding:2px 6px; border:1px solid #e5e7eb; border-radius:999px; font-size:0.72rem; line-height:1.2; color:#111827; text-decoration:none; background:#fff;">POST</a>
                      <% } %>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= tipoLabel %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (currentQty != null ? String(currentQty) : '-') %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;"><%= (dropQty != null ? String(dropQty) : '-') %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827; text-align:right;">
                      <%= (finalQty != null ? String(finalQty) : (initialQty != null ? String(initialQty) : '-')) %>
                      <% if (finalMismatch) { %>
                        <span title="Final informado diferente do cálculo (atual+repor): <%= String(rawFinalQty) %>" style="margin-left:6px; color:#6b7280; font-weight:700;">*</span>
                      <% } %>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; text-align:right;">
                      <div style="display:flex; align-items:center; justify-content:flex-end; gap:8px;">
                        <input type="number" class="refil2AuditCurrent" value="<%= (auditCurrent != null ? String(auditCurrent) : '') %>" placeholder="-" style="width:92px; padding:6px 2px; border:0; border-radius:0; text-align:right; outline:none; background:transparent;" />
                        <button type="button" class="refil2AuditVerifyOne" style="padding:5px 8px; border:1px solid #e5e7eb; background:#fff; color:#111827; border-radius:8px; cursor:pointer; font-size:0.85rem;">Verificar</button>
                      </div>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6;">
                      <input type="text" class="refil2AuditResult" value="<%= String(auditResult || '') %>" placeholder="" style="width:90px; max-width: 90px; padding:6px 8px; border:1px solid #e5e7eb; border-radius:8px; text-transform: uppercase;" />
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6;"><span class="refil2-badge <%= st.cls %>"><%= st.label %></span></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#374151;"><%= st.msg %></td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6;">
                      <button type="button" class="refil2ForceRefilOne" style="padding:5px 8px; border:1px solid #e5e7eb; background:#111827; color:#fff; border-radius:8px; cursor:pointer; font-size:0.85rem;">Forçar refil</button>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; color:#111827;">
                      <span class="refil2ForceAt"><%= forceAt %></span>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; font-family: monospace; color:#111827;">
                      <span class="refil2ForceOrderId"><%= forceOrderId || '-' %></span>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; font-family: monospace; color:#111827;">
                      <span class="refil2ForceCharge"><%= forceCharge || '-' %></span>
                    </td>
                    <td style="padding:6px 4px; border-bottom:1px solid #f3f4f6; text-align:center;">
                      <span class="refil2ChargedOk" style="font-weight:800; color:#16a34a;"><%= forceCharged ? 'OK' : '' %></span>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="18" style="padding:10px 6px; color:#6b7280; text-align:center;">Sem solicitações ainda</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <div id="refil2ChargeModal" style="display:none; position:fixed; inset:0; background: rgba(0,0,0,0.45); z-index: 9999; align-items:center; justify-content:center; padding: 18px;">
        <div style="width: 100%; max-width: 920px; background:#fff; border-radius: 12px; box-shadow: 0 18px 60px rgba(0,0,0,0.25); overflow:hidden;">
          <div style="padding: 12px 14px; border-bottom: 1px solid #e5e7eb; display:flex; align-items:center; justify-content:space-between; gap: 10px;">
            <div style="font-weight: 900; color:#111827;">Cobrança (copiar)</div>
            <button type="button" id="refil2ChargeClose" style="padding:6px 10px; border:1px solid #e5e7eb; background:#fff; border-radius:8px; cursor:pointer;">Fechar</button>
          </div>
          <div style="padding: 12px 14px;">
            <div id="refil2ChargeMeta" style="font-size:0.9rem; color:#6b7280; margin-bottom: 10px;"></div>
            <pre id="refil2ChargeText" style="white-space: pre-wrap; word-break: break-word; border:1px solid #e5e7eb; background:#f9fafb; padding: 12px; border-radius: 10px; max-height: 420px; overflow:auto; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace; font-size: 0.9rem;"></pre>
            <div style="display:flex; gap:10px; justify-content:flex-end; margin-top: 12px;">
              <button type="button" id="refil2ChargeCopy" style="padding:8px 12px; border:1px solid #e5e7eb; background:#111827; color:#fff; border-radius:10px; cursor:pointer;">Copiar e marcar OK</button>
            </div>
          </div>
        </div>
      </div>
      <script>
        (function(){
          function el(id){ return document.getElementById(id); }
          try {
            var topScroll = el('refil2ScrollTop');
            var topInner = el('refil2ScrollTopInner');
            var bottomScroll = el('refil2ScrollBottom');
            var table = bottomScroll ? bottomScroll.querySelector('table') : null;
            var syncing = false;
            function syncTopWidth(){
              try {
                if (!topInner || !table) return;
                topInner.style.width = String(table.scrollWidth || 0) + 'px';
              } catch (_) {}
            }
            if (topScroll && bottomScroll) {
              topScroll.addEventListener('scroll', function(){
                try {
                  if (syncing) return;
                  syncing = true;
                  bottomScroll.scrollLeft = topScroll.scrollLeft;
                } catch (_) {} finally { syncing = false; }
              });
              bottomScroll.addEventListener('scroll', function(){
                try {
                  if (syncing) return;
                  syncing = true;
                  topScroll.scrollLeft = bottomScroll.scrollLeft;
                } catch (_) {} finally { syncing = false; }
              });
            }
            syncTopWidth();
            window.addEventListener('resize', function(){ syncTopWidth(); });
            setTimeout(syncTopWidth, 50);
          } catch (_) {}
          function readJsonResp(resp){
            try { return resp && typeof resp.json === 'function' ? resp.json() : Promise.resolve(null); } catch (_) { return Promise.resolve(null); }
          }
          function sortRows(dir){
            try {
              var wrap = el('refil2RequestsWrap');
              if (!wrap) return;
              var tbody = wrap.querySelector('tbody');
              if (!tbody) return;
              var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
              if (!rows.length) return;
              rows.sort(function(a, b){
                var da = String(a.getAttribute('data-refil2-days') || '').trim();
                var db = String(b.getAttribute('data-refil2-days') || '').trim();
                var na = da === '' ? null : Number(da);
                var nb = db === '' ? null : Number(db);
                var aOk = (na !== null && isFinite(na));
                var bOk = (nb !== null && isFinite(nb));
                if (!aOk && !bOk) return 0;
                if (!aOk) return 1;
                if (!bOk) return -1;
                return (na - nb) * dir;
              });
              rows.forEach(function(r){ tbody.appendChild(r); });
            } catch (_) {}
          }
          var sortDir = 'desc';
          function parsePtBrDateTime(s){
            try {
              var t = String(s || '').trim();
              if (!t || t === '-') return null;
              var m = t.match(/(\d{2})\/(\d{2})\/(\d{4})(?:,\s*|\s+)?(\d{2}):(\d{2})(?::(\d{2}))?/);
              if (!m) {
                var m2 = t.match(/(\d{2})\/(\d{2})\/(\d{4})/);
                if (!m2) return null;
                var dd2 = Number(m2[1]), mm2 = Number(m2[2]), yy2 = Number(m2[3]);
                var d2 = new Date(yy2, mm2 - 1, dd2, 0, 0, 0, 0);
                return Number.isFinite(d2.getTime()) ? d2.getTime() : null;
              }
              var dd = Number(m[1]), mm = Number(m[2]), yy = Number(m[3]);
              var hh = Number(m[4] || '0'), mi = Number(m[5] || '0'), ss = Number(m[6] || '0');
              var d = new Date(yy, mm - 1, dd, hh, mi, ss, 0);
              return Number.isFinite(d.getTime()) ? d.getTime() : null;
            } catch (_) { return null; }
          }
          function parseDateInputStart(v){
            try {
              var s = String(v || '').trim();
              if (!s) return null;
              var d = new Date(s + 'T00:00:00');
              return Number.isFinite(d.getTime()) ? d.getTime() : null;
            } catch (_) { return null; }
          }
          function parseDateInputEnd(v){
            try {
              var s = String(v || '').trim();
              if (!s) return null;
              var d = new Date(s + 'T23:59:59');
              return Number.isFinite(d.getTime()) ? d.getTime() : null;
            } catch (_) { return null; }
          }
          function applyFilters(){
            try {
              var sel = el('refil2StatusFilter');
              var autoSel = el('refil2AutoFilter');
              var userSearchEl = el('refil2UserSearch');
              var dateCol = el('refil2DateColumn');
              var auditSel = el('refil2AuditFilter');
              var dateFromEl = el('refil2DateFrom');
              var dateToEl = el('refil2DateTo');
              var wrap = el('refil2RequestsWrap');
              if (!wrap) return;
              var tbody = wrap.querySelector('#refil2ScrollBottom tbody');
              if (!tbody) return;
              var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
              var shown = 0;
              rows.forEach(function(r){
                var id = String(r.getAttribute('data-refil2-id') || '').trim();
                if (!id) return;
                shown += 1;
                try { r.setAttribute('data-refil2-match', '1'); } catch (_) {}
                try { r.style.display = ''; } catch (_) {}
              });
              try {
                var fc = el('refil2FilteredCount');
                if (fc) fc.textContent = String(shown);
              } catch (_) {}
            } catch (_) {}
          }

          try {
            try {
              var qs = new URLSearchParams(String((window && window.location && window.location.search) || '').replace(/^\?/, ''));
              var s0 = el('refil2StatusFilter');
              if (s0) {
                var v0 = String(qs.get('refil2Status') || 'all');
                if (v0) s0.value = v0;
              }
              var a0 = el('refil2AutoFilter');
              if (a0) {
                var v1 = String(qs.get('refil2Auto') || 'all');
                if (v1) a0.value = v1;
              }
              var us0 = el('refil2UserSearch');
              if (us0) us0.value = String(qs.get('refil2User') || '');
              var d0 = el('refil2DateColumn');
              if (d0) {
                var v2 = String(qs.get('refil2DateColumn') || 'requested');
                if (v2) d0.value = v2;
              }
              var df0 = el('refil2DateFrom');
              if (df0) df0.value = String(qs.get('refil2DateFrom') || '');
              var dt0 = el('refil2DateTo');
              if (dt0) dt0.value = String(qs.get('refil2DateTo') || '');
              var au0 = el('refil2AuditFilter');
              if (au0) {
                var v3 = String(qs.get('refil2Audit') || 'all');
                if (v3) au0.value = v3;
              }
              var onlyWithEl0 = el('refil2OnlyWithRefilId');
              if (onlyWithEl0) {
                var ridMode = String(qs.get('refil2RefilId') || '').toLowerCase().trim();
                var legacyChecked = String(qs.get('refil2OnlyWithRefilId') || '') === '1';
                onlyWithEl0.checked = (legacyChecked || ridMode === 'with');
              }
            } catch (_) {}
            applyFilters();
            var applyBtn = el('refil2ApplyFiltersBtn');
            if (applyBtn) applyBtn.addEventListener('click', function(){
              try {
                var qs = new URLSearchParams(String((window && window.location && window.location.search) || '').replace(/^\?/, ''));
                qs.set('view', 'refil2');
                qs.set('refil2Page', '1');
                var s = el('refil2StatusFilter');
                var a = el('refil2AutoFilter');
                var us = el('refil2UserSearch');
                var dcol = el('refil2DateColumn');
                var au = el('refil2AuditFilter');
                var onlyWithEl = el('refil2OnlyWithRefilId');
                var df = el('refil2DateFrom');
                var dt = el('refil2DateTo');
                var sv = s ? String(s.value || 'all') : 'all';
                var av = a ? String(a.value || 'all') : 'all';
                var uv = us ? String(us.value || '').trim() : '';
                var dv = dcol ? String(dcol.value || 'requested') : 'requested';
                var auv = au ? String(au.value || 'all') : 'all';
                var onlyWith = !!(onlyWithEl && onlyWithEl.checked);
                var dfv = df ? String(df.value || '') : '';
                var dtv = dt ? String(dt.value || '') : '';
                if (sv && sv !== 'all') qs.set('refil2Status', sv); else qs.delete('refil2Status');
                if (av && av !== 'all') qs.set('refil2Auto', av); else qs.delete('refil2Auto');
                if (uv) qs.set('refil2User', uv); else qs.delete('refil2User');
                if (dv && dv !== 'requested') qs.set('refil2DateColumn', dv); else qs.delete('refil2DateColumn');
                if (auv && auv !== 'all') qs.set('refil2Audit', auv); else qs.delete('refil2Audit');
                qs.delete('refil2RefilId');
                if (onlyWith) qs.set('refil2OnlyWithRefilId', '1'); else qs.delete('refil2OnlyWithRefilId');
                if (dfv) qs.set('refil2DateFrom', dfv); else qs.delete('refil2DateFrom');
                if (dtv) qs.set('refil2DateTo', dtv); else qs.delete('refil2DateTo');
                window.location.search = '?' + qs.toString();
              } catch (_) {}
            });
            var clearBtn = el('refil2ClearFiltersBtn');
            if (clearBtn) clearBtn.addEventListener('click', function(){
              try {
                var sel2 = el('refil2StatusFilter');
                if (sel2) sel2.value = 'all';
                var a2 = el('refil2AutoFilter');
                if (a2) a2.value = 'all';
                var us2 = el('refil2UserSearch');
                if (us2) us2.value = '';
                var dcol2 = el('refil2DateColumn');
                if (dcol2) dcol2.value = 'requested';
                var au2 = el('refil2AuditFilter');
                if (au2) au2.value = 'all';
                var onlyWithEl2 = el('refil2OnlyWithRefilId');
                if (onlyWithEl2) onlyWithEl2.checked = false;
                var df2 = el('refil2DateFrom');
                if (df2) df2.value = '';
                var dt2 = el('refil2DateTo');
                if (dt2) dt2.value = '';
                try {
                  var selAll2 = el('refil2SelectAll');
                  if (selAll2) selAll2.checked = false;
                } catch (_) {}
                try {
                  var qs = new URLSearchParams(String((window && window.location && window.location.search) || '').replace(/^\?/, ''));
                  qs.set('view', 'refil2');
                  qs.set('refil2Page', '1');
                  qs.delete('refil2Status');
                  qs.delete('refil2Auto');
                  qs.delete('refil2User');
                  qs.delete('refil2DateColumn');
                  qs.delete('refil2DateFrom');
                  qs.delete('refil2DateTo');
                  qs.delete('refil2Audit');
                  qs.delete('refil2OnlyWithRefilId');
                  qs.delete('refil2RefilId');
                  window.location.search = '?' + qs.toString();
                } catch (_) {
                  applyFilters();
                }
              } catch (_) {}
            });
          } catch (_) {}

          try {
            var reportBtn = el('refil2ReportBtn');
            var reportModal = el('refil2ReportModal');
            var reportCloseBtn = el('refil2ReportCloseBtn');
            var totalEl = el('refil2ReportTotal');
            var okEl = el('refil2ReportOk');
            var nokEl = el('refil2ReportNok');
            var nokWithIdEl = el('refil2ReportNokWithId');
            var nokNoIdEl = el('refil2ReportNokNoId');
            var pieOkNokEl = el('refil2ReportPieOkNok');
            var pieNokIdEl = el('refil2ReportPieNokId');
            var barsEl = el('refil2ReportBars');
            var pieOkNokChart = null;
            var pieNokIdChart = null;
            var barsChart = null;
            function destroyCharts(){
              try { if (pieOkNokChart) { pieOkNokChart.destroy(); pieOkNokChart = null; } } catch (_) {}
              try { if (pieNokIdChart) { pieNokIdChart.destroy(); pieNokIdChart = null; } } catch (_) {}
              try { if (barsChart) { barsChart.destroy(); barsChart = null; } } catch (_) {}
            }
            function setTotals(t){
              try {
                const x = (t && typeof t === 'object') ? t : {};
                const render = (v) => {
                  if (typeof v === 'string') return v;
                  const n = Number(v);
                  return Number.isFinite(n) ? String(n) : '0';
                };
                if (totalEl) totalEl.textContent = render(x.auditedTotal);
                if (okEl) okEl.textContent = render(x.okCount);
                if (nokEl) nokEl.textContent = render(x.nokCount);
                if (nokWithIdEl) nokWithIdEl.textContent = render(x.nokWithId);
                if (nokNoIdEl) nokNoIdEl.textContent = render(x.nokNoId);
              } catch (_) {}
            }
            function goToRefil2AuditFilter(bucket){
              try {
                var qs = new URLSearchParams(String((window && window.location && window.location.search) || '').replace(/^\?/, ''));
                qs.set('view', 'refil2');
                qs.set('refil2Page', '1');
                qs.delete('refil2OnlyWithRefilId');
                if (bucket === 'ok') {
                  qs.set('refil2Audit', 'ok');
                  qs.delete('refil2RefilId');
                } else if (bucket === 'nok') {
                  qs.set('refil2Audit', 'nok');
                  qs.delete('refil2RefilId');
                } else if (bucket === 'nok_with_id') {
                  qs.set('refil2Audit', 'nok');
                  qs.set('refil2RefilId', 'with');
                } else if (bucket === 'nok_no_id') {
                  qs.set('refil2Audit', 'nok');
                  qs.set('refil2RefilId', 'without');
                }
                closeRefil2Report();
                setTimeout(function(){
                  try { window.location.search = '?' + qs.toString(); } catch (_) {}
                }, 0);
              } catch (_) {}
            }
            async function ensureChartJsLoaded(){
              try {
                if (typeof Chart === 'function') return true;
                return await new Promise(function(resolve){
                  try {
                    var existing = document.querySelector('script[data-chartjs="1"]');
                    if (existing) {
                      var t = 0;
                      var timer = setInterval(function(){
                        t += 1;
                        if (typeof Chart === 'function') { clearInterval(timer); resolve(true); }
                        if (t > 50) { clearInterval(timer); resolve(false); }
                      }, 100);
                      return;
                    }
                    var s = document.createElement('script');
                    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js';
                    s.async = true;
                    s.setAttribute('data-chartjs', '1');
                    s.onload = function(){ resolve(typeof Chart === 'function'); };
                    s.onerror = function(){ resolve(false); };
                    document.head.appendChild(s);
                  } catch (_) { resolve(false); }
                });
              } catch (_) { return false; }
            }
            async function fetchJson(url, timeoutMs){
              const controller = new AbortController();
              const t = setTimeout(() => controller.abort(), Number(timeoutMs || 15000));
              try {
                const resp = await fetch(url, { method: 'GET', headers: { 'Accept': 'application/json' }, signal: controller.signal });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) {
                  const msg = (data && data.message) ? data.message : (`HTTP ${resp.status}`);
                  throw new Error(msg);
                }
                return data;
              } finally {
                clearTimeout(t);
              }
            }
            function buildReportUrl(extra){
              const qs = new URLSearchParams(String((window && window.location && window.location.search) || '').replace(/^\?/, ''));
              qs.delete('refil2Page');
              if (extra && typeof extra === 'object') {
                Object.keys(extra).forEach((k) => {
                  const v = extra[k];
                  if (v == null || v === '') qs.delete(k);
                  else qs.set(k, String(v));
                });
              }
              const s = qs.toString();
              return '/api/painel/refil2/audit-report' + (s ? ('?' + s) : '');
            }
            function renderCharts(totals){
              try { destroyCharts(); } catch (_) {}
              const okCount = Number(totals && totals.okCount || 0) || 0;
              const nokCount = Number(totals && totals.nokCount || 0) || 0;
              const nokWithId = Number(totals && totals.nokWithId || 0) || 0;
              const nokNoId = Number(totals && totals.nokNoId || 0) || 0;
              try {
                if (typeof Chart !== 'function') return;
                if (pieOkNokEl) {
                  pieOkNokChart = new Chart(pieOkNokEl.getContext('2d'), {
                    type: 'pie',
                    data: { labels: ['OK', 'NOK'], datasets: [{ data: [okCount, nokCount], backgroundColor: ['#16a34a', '#dc2626'] }] },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, onClick: function(_, els){ try { if (!els || !els.length) return; const idx = els[0].index; goToRefil2AuditFilter(idx === 0 ? 'ok' : 'nok'); } catch (_) {} } }
                  });
                }
                if (pieNokIdEl) {
                  pieNokIdChart = new Chart(pieNokIdEl.getContext('2d'), {
                    type: 'pie',
                    data: { labels: ['NOK c/ Refil ID', 'NOK s/ Refil ID'], datasets: [{ data: [nokWithId, nokNoId], backgroundColor: ['#111827', '#f59e0b'] }] },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, onClick: function(_, els){ try { if (!els || !els.length) return; const idx = els[0].index; goToRefil2AuditFilter(idx === 0 ? 'nok_with_id' : 'nok_no_id'); } catch (_) {} } }
                  });
                }
                if (barsEl) {
