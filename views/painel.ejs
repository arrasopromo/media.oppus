          </div>
          <script>
            (function(){
              function safeTrim(v){ return String(v == null ? '' : v).trim(); }
              function bind(){
                var btns = Array.prototype.slice.call(document.querySelectorAll('.sale-delete-btn'));
                if (!btns.length) return;
                btns.forEach(function(btn){
                  if (btn.getAttribute('data-bound') === '1') return;
                  btn.setAttribute('data-bound', '1');
                  btn.addEventListener('click', async function(){
                    var id = safeTrim(btn.getAttribute('data-sale-id') || '');
                    if (!id) return;
                    if (!confirm('Excluir esta venda? Isso apaga o registro no MongoDB.')) return;
                    btn.disabled = true;
                    try {
                      var resp = await fetch('/api/painel/vendas/delete', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        body: JSON.stringify({ id: id }),
                        credentials: 'same-origin'
                      });
                      var data = await resp.json().catch(function(){ return null; });
                      if (!data || data.ok !== true) {
                        var err = (data && (data.message || data.error)) ? (data.message || data.error) : ('HTTP ' + resp.status);
                        alert('Erro ao excluir: ' + err);
                        btn.disabled = false;
                        return;
                      }
                      try {
                        var tr = btn.closest ? btn.closest('tr') : null;
                        if (tr && tr.parentNode) tr.parentNode.removeChild(tr);
                      } catch(_) {}
                    } catch (e) {
                      alert('Erro ao excluir: ' + (e && e.message ? e.message : String(e)));
                      btn.disabled = false;
                    }
                  });
                });
              }
              if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
              else bind();
            })();
          </script>
        <% } else { %>
          <% if (view === 'dashboard') { %>
