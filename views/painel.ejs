        <div class="panel-table-scroll" id="refil2ScrollBottom" style="margin-top: 6px;">
          <table style="width:100%; border-collapse: collapse; font-size: 0.92rem; min-width: 2080px;">
            <thead>
              <tr>
                <th style="text-align:center; padding:6px 4px; border-bottom:1px solid #e5e7eb; width:44px;">
                  <input id="refil2SelectAll" type="checkbox" />
                </th>
                <th style="text-align:left; padding:6px 4px; border-bottom:1px solid #e5e7eb;">Data/Hora</th>
