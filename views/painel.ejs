              var labels = Array.isArray(data.labels) ? data.labels : [];
              var fmt = function(k){
                try {
                  var parts = String(k || '').split('-');
                  if (parts.length !== 3) return String(k || '');
                  return parts[2] + '/' + parts[1];
                } catch (_) { return String(k || ''); }
              };
              var labelShort = labels.map(fmt);
              var avgCtx = document.getElementById('avgTicketTimelineChart');
              if (avgCtx) {
                new Chart(avgCtx, {
                  type: 'line',
                  data: {
                    labels: labelShort,
                    datasets: [{
                      label: 'Ticket médio (R$)',
                      data: Array.isArray(data.dailyAvgTicket) ? data.dailyAvgTicket : [],
                      borderColor: '#2563eb',
                      backgroundColor: 'rgba(37, 99, 235, 0.15)',
                      tension: 0.3,
                      fill: true,
                      pointRadius: 2
                    }]
