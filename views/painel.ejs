          <div class="panel-table-scroll" style="margin-top:10px;">
            <table style="width:100%; border-collapse: collapse; font-size: 0.92rem; min-width: 820px;">
              <thead>
                <tr>
                  <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Tipo</th>
                  <th style="text-align:right; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Clientes (tipo)</th>
                  <th style="text-align:right; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Clientes recorrentes</th>
                  <th style="text-align:right; padding:8px 6px; border-bottom:1px solid #e5e7eb;">LTV (%)</th>
