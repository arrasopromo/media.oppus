              <div id="ltvCustomersModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:1000; align-items:center; justify-content:center; padding: 14px;">
                <div style="background:#fff; width:min(980px, 96vw); max-height: 90vh; border-radius: 10px; overflow:hidden; box-shadow:0 8px 24px rgba(0,0,0,0.15);">
                  <div style="display:flex; align-items:center; justify-content:space-between; padding: 12px 14px; border-bottom:1px solid #e5e7eb; gap: 10px;">
                    <strong id="ltvCustomersModalTitle" style="color:#111827;">Clientes</strong>
                    <button type="button" id="ltvCustomersModalClose" style="padding:6px 10px; border:1px solid #e5e7eb; background:#fff; border-radius:8px; cursor:pointer;">Fechar</button>
                  </div>
                  <div style="padding: 12px 14px; overflow:auto; max-height: calc(90vh - 52px);">
                    <div style="display:flex; gap: 10px; flex-wrap: wrap; align-items:center; margin-bottom: 10px;">
                      <input id="ltvCustomersSearch" type="text" placeholder="Buscar por usuário/telefone/email" style="flex:1 1 280px; padding: 8px 10px; border:1px solid #e5e7eb; border-radius: 8px;" />
                      <div id="ltvCustomersCount" style="font-size:0.9rem; color:#6b7280;"></div>
                    </div>
                    <div class="panel-table-scroll">
                      <table style="width:100%; border-collapse: collapse; font-size: 0.92rem;">
                        <thead>
                          <tr>
                            <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Usuário</th>
                            <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Telefone</th>
                            <th style="text-align:left; padding:8px 6px; border-bottom:1px solid #e5e7eb;">Email</th>
