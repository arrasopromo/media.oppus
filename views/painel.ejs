              </thead>
              <tbody>
                <% (Array.isArray(ltvByType) ? ltvByType : []).forEach(function(it){ %>
                  <tr>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; color:#111827;"><%= String(it && (it.label || it.type) ? (it.label || it.type) : '-') %></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; text-align:right; color:#111827;"><%= Number(it && it.totalCustomers ? it.totalCustomers : 0) %></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; text-align:right; color:#111827;"><%= Number(it && it.repeatCustomers ? it.repeatCustomers : 0) %></td>
                    <td style="padding:8px 6px; border-bottom:1px solid #f3f4f6; text-align:right; color:#111827;"><%= Number(it && it.pctRepeatCustomers ? it.pctRepeatCustomers : 0).toFixed(1).replace('.', ',') %>%</td>
                  </tr>
                <% }) %>
                <% if (!(Array.isArray(ltvByType) && ltvByType.length)) { %>
                  <tr><td colspan="4" style="padding:10px 6px; color:#6b7280;">Sem dados</td></tr>
