                      <div class="pm-body" style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px; min-height:64px;">
                        <div class="pm-icon" style="display:flex;align-items:center;justify-content:center;">
                          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
                        </div>
                        <div class="pm-title" style="font-weight:600; color:#111827; font-size:0.92rem; line-height:1;">Cartão de Crédito</div>
                      </div>
                    </label>
                </div>
                <style>
                  @media (max-width: 640px) {
                    #paymentMethodSelector { gap: 0.6rem !important; }
                    #paymentMethodSelector .payment-option { max-width: none !important; }
                  }
                  @media (min-width: 641px) {
                    #paymentMethodSelector .payment-option { max-width: 240px !important; }
                  }
                </style>

                <div id="cardPaymentContent" style="display:none; margin-bottom:1.5rem;">
                    <form id="cardPaymentForm" onsubmit="event.preventDefault();">
                        <div class="form-group" style="margin-bottom:1rem;">
                            <label for="cardNumber" style="display:block; font-weight:600; margin-bottom:0.25rem; color:#374151;">Número do Cartão</label>
                            <div style="position:relative;">
                                <input type="text" id="cardNumber" class="select-input" placeholder="0000 0000 0000 0000" maxlength="19" required style="height:44px; border:1px solid #d1d5db; border-radius:10px; padding:0 44px 0 14px; font-size:1rem; outline:none;">
                                <div style="position:absolute; right:12px; top:50%; transform:translateY(-50%); pointer-events:none;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
                                </div>
                            </div>
                        </div>

                        <div style="display:flex; gap:1rem; margin-bottom:1rem;">
                            <div style="flex:1;">
                                <label for="cardExpiry" style="display:block; font-weight:600; margin-bottom:0.25rem; color:#374151;">Validade</label>
                                <input type="text" id="cardExpiry" class="select-input" placeholder="MM/AA" maxlength="5" required style="height:44px; border:1px solid #d1d5db; border-radius:10px; padding:0 14px; font-size:1rem; outline:none;">
                            </div>
                            <div style="flex:1;">
                                <label for="cardCvv" style="display:block; font-weight:600; margin-bottom:0.25rem; color:#374151;">CVV</label>
                                <input type="text" id="cardCvv" class="select-input" placeholder="123" maxlength="4" required style="height:44px; border:1px solid #d1d5db; border-radius:10px; padding:0 14px; font-size:1rem; outline:none;">
                            </div>
                        </div>

                        <div class="form-group" style="margin-bottom:1rem;">
                            <label for="cardInstallments" style="display:block; font-weight:600; margin-bottom:0.25rem;">Parcelas</label>
                            <select id="cardInstallments" class="select-input" style="width:100%;">
                                <option value="1">1x</option>
                            </select>
                        </div>

                        <div class="form-group" style="margin-bottom:1rem;">
                            <label for="cardHolderName" style="display:block; font-weight:600; margin-bottom:0.25rem; color:#374151;">Nome no Cartão</label>
                            <input type="text" id="cardHolderName" class="select-input" placeholder="Nome impresso no cartão" required style="height:44px; border:1px solid #d1d5db; border-radius:10px; padding:0 14px; font-size:1rem; outline:none;">
                        </div>

                        <div class="form-group" style="margin-bottom:1rem;">
                            <label for="cardHolderCpf" style="display:block; font-weight:600; margin-bottom:0.25rem; color:#374151;">CPF do Titular</label>
                            <input type="text" id="cardHolderCpf" class="select-input" placeholder="000.000.000-00" maxlength="14" required style="height:44px; border:1px solid #d1d5db; border-radius:10px; padding:0 14px; font-size:1rem; outline:none;">
                            <div style="margin-top:6px; font-size:0.85rem; color:#6b7280;">Obrigatório para transações nacionais (antifraude dos emissores).</div>
                        </div>

                        <div id="pagarmeBadgeCard" style="display:none; align-items:center; justify-content:center; gap:10px; margin-top:8px; margin-bottom:10px; color:#6b7280; font-size:0.85rem; text-align:center;">
                          <img src="/images/logo-pagarme.png" alt="Pagar.me" style="height:18px; width:auto; display:inline-block;"/>
                          <span>Pagamento processado pela Pagar.me</span>
                        </div>
                        <button id="payWithCardBtn" type="submit" class="continue-button" style="margin-top:0.5rem; display:flex; align-items:center; justify-content:center; position:relative; padding-right:52px;">
                             <span class="button-text">Realizar pedido</span>
                             <svg class="button-icon" style="position:absolute; right:16px;" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>
                    </form>
                </div>

                <div class="button-container" id="pixPaymentBtnContainer" style="display:flex; flex-direction:column; align-items:center;">
                  <button id="realizarPedidoBtn" class="continue-button" style="width:100%; max-width:420px; display:flex; align-items:center; justify-content:center; position:relative; padding-right:52px;">
                    <span class="button-text">Realizar pedido</span>
                    <svg class="button-icon" style="position:absolute; right:16px;" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>

              <div id="pixResultado" class="card-desc" style="display:none; margin-top: 0.75rem;"></div>


            </div>
          </div>
        </div>
      </section>

      <div id="postSelectModal" class="modal-overlay" style="display:none;">
        <div class="modal-dialog">
          <div class="modal-header">
            <h3 id="postModalTitle" class="modal-title">Selecionar reels</h3>
            <button id="postModalClose" class="modal-close" type="button" aria-label="Fechar">✕</button>
          </div>
          <div class="modal-body">
            <div id="postModalGrid" class="post-grid"></div>
          </div>
          <div class="modal-footer">
            <button id="postModalClose2" class="continue-button" type="button">Fechar</button>
          </div>
        </div>
      </div>

      <div id="warranty60Modal" class="modal-overlay" style="display:none;">
        <div class="modal-dialog">
          <div class="modal-header">
            <h3 class="modal-title">Garantia estendida</h3>
            <button id="warranty60CloseBtn" class="modal-close" type="button" aria-label="Fechar">✕</button>
          </div>
          <div class="modal-body">
            <p style="margin-top:0.75rem; color: var(--text-secondary);">Apenas com 4 cliques e menos de 30 segundos basta a pessoa colocar o id do pedido de serviço dela no nosso sistema, e clicar no botão solicitar refil e ela recupera a quantidade de curtidas que teve queda.</p>
            <div id="warrantyGifSlot" style="display:flex; align-items:center; justify-content:center; min-height:160px; margin-top: 1rem;">
               <img src="/images/reposicao.jpeg" alt="Garantia de Reposição" style="max-width:100%; border-radius:8px;">
            </div>
          </div>
          <div class="modal-footer">
            <button id="warranty60CloseBtn2" class="continue-button" type="button">Fechar</button>
          </div>
        </div>
      </div>

      <div id="commentsExampleModal" class="modal-overlay" style="display:none; align-items:center; justify-content:center; z-index:9999;">
        <div class="modal-dialog" style="max-width:400px; width:90%; border-radius: 16px; padding: 1.5rem; position:relative; display:flex; flex-direction:column;">
          <div class="modal-header" style="border:none; padding-bottom:0;">
            <h3 class="modal-title" style="margin:0 auto;">Exemplo de Comentários</h3>
            <button id="commentsExampleCloseBtn" class="modal-close" type="button" aria-label="Fechar" style="position:absolute; right:1rem; top:1rem;">✕</button>
          </div>
          <div class="modal-body" style="text-align:center;">
            <div style="position:relative; aspect-ratio: 9 / 16; height: clamp(320px, 60vh, 560px); max-width: 100%; margin: 0.75rem auto 0; border-radius:12px; overflow:hidden; box-shadow: var(--shadow); background: #000;">
              <video id="commentsVideoPlayer" src="/images/comentarios.mp4" controls muted playsinline style="position:absolute; inset:0; width:100%; height:100%; object-fit: cover;"></video>
            </div>
            <p style="margin-top:0.75rem; color: var(--text-secondary);">Comentários de perfis brasileiros, alta qualidade, comentários positivos e sem queda.</p>
          </div>
          <div class="modal-footer">
            <button id="commentsExampleCloseBtn2" class="continue-button" type="button">Fechar</button>
          </div>
        </div>
      </div>

    </main>
    <footer class="footer">
      <div class="footer-bar">
        <a href="https://instagram.com/agencia.oppus" target="_blank" rel="noopener" class="footer-link instagram-link" aria-label="Instagram Agência OPPUS">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm0 2a3 3 0 00-3 3v10a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3H7zm5 3a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6zm5.5-3a1.5 1.5 0 110 3 1.5 1.5 0 010-3z"/></svg>
        </a>
        <span class="footer-center">&copy; 2025 Agência OPPUS. Todos os direitos reservados.</span>
        <a href="/termos" id="termsLink" class="footer-link">Termos de Uso</a>
      </div>
    </footer>
  </div>

   <script src="/js/main.js"></script>
   <script src="/js/why-us.js"></script>
   <script src="/js/servicos-instagram.js?v=<%= Date.now() %>"></script>
   <div id="toastContainer" class="toast-container"></div>



</body>
</html>
