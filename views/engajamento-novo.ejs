</head>
<body class="theme-light has-fixed-menu">
  <%- include('partials/menu', { logoLink: '/engajamento-novo' }) %>
  <script>
    // Server-side UTMs passed to client
    window.SERVER_UTMS_QUERY = '<%- serverQueryString %>';
    
    // Configuração inicial
    window.__ENG_MODE__ = false; // Modo checkout direto
  </script>

  <div class="container checkout-page">
    <header class="header">
      <div id="headerTicker" class="header-ticker" aria-live="polite">
        <span class="ticker-item enter">Empresa regularizada</span>
      </div>
      <h1 class="title">
        Cresça o seu perfil com<br>
        <span class="title-highlight-gradient">resultados reais e imediatos</span>
      </h1>
      <p class="subtitle" style="margin-top:0.25rem;">Transforme seu perfil com serviços de alta qualidade que geram autoridade de verdade.<br>Veja resultados em até 5 minutos.</p>
    </header>

    <main class="main-content">
      
      <!-- Seletor de Serviço (Contexto) -->
      <div class="service-context-selector">
        <button class="service-selector-btn active" data-service="followers" onclick="window.selectService && window.selectService('followers')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          Seguidores
        </button>
        <button class="service-selector-btn" data-service="likes" onclick="window.selectService && window.selectService('likes')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
          Curtidas
        </button>
        <button class="service-selector-btn" data-service="views" onclick="window.selectService && window.selectService('views')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          Visualizações
        </button>
      </div>

      <!-- Stepper removed as per request -->


      <section class="section-block">
        <!-- STEP 1: Seleção do Serviço -->
        <div id="step1Container">

          <!-- Audio Player -->
          <div class="service-card" id="audioCard" style="margin-bottom: 2rem;">
            <div class="card-content">
              <h3 class="card-title">Guia de áudio</h3>
              <div class="card-desc">
                  <div class="audio-player">
                  <audio id="guideAudio" class="audio-element" preload="none" src="/images/audio%20site.MP3"></audio>
                  <div class="audio-controls">
                    <div id="tutorialAudio" class="tutorial-pop tutorial-pop-input" data-tip-mode="manual" data-tip-top="50" data-tip-left="" data-tip-arrow-left="">
                      <div class="tutorial-pop-step">1/5</div>
                      <div class="tutorial-pop-text">Ouça o áudio primeiro</div>
                    </div>
                    <button type="button" id="audioPlayBtn" class="audio-speed-btn">Ouvir Áudio</button>
                    <input type="range" id="audioProgress" class="audio-progress" min="0" max="100" value="0" />
                  <span class="audio-time" style="white-space:nowrap;"><span id="audioCurrent">00:00</span>/<span id="audioDuration">00:00</span></span>
                  </div>
                  <div class="audio-speed-row">
                    <button type="button" id="audioSpeed15x" class="audio-speed-btn">1.5x</button>
                    <button type="button" id="audioSpeed2x" class="audio-speed-btn">2x</button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Botão Comprar Agora (Moved to top) -->
          <div class="service-card" style="background: transparent; border: none; box-shadow: none; padding: 0; margin-bottom: 2rem;">
            <div class="card-content" style="display:flex; justify-content:center; align-items:center; text-align:center;">
              <a href="#tipoCards" id="buyFollowersBtn" class="continue-button" style="display:inline-flex; justify-content:center; align-items:center; text-align:center; margin:0 auto; width: 100%; max-width: 450px;">
                <span class="button-text">COMPRAR SEGUIDORES AGORA</span>
              </a>
              <div class="value-props" style="margin-top: 1rem;">
                <div class="value-prop-item">
                  <div class="value-prop-row">
                    <img class="value-prop-icon" src="/images/ampulheta.png" alt="Anos de mercado" loading="lazy" width="119" height="119" />
                    <div class="value-prop-metric">+3</div>
                  </div>
                  <div class="value-prop-caption"><span class="caption-desktop">anos de operação</span><span class="caption-mobile">anos de<br>operação</span></div>
                </div>
                <div class="value-prop-item">
                  <div class="value-prop-row">
                    <img class="value-prop-icon" src="/images/foguete.png" alt="Seguidores entregues" loading="lazy" width="119" height="119" />
                    <div class="value-prop-metric">+2</div>
                  </div>
                  <div class="value-prop-caption"><span class="caption-desktop">milhões de seguidores entregues</span><span class="caption-mobile">milhões de<br>seguidores<br>entregues</span></div>
                </div>
                <div class="value-prop-item">
                  <div class="value-prop-row">
                    <img class="value-prop-icon" src="/images/moeda.png" alt="Melhores preços" loading="lazy" width="119" height="119" />
                    <div class="value-prop-metric">R$<span class="value-prop-arrow">↓</span></div>
                  </div>
                  <div class="value-prop-caption"><span class="caption-desktop">melhores preços do mercado</span><span class="caption-mobile">melhores<br>preços do<br>mercado</span></div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Testimonials Section (Image based) -->
          <div class="testimonials-section" id="depoimentosCard" style="display: flex; flex-direction: column; align-items: center; margin-bottom: 2rem;">
            <div class="why-us-pill">O que as pessoas estão falando?</div>
            <h2 class="why-us-title">Veja depoimentos de quem <span class="why-us-gradient-text">comprou conosco</span></h2>
            <p class="why-us-subtitle" style="margin-bottom: 1.5rem;">Junte-se a milhares de clientes satisfeitos que impulsionaram suas redes sociais.</p>
            <div id="testimonialsCarousel" class="testimonials-carousel">
              <button type="button" class="carousel-btn prev" aria-label="Anterior">‹</button>
              <div class="carousel-viewport">
              <div class="carousel-track">
                  <div class="carousel-item active" data-index="0"><img src="/images/depo1.png" alt="Depoimento 1" loading="lazy" width="505" height="897" /></div>
                  <div class="carousel-item" data-index="1"><img src="/images/depo2.jpg" alt="Depoimento 2" loading="lazy" width="577" height="769" /></div>
                  <div class="carousel-item" data-index="2"><img src="/images/depo3.png" alt="Depoimento 3" loading="lazy" width="433" height="769" /></div>
              </div>
              </div>
              <button type="button" class="carousel-btn next" aria-label="Próximo">›</button>
            </div>
          </div>

          <!-- Why Us (Moved here) -->
          <div class="why-choose-us-section" style="margin-bottom: 2rem;">
            <div class="why-us-pill">Por que escolher a Agência Oppus?</div>
            <h2 class="why-us-title">Sabemos o que está <span class="why-us-gradient-text">funcionando</span></h2>
            <p class="why-us-subtitle">Nossa metodologia comprovada entrega crescimento sustentável para sua presença digital</p>
            <div class="why-us-slider-container">
              <div class="why-us-track" id="whyUsTrack">
                <div class="why-us-card">
                  <div class="why-us-icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 16V12M12 8H12.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <h3>100% Seguro</h3>
                  <p>Sem riscos de banimento. Metodologia aprovada pelos algoritmos das plataformas.</p>
                </div>
                <div class="why-us-card">
                  <div class="why-us-icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M16 21V19C16 17.9391 15.5786 16.9217 14.8284 16.1716C14.0783 15.4214 13.0609 15 12 15C10.9391 15 9.92172 15.4214 9.17157 16.1716C8.42143 16.9217 8 17.9391 8 19V21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M4 7C4 9.20914 5.79086 11 8 11H16C18.2091 11 20 9.20914 20 7C20 4.79086 18.2091 3 16 3H8C5.79086 3 4 4.79086 4 7Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <h3>Seguidores Reais</h3>
                  <p>Trabalhamos com pacote de seguidores brasileiros reais e ativos</p>
                </div>
                <div class="why-us-card">
                  <div class="why-us-icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M18.5 11.5L12 5L5.5 11.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M12 12.5V19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <h3>Entrega Rápida</h3>
                  <p>Pacotes com resultados visiveis em até 5 minutos com crescimento de autoridade rápido</p>
                </div>
              </div>
              <div class="why-us-dots">
                <div class="why-us-dot active" data-index="0"></div>
                <div class="why-us-dot" data-index="1"></div>
                <div class="why-us-dot" data-index="2"></div>
              </div>
            </div>
          </div>

          <!-- Cards de Opções (Tipos) - Visível como Botões Verticais -->
          <div id="tipoCards" class="option-cards vertical-buttons" style="margin-bottom: 1.5rem; display: flex; gap: 0.75rem;"></div>
          
          <div class="service-card" id="tipoDescCard" style="display:none;">
            <div class="card-content">
              <h3 class="card-title" id="tipoDescTitle"></h3>
              <div class="card-desc" id="tipoDescContent"></div>
            </div>
          </div>

          <!-- Cards de Planos (Quantidade) - Select visível -->
          <div class="service-card" id="quantidadeSelectCard" style="display:none;">
            <div class="card-content">
              <h3 class="card-title">Escolha o pacote</h3>
              <div class="input-group" id="grupoQuantidade" style="position:relative;">
                <select id="quantidadeSelect" class="select-input" style="flex:1;">
                  <option value="">Selecione o tipo primeiro...</option>
                </select>
                <!-- Tutorial: 3/4 -->
                <div id="tutorial2Pacote" class="tutorial-pop tutorial-pop-input" style="display:none;">
                  <div class="tutorial-pop-step">3/4</div>
                  <div class="tutorial-pop-text">Selecionar o plano</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Select de Tipo Oculto (Substituído por Botões) -->
          <div class="service-card" id="tipoSelectCard" style="display:none;">
            <div class="card-content">
              <h3 class="card-title">Tipo de serviço</h3>
              <div class="input-group" id="grupoTipo" style="position:relative;">
                <select id="tipoSelect" class="select-input" style="flex:1;">
                  <option value="" selected>Selecione...</option>
                </select>
              </div>
            </div>
          </div>


        </div>

        <!-- STEP 2: Dados do Perfil -->
        <div id="step2Container" style="display:none;">
          <div class="service-card">
            <div class="card-content">
              <div style="text-align: center; margin-bottom: 1.5rem; position: relative; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
