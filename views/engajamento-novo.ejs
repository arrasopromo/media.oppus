      const track = document.querySelector('.carousel-track');
      const items = document.querySelectorAll('.carousel-item');
      const prevBtn = document.querySelector('.carousel-btn.prev');
      const nextBtn = document.querySelector('.carousel-btn.next');
      
      if (track && items.length > 0) {
        let currentIndex = 0;
        
        function updateCarousel() {
          // Assuming items are equal width and visible 1 at a time (or partial)
          // Simple transform based on index
          // Check if it's a simple fade or slide. Structure suggests slide (track).
          const itemWidth = items[0].offsetWidth;
          // Center the active item?
          // Let's just scroll to the item
          const scrollAmount = items[currentIndex].offsetLeft - (track.parentElement.offsetWidth - items[currentIndex].offsetWidth) / 2;
          
          track.parentElement.scrollTo({
            left: items[currentIndex].offsetLeft - (track.parentElement.offsetWidth - items[currentIndex].offsetWidth) / 2,
            behavior: 'smooth'
          });
          
          items.forEach((item, i) => {
             if (i === currentIndex) item.classList.add('active');
             else item.classList.remove('active');
          });
        }
        
        if (prevBtn) {
          prevBtn.addEventListener('click', () => {
            currentIndex = (currentIndex > 0) ? currentIndex - 1 : items.length - 1;
            updateCarousel();
          });
        }
        
        if (nextBtn) {
          nextBtn.addEventListener('click', () => {
            currentIndex = (currentIndex < items.length - 1) ? currentIndex + 1 : 0;
            updateCarousel();
          });
        }
        
        // Auto play for testimonials? User didn't ask, but good for UX.
        // setInterval(() => { if(nextBtn) nextBtn.click(); }, 5000);
      }
      
      // --- Why Us Slider (Mobile mostly) ---
      const whyUsTrack = document.getElementById('whyUsTrack');
      const whyUsDots = document.querySelectorAll('.why-us-dot');
      
      if (whyUsTrack && whyUsDots.length > 0) {
        // Scroll listener to update dots
        whyUsTrack.addEventListener('scroll', () => {
           const scrollLeft = whyUsTrack.scrollLeft;
           const cards = whyUsTrack.querySelectorAll('.why-us-card');
           let cardWidth = whyUsTrack.offsetWidth; // Fallback
           
           if (cards.length > 0) {
               // Get width + gap (approx 24px)
               cardWidth = cards[0].offsetWidth + 24; 
           }
           
           const index = Math.round(scrollLeft / cardWidth);
           
           whyUsDots.forEach((dot, i) => {
             if (i === index) dot.classList.add('active');
             else dot.classList.remove('active');
           });
        });
        
        // Dot click
        whyUsDots.forEach((dot, i) => {
           dot.addEventListener('click', () => {
             const cards = whyUsTrack.querySelectorAll('.why-us-card');
             if (cards[i]) {
                // Calculate position relative to track
                // If track is not positioned, offsetLeft is relative to parent.
                // We subtract track.offsetLeft to get position inside track.
                // However, simple approach for scroll-snap is usually enough.
                // Let's try to be precise.
                let targetLeft = cards[i].offsetLeft;
                if (whyUsTrack.offsetParent === cards[i].offsetParent) {
                    targetLeft -= whyUsTrack.offsetLeft;
                }
                
                whyUsTrack.scrollTo({
                  left: targetLeft,
                  behavior: 'smooth'
                });
             }
           });
        });
      }

      // --- FAQ Accordion ---
      const faqCards = document.querySelectorAll('.faq-card');
      faqCards.forEach(card => {
        card.addEventListener('click', () => {
          const questionBtn = card.querySelector('.faq-question');
          const answer = card.querySelector('.faq-answer');
          const toggle = card.querySelector('.faq-toggle');
          
          if (!questionBtn || !answer || !toggle) return;

          const isExpanded = questionBtn.getAttribute('aria-expanded') === 'true';
          
          questionBtn.setAttribute('aria-expanded', !isExpanded);
          answer.hidden = isExpanded;
          toggle.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
        });
      });
    });
  </script>
</body>
</html>
