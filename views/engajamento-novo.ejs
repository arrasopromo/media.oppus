  <meta charset="utf-8" />
  <title>Checkout - Engajamento</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <link href="/css/style.css?v=6" rel="stylesheet" />
  <link href="/css/badges.css" rel="stylesheet" />
  <link href="/css/perfil.css" rel="stylesheet" />
  <!-- Testimonials CSS -->
  <link href="/css/testimonials.css" rel="stylesheet" />
  <link href="/css/why-us.css?v=5" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  
  <style>
    /* Footer Fix */
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .checkout-page {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .main-content {
      flex: 1;
      width: 100%;
    }

    /* Estilos específicos para o seletor de contexto (Topo) */
    .service-context-selector {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 2rem;
      padding: 0 1rem;
      flex-wrap: wrap;
    }
    
    /* Base Button Style */
    .service-selector-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      background: #ffffff;
      border: 1px solid var(--border-color);
      border-radius: 999px; /* Pill shape */
      font-weight: 700;
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s ease;
      font-size: 0.95rem;
      box-shadow: var(--shadow-sm);
      white-space: nowrap;
    }
    
    .service-selector-btn:hover {
      border-color: var(--primary-purple);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    
    .service-selector-btn.active {
      background: var(--instagram-gradient);
      color: white;
      border: 1px solid transparent;
      box-shadow: 0 4px 12px rgba(220, 39, 67, 0.3);
    }

    .service-selector-btn svg {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    /* Specific Styles for Service Type Buttons (The ones to change) */
    .type-btn {
      background: #1e1e1e; /* Dark theme */
      color: #ffffff;
      border: 1px solid rgba(255,255,255,0.1);
      font-size: 0.8rem; /* Smaller font */
      padding: 0.5rem 1rem; /* Smaller padding */
      height: auto;
      min-width: 0;
    }

    .type-btn:hover {
        background: #333;
    }
    
    .type-btn.active {
        background: var(--instagram-gradient);
        border-color: transparent;
    }

    /* Custom Buy Button Style */
    .buy-btn-custom {
      background: var(--primary-purple) !important;
      font-size: 0.85rem !important;
      padding: 0.5rem 1.5rem !important;
      height: auto !important;
      min-height: 0 !important;
      border-radius: 999px !important;
      box-shadow: none !important;
      color: white !important;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
    }
    .buy-btn-custom:hover {
      background: var(--dark-purple) !important;
      transform: translateY(-2px);
    }

    /* Horizontal Layout for Type Buttons */
    #tipoCards {
      display: flex;
      flex-direction: row;
      gap: 0.75rem;
      overflow-x: auto;
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge */
      justify-content: center; /* Center them */
      flex-wrap: wrap; /* Wrap on small screens or scroll? User image showed row. Let's wrap for better usability unless specifically scroll. */
    }
    
    /* User asked for "smaller", "like I put on computer". Assuming horizontal pills. */
    /* If many options, wrap is safer than scroll for desktop. */

    /* Ferramenta Exclusiva Image Size */
    .exclusive-img-container {
        max-width: 320px;
        margin: 0 auto;
        transition: max-width 0.3s ease;
    }
    @media (min-width: 768px) {
      .exclusive-img-container {
        max-width: 500px !important; /* Slightly smaller on desktop */
      }
    }
    
    #ferramentaExclusivaSection img {
        transition: all 0.3s ease;
        width: 100%;
        height: auto;
    }

    /* Ajuste para mobile */
    @media (max-width: 640px) {
      .service-context-selector {
        gap: 0.5rem;
      }
      .service-selector-btn {
        padding: 0.6rem 1rem;
        font-size: 0.85rem;
      }
      #tipoCards {
        justify-content: flex-start; /* Align left on mobile for scrolling */
        flex-wrap: nowrap; /* Force scroll on mobile */
        padding-left: 1rem;
        padding-right: 1rem;
        margin-left: -1rem; /* Full width scroll */
        margin-right: -1rem;
      }
    }
  </style>

  <!-- TRACK COMBO -->
  <script>
    (function() {
      var script = document.createElement("script");
      script.type = "text/javascript";
      script.async = true;
      script.src = "https://track.agenciaoppus.site/tag/TC-FQZRKRMP.js";
      var firstScript = document.getElementsByTagName("script")[0];
      firstScript.parentNode.insertBefore(script, firstScript);
    })();
  </script>
