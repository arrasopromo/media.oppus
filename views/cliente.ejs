                  <div>
                    <div class="client-welcome-greeting">Bem-vindo de volta</div>
                    <div class="client-welcome-email"><%= esc(pageEmail) %></div>
                  </div>
                  <!-- Badge de Nível -->
                  <button id="clientLevelBadge" onclick="document.getElementById('levelModal').classList.add('active')" style="background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;gap:0;flex-shrink:0">
                    <%
                      var _lvl = pageClientLevel;
                      var _lvlColors = ['','#6b7280','#cd7f32','#9ca3af','#f59e0b','#e5e7eb','#60a5fa','#a855f7'];
                      var _lvlBgs    = ['','rgba(107,114,128,.1)','rgba(205,127,50,.12)','rgba(156,163,175,.12)','rgba(245,158,11,.12)','rgba(229,231,235,.12)','rgba(96,165,250,.12)','rgba(168,85,247,.15)'];
                      var _lvlBorder = ['','rgba(107,114,128,.3)','rgba(205,127,50,.4)','rgba(156,163,175,.4)','rgba(245,158,11,.4)','rgba(229,231,235,.5)','rgba(96,165,250,.4)','rgba(168,85,247,.45)'];
                    %>
                    <span style="display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:999px;background:<%= _lvlBgs[_lvl] %>;border:1.5px solid <%= _lvlBorder[_lvl] %>;color:<%= _lvlColors[_lvl] %>;font-size:12px;font-weight:800;font-family:var(--font-family);letter-spacing:.03em">
