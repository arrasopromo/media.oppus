                    <div class="client-coupon-price-block">
                      <span class="client-coupon-price-val" style="font-size:17px;color:#1c1917;" id="couponCodeDisplay"><%= esc(pageClientCoupon.code) %></span>
                      <span class="client-coupon-badge">-<%= esc(String(pageClientCoupon.pct || '')) %>% OFF</span>
                    </div>
                    <div class="client-coupon-btns">
                      <a class="client-coupon-link" href="/servicos-instagram?cupom=<%= encodeURIComponent(String(pageClientCoupon.code || '')) %>" id="clientCouponUseBtn">
                        <span>Usar cupom →</span>
                        <span class="client-coupon-link-timer" id="couponBtnTimer">Copiar código: <%= esc(pageClientCoupon.code) %></span>
                      </a>
                    </div>
                  </div>
