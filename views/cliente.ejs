            <div id="clientPager" style="display:none; margin-top:10px; justify-content:center; gap:8px; align-items:center; flex-wrap:wrap;">
              <button type="button" id="clientPrevPage" class="client-filter-btn" style="box-shadow:none;">Anterior</button>
              <div id="clientPageInfo" style="color: var(--text-secondary); font-weight:700; font-size:0.9rem;"></div>
