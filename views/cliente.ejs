                    </div>
                    <div style="margin-top:8px;display:flex;justify-content:center;">
                      <a class="continue-button client-details-btn" style="text-decoration:none;display:inline-flex;align-items:center;justify-content:center;" href="/pedido?t=<%= encodeURIComponent(o.identifier || '') %>&ref=<%= encodeURIComponent(o.correlationID || '') %>&from=cliente">
                        <span class="button-text">Ver detalhes</span>
                      </a>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </main>
  <script>try{ localStorage.removeItem('oppus_selected_oid'); }catch(_){}</script>
  <script src="/js/main.js"></script>
  <script>
    (function(){
      try {
        var theme = localStorage.getItem('oppus_theme') || 'dark';
        document.body.classList.toggle('theme-light', theme === 'light');
      } catch (_) {}
      var backBtn = document.getElementById('clientPageBackBtn');
      if (backBtn) backBtn.addEventListener('click', function(){ window.location.href = '/'; });
      function setMsg(el, text, ok){
        if (!el) return;
        el.textContent = String(text || '');
        el.className = 'status-message ' + (ok ? 'success' : 'error');
        el.style.display = 'block';
      }
      var logoutBtn = document.getElementById('clientLogoutBtn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async function(){
          try { await fetch('/cliente/logout', { method:'POST', headers:{'Content-Type':'application/json'}, body:'{}' }); } catch(_) {}
          window.location.href = '/cliente';
        });
      }

      var loginBtn = document.getElementById('clientLoginBtn');
      if (loginBtn) {
        var authStep = 'email'; // 'email' → verifica e-mail; depois 'login' ou 'setup'
        var emailEl = document.getElementById('clientEmailInput');
        var passEl = document.getElementById('clientPasswordInput');
        var newPwEl = document.getElementById('clientNewPwInput');
        var newPw2El = document.getElementById('clientNewPwInput2');
        var hintEl = document.getElementById('clientAuthHint');
        var msg = document.getElementById('clientAuthMsg');
        function setBtn(txt){ var s = loginBtn.querySelector('.button-text'); if(s) s.textContent = txt; else loginBtn.textContent = txt; }
        function showHint(t){ if(hintEl){ hintEl.style.display=''; hintEl.textContent=t; } }
        // Enter em qualquer campo aciona o botão
        [emailEl, passEl, newPwEl, newPw2El].forEach(function(el){
          if(el) el.addEventListener('keydown', function(ev){ if(ev.key === 'Enter'){ ev.preventDefault(); loginBtn.click(); } });
        });
        loginBtn.addEventListener('click', async function(){
          var email = emailEl ? String(emailEl.value || '').trim().toLowerCase() : '';
          try {
            // ETAPA 1: só e-mail → descobrir se tem conta
            if (authStep === 'email') {
              if (!email || email.indexOf('@') === -1) { setMsg(msg, 'Digite um e-mail válido.', false); return; }
              loginBtn.disabled = true; setBtn('Verificando...');
              var rc = await fetch('/api/cliente/first-access', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email: email }) });
              var dc = await rc.json().catch(function(){ return null; });
              loginBtn.disabled = false;
              if (dc && dc.ok && dc.action === 'has_password') {
                authStep = 'login';
                if (emailEl) emailEl.setAttribute('readonly','readonly');
                if (passEl) { passEl.style.display=''; passEl.focus(); }
                showHint('Bem-vindo de volta! Digite sua senha para entrar.');
                setBtn('Entrar');
                if (msg) msg.style.display='none';
                return;
              }
              if (dc && dc.ok && dc.action === 'setup') {
                authStep = 'setup';
                if (emailEl) emailEl.setAttribute('readonly','readonly');
                if (newPwEl) { newPwEl.style.display=''; newPwEl.focus(); }
                if (newPw2El) newPw2El.style.display='';
                showHint('Encontramos sua compra! Crie uma senha para acessar sua conta.');
                setBtn('Criar senha e entrar');
                if (msg) msg.style.display='none';
                return;
              }
              setMsg(msg, 'Não encontramos uma conta nem compra paga com esse e-mail.', false);
              setBtn('Continuar');
              return;
            }
            // ETAPA 2a: login com senha
            if (authStep === 'login') {
              loginBtn.disabled = true;
              var r = await fetch('/cliente/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email: email, password: passEl ? passEl.value : '' }) });
              var d = await r.json().catch(function(){ return null; });
              if (!d || d.ok !== true) { setMsg(msg, 'Senha incorreta.', false); loginBtn.disabled = false; return; }
              window.location.href = '/cliente';
              return;
            }
            // ETAPA 2b: criar senha
            if (authStep === 'setup') {
              var p1 = newPwEl ? String(newPwEl.value || '').trim() : '';
              var p2 = newPw2El ? String(newPw2El.value || '').trim() : '';
              if (p1.length < 8) { setMsg(msg, 'A senha deve ter pelo menos 8 caracteres.', false); return; }
              if (p1 !== p2) { setMsg(msg, 'As senhas não coincidem.', false); return; }
              loginBtn.disabled = true;
              var rs = await fetch('/cliente/setup-password', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email: email, password: p1 }) });
              var ds = await rs.json().catch(function(){ return null; });
              if (!ds || ds.ok !== true) { setMsg(msg, (ds && ds.message) ? ds.message : 'Erro ao criar senha.', false); loginBtn.disabled = false; return; }
              window.location.href = '/cliente';
              return;
            }
          } catch (e) {
            setMsg(msg, 'Erro ao conectar.', false);
            loginBtn.disabled = false;
          }
        });
      }

      var forgotStandaloneBtn = document.getElementById('clientForgotStandaloneBtn');
      if (forgotStandaloneBtn) {
        forgotStandaloneBtn.addEventListener('click', async function(){
          var emailEl = document.getElementById('clientForgotEmailStandaloneInput');
          var msg = document.getElementById('clientForgotMsg');
          var email = emailEl ? String(emailEl.value || '').trim() : '';
          try {
            forgotStandaloneBtn.disabled = true;
            await fetch('/cliente/forgot', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email: email }) });
            window.location.href = '/cliente/esqueci-senha?sent=1&email=' + encodeURIComponent(email);
          } catch (e) {
            setMsg(msg, 'Erro ao enviar.', false);
            forgotStandaloneBtn.disabled = false;
          }
        });
      }

      (function(){
        var resendBtn = document.getElementById('clientResendBtn');
        var hint = document.getElementById('clientResendHint');
        if (!resendBtn) return;
        var email = <%- JSON.stringify(pageEmail) %>;
        var remaining = 60;
        function update(){
          if (!hint) return;
          if (remaining > 0) {
            hint.textContent = 'Você poderá tentar novamente em ' + remaining + 's.';
          } else {
            hint.textContent = '';
          }
        }
        function tick(){
          remaining -= 1;
          if (remaining <= 0) {
            remaining = 0;
            try { resendBtn.disabled = false; } catch(_) {}
            try { resendBtn.style.opacity = '1'; } catch(_) {}
            update();
            return;
          }
          update();
          setTimeout(tick, 1000);
        }
        try { resendBtn.disabled = true; resendBtn.style.opacity = '0.7'; } catch(_) {}
        update();
        setTimeout(tick, 1000);
        resendBtn.addEventListener('click', async function(){
          try {
            resendBtn.disabled = true;
            resendBtn.style.opacity = '0.7';
            remaining = 60;
            update();
            setTimeout(tick, 1000);
            await fetch('/cliente/forgot', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email: String(email || '') }) });
          } catch(_) {}
        });
      })();

      var changeBtn = document.getElementById('clientChangePasswordBtn');
      if (changeBtn) {
        changeBtn.addEventListener('click', async function(){
          var cur = document.getElementById('clientCurrentPasswordInput');
          var n1 = document.getElementById('clientNewPasswordInput');
          var n2 = document.getElementById('clientNewPasswordInput2');
          var msg = document.getElementById('clientChangeMsg');
          var p1 = n1 ? String(n1.value || '') : '';
          var p2 = n2 ? String(n2.value || '') : '';
          if (p1.length < 8) return setMsg(msg, 'Nova senha muito curta.', false);
          if (p1 !== p2) return setMsg(msg, 'As senhas não conferem.', false);
          try {
            changeBtn.disabled = true;
            var r = await fetch('/cliente/change-password', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ currentPassword: cur ? cur.value : '', newPassword: p1 }) });
            var d = await r.json().catch(function(){ return null; });
            if (!d || d.ok !== true) {
              setMsg(msg, 'Não foi possível atualizar a senha.', false);
              changeBtn.disabled = false;
              return;
            }
            window.location.href = '/cliente';
          } catch (e) {
            setMsg(msg, 'Erro ao conectar.', false);
            changeBtn.disabled = false;
          }
        });
      }

      var resetBtn = document.getElementById('clientResetBtn');
      if (resetBtn) {
        resetBtn.addEventListener('click', async function(){
          var n1 = document.getElementById('clientResetPasswordInput');
          var n2 = document.getElementById('clientResetPasswordInput2');
          var msg = document.getElementById('clientResetMsg');
          var p1 = n1 ? String(n1.value || '') : '';
          var p2 = n2 ? String(n2.value || '') : '';
          if (p1.length < 8) return setMsg(msg, 'Nova senha muito curta.', false);
          if (p1 !== p2) return setMsg(msg, 'As senhas não conferem.', false);
          try {
            resetBtn.disabled = true;
            var r = await fetch('/cliente/reset', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email: <%- JSON.stringify(pageEmail) %>, token: <%- JSON.stringify(pageToken) %>, newPassword: p1 }) });
            var d = await r.json().catch(function(){ return null; });
            if (!d || d.ok !== true) {
              setMsg(msg, 'Link inválido ou expirado.', false);
              resetBtn.disabled = false;
              return;
            }
            window.location.href = '/cliente';
          } catch (e) {
            setMsg(msg, 'Erro ao conectar.', false);
            resetBtn.disabled = false;
          }
        });
      }

      (function(){
        var copyBtn = document.getElementById('clientCopyCouponBtn');
        if (!copyBtn) return;
        copyBtn.addEventListener('click', async function(){
          try {
            var el = document.getElementById('clientCouponCode');
            var code = el ? String(el.textContent || '').trim() : '';
            if (!code) return;
            var original = copyBtn.getAttribute('data-original-html');
            if (!original) {
              original = copyBtn.innerHTML;
              copyBtn.setAttribute('data-original-html', original);
            }
            if (navigator && navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(code);
            } else {
              var ta = document.createElement('textarea');
              ta.value = code;
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              ta.remove();
            }
            copyBtn.textContent = 'Copiado';
            setTimeout(function(){ try { copyBtn.innerHTML = original; } catch(_) {} }, 900);
          } catch (_) {}
        });
      })();

      (function(){
        var payBtns = Array.from(document.querySelectorAll('.client-filter-btn[data-filter]') || []);
        if (!payBtns.length) return;
        var cards = Array.from(document.querySelectorAll('.client-order-card') || []);
        var elTotal = document.getElementById('clientOrdersTotal');
        var elPaid = document.getElementById('clientOrdersPaid');
        var elPending = document.getElementById('clientOrdersPending');
        var elPendingCard = document.getElementById('clientOrdersPendingCard');
        var elShown = document.getElementById('clientOrdersShown');
        var elTotalInline = document.getElementById('clientOrdersTotalInline');
        var catWrap = document.getElementById('clientCatFilter');
        var pager = document.getElementById('clientPager');
        var prevBtn = document.getElementById('clientPrevPage');
        var nextBtn = document.getElementById('clientNextPage');
        var pageInfo = document.getElementById('clientPageInfo');

        var perPage = 20;
        var payFilter = 'all';
        var catFilter = 'all';
        var page = 1;
        var catBtns = [];

        function countFor(status){
          var k = String(status || 'all');
          if (k === 'all') return cards.length;
          var n = 0;
          cards.forEach(function(c){
            var st = String(c.getAttribute('data-pay-status') || 'pending');
            if (st === k) n += 1;
          });
          return n;
        }

        function setCounts(){
          var total = cards.length;
          var paid = countFor('paid');
          var pending = countFor('pending');
          if (elTotal) elTotal.textContent = String(total);
          if (elPaid) elPaid.textContent = String(paid);
          if (elPending) elPending.textContent = String(pending);
          if (elPendingCard) elPendingCard.style.display = pending > 0 ? '' : 'none';
          if (elTotalInline) elTotalInline.textContent = String(total);
        }

        function normalizeCat(raw){
          var s = String(raw || '').toLowerCase().trim().replace(/\s+/g, '_');
          if (!s) return '';
          if (s.indexOf('curt') !== -1 || s.indexOf('like') !== -1) return 'curtidas';
          if (s.indexOf('visual') !== -1 || s.indexOf('view') !== -1) return 'visualizacoes';
          if (s.indexOf('coment') !== -1) return 'comentarios';
          if (s.indexOf('segu') !== -1) return 'seguidores';
          return s;
        }
        function catLabel(k){
          if (k === 'seguidores') return 'Seguidores';
          if (k === 'curtidas') return 'Curtidas';
          if (k === 'visualizacoes') return 'Visualizações';
          if (k === 'comentarios') return 'Comentários';
          return k;
        }

        function buildCatFilter(){
          if (!catWrap) return;
          var title = document.getElementById('clientCatFilterTitle');
          var set = {};
          cards.forEach(function(c){
            var k = normalizeCat(c.getAttribute('data-cat') || '');
            if (k) set[k] = true;
          });
          var keys = Object.keys(set);
          if (keys.length <= 1) {
            catWrap.style.display = 'none';
            if (title) title.style.display = 'none';
            catBtns = [];
            catFilter = 'all';
            return;
          }
          keys.sort();
          catWrap.innerHTML = '';
          var mk = function(label, key){
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'client-filter-btn' + (key === 'all' ? ' is-active' : '');
            b.setAttribute('data-cat-filter', key);
            b.textContent = label;
            b.addEventListener('click', function(){
              catFilter = String(key || 'all');
              page = 1;
              render();
            });
            catWrap.appendChild(b);
            return b;
          };
          catBtns = [mk('Todos tipos', 'all')].concat(keys.map(function(k){ return mk(catLabel(k), k); }));
          catWrap.style.display = '';
          if (title) title.style.display = '';
        }

        function updateActiveBtns(){
          payBtns.forEach(function(b){
            b.classList.toggle('is-active', String(b.getAttribute('data-filter') || '') === payFilter);
          });
          catBtns.forEach(function(b){
            b.classList.toggle('is-active', String(b.getAttribute('data-cat-filter') || '') === catFilter);
          });
        }

        function getFiltered(){
          return cards.filter(function(c){
            var st = String(c.getAttribute('data-pay-status') || 'pending');
            var okPay = (payFilter === 'all') || (st === payFilter);
            if (!okPay) return false;
            if (catFilter === 'all') return true;
            var ck = normalizeCat(c.getAttribute('data-cat') || '');
            return ck === catFilter;
          });
        }

        function bindAvatar(img){
          try {
            if (!img || img.getAttribute('data-avatar-bound') === '1') return;
            img.setAttribute('data-avatar-bound', '1');
            img.addEventListener('load', function(){
              try { img.setAttribute('data-avatar-loaded', '1'); } catch(_) {}
            });
            img.addEventListener('error', function(){
              try { img.setAttribute('data-avatar-loaded', '0'); } catch(_) {}
            });
          } catch (_) {}
        }

        function pokeAvatar(img){
          try {
            if (!img) return;
            bindAvatar(img);
            // já está carregada e com src definido — não precisa fazer nada
            if (img.getAttribute('data-avatar-loaded') === '1' && img.getAttribute('src')) return;
            var src = String(img.getAttribute('data-avatar-src') || '').trim();
            if (!src) return;
            // força eager antes de setar src — sem isso o browser ignora quando display:none
            img.loading = 'eager';
            img.decoding = 'async';
            img.removeAttribute('src');
            img.setAttribute('src', src);
          } catch (_) {}
        }

        function render(){
          updateActiveBtns();
          var filtered = getFiltered();
          var totalFiltered = filtered.length;
          var maxPage = Math.max(1, Math.ceil(totalFiltered / perPage));
          page = Math.max(1, Math.min(page, maxPage));
          var start = (page - 1) * perPage;
          var end = start + perPage;
          cards.forEach(function(c){ c.style.display = 'none'; });
          var shown = 0;
          for (var i = start; i < end; i++) {
            var c = filtered[i];
            if (!c) continue;
            c.style.display = 'block';
            shown += 1;
          }
          try {
            requestAnimationFrame(function(){
              for (var i = start; i < end; i++) {
                var c = filtered[i];
                if (!c) continue;
                var img = c.querySelector('img[data-avatar-src]');
                if (img) pokeAvatar(img);
              }
            });
          } catch (_) {}
          if (elShown) elShown.textContent = String(shown);
          if (elTotalInline) elTotalInline.textContent = String(totalFiltered);

          if (pager && prevBtn && nextBtn && pageInfo) {
            if (totalFiltered > perPage) {
              pager.style.display = 'flex';
              prevBtn.disabled = page <= 1;
              nextBtn.disabled = page >= maxPage;
              pageInfo.textContent = 'Página ' + page + ' de ' + maxPage;
            } else {
              pager.style.display = 'none';
            }
          }
        }

        payBtns.forEach(function(b){
          b.addEventListener('click', function(){
            payFilter = String(b.getAttribute('data-filter') || 'all');
            page = 1;
            render();
          });
        });
        if (prevBtn) {
          prevBtn.addEventListener('click', function(){
            page = Math.max(1, page - 1);
            render();
          });
        }
        if (nextBtn) {
          nextBtn.addEventListener('click', function(){
            page = page + 1;
            render();
          });
        }
        setCounts();
        buildCatFilter();
        render();

        // pré-carrega avatares de TODOS os pedidos em background usando fila controlada
        (function(){
          var allImgs = Array.from(document.querySelectorAll('#clientCardsWrap img[data-avatar-src]') || []);
          if (!allImgs.length) return;
          // coloca os da primeira página no início da fila
          var firstPage = [], rest = [];
          allImgs.forEach(function(img){
            var card = img.closest('.client-order-card');
            var isVisible = card && card.style.display !== 'none';
            if (isVisible) firstPage.push(img); else rest.push(img);
          });
          var queue = firstPage.concat(rest);
          var concurrency = 3;
          var active = 0;

          function loadImg(img, src){
            return new Promise(function(resolve){
              var probe = new Image();
              probe.onload = function(){
                try {
                  // aqui o probe já aqueceu o cache do browser
                  // agora aplica no elemento real com eager para garantir fetch
                  img.loading = 'eager';
                  img.removeAttribute('src');
                  img.setAttribute('src', src);
                  img.setAttribute('data-avatar-loaded', '1');
                } catch(_){}
                resolve();
              };
              probe.onerror = function(){
                try { img.setAttribute('data-avatar-loaded', '0'); } catch(_){}
                resolve();
              };
              probe.src = src;
            });
          }

          function next(){
            while (active < concurrency && queue.length) {
              var img = queue.shift();
              if (!img) continue;
              // já tem src definido (foi carregado pelo pokeAvatar) — pula
              if (img.getAttribute('data-avatar-loaded') === '1' && img.getAttribute('src')) continue;
              var src = String(img.getAttribute('data-avatar-src') || '').trim();
              if (!src) continue;
              active++;
              loadImg(img, src).then(function(){ active--; setTimeout(next, 60); });
            }
          }
          // primeira página carrega imediatamente após o render
          setTimeout(next, 200);
        })();
      })();
    })();
  </script>
</body>
</html>
