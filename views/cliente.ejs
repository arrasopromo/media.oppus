                %>
                <% if (_refilHrefClient) { %>
                <a href="<%= _refilHrefClient %>" class="client-welcome-refil">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
                  Acessar ferramenta de reposição
                </a>
                <% } %>
              </div>
            </div>
            <% if (pageClientCoupon && pageClientCoupon.code) { %>
              <% var _couponUsed = !!(pageClientCoupon.used); %>
              <div class="client-coupon" id="clientCouponWrap">
                <div class="client-coupon-card" style="<%= _couponUsed ? 'opacity:0.7;' : '' %>">
                  <div class="client-coupon-header">
                    <% if (_couponUsed) { %>
                      <div class="client-coupon-pill" style="background:rgba(107,114,128,.12);border-color:rgba(107,114,128,.25);color:#6b7280;">✓ Cupom usado</div>
                    <% } else { %>
                      <div class="client-coupon-pill">🎫 OFERTA ÚNICA</div>
                    <% } %>
                  </div>
                  <div class="client-coupon-headline">
                    <% if (_couponUsed) { %>Cupom já utilizado<% } else { %>Antes de ir embora: <span class="client-coupon-grad">use seu desconto exclusivo</span><% } %>
