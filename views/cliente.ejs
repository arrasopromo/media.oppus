              </div>
            <% } else { %>
              <div id="clientCardsWrap" style="display:grid; gap:10px;">
                <% pageOrders.forEach(function(o){ %>
                  <div class="client-order-card" data-pay-status="<%= esc(o.payStatus || 'pending') %>" data-cat="<%= esc(String(o.categoria || '')) %>" style="padding:14px;border:1px solid var(--border-color);border-radius:16px;background:var(--bg-secondary); box-shadow: var(--shadow-md);">
