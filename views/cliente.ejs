                </div>
              </div>
              <span id="clientCouponCode" style="display:none"><%= esc(pageClientCoupon.code) %></span>
            <% } %>

            <!-- Modal de Roadmap de Níveis -->
            <div id="levelModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.45);align-items:center;justify-content:center;padding:16px;">
              <div style="background:var(--bg-secondary,#fff);border-radius:20px;max-width:360px;width:100%;padding:24px 20px 20px;box-shadow:0 8px 40px rgba(0,0,0,.18);position:relative;max-height:90vh;overflow-y:auto">
                <button onclick="document.getElementById('levelModal').classList.remove('active')" style="position:absolute;top:12px;right:14px;background:none;border:none;cursor:pointer;color:var(--text-secondary,#6b7280);font-size:20px;line-height:1;opacity:.6">&times;</button>
                <div style="font-size:16px;font-weight:900;color:var(--text-primary,#111);margin-bottom:4px;font-family:var(--font-family)">Seus Níveis</div>
                <div style="font-size:12px;color:var(--text-secondary,#6b7280);margin-bottom:18px;font-family:var(--font-family)">Continue comprando para evoluir</div>
                <%
                  var _lvlData = [
                    { n:1, label:'Iniciante',  color:'#6b7280', bg:'rgba(107,114,128,.1)',  border:'rgba(107,114,128,.25)', icon:'⭐' },
                    { n:2, label:'Bronze',     color:'#cd7f32', bg:'rgba(205,127,50,.1)',   border:'rgba(205,127,50,.3)',   icon:'🥉' },
                    { n:3, label:'Prata',      color:'#9ca3af', bg:'rgba(156,163,175,.1)',  border:'rgba(156,163,175,.3)', icon:'🥈' },
                    { n:4, label:'Ouro',       color:'#d97706', bg:'rgba(245,158,11,.1)',   border:'rgba(245,158,11,.35)', icon:'🥇' },
                    { n:5, label:'Platina',    color:'#6b7280', bg:'rgba(229,231,235,.15)', border:'rgba(209,213,219,.5)', icon:'💎' },
                    { n:6, label:'Diamante',   color:'#3b82f6', bg:'rgba(96,165,250,.1)',   border:'rgba(96,165,250,.35)', icon:'💠' },
                    { n:7, label:'Elite',      color:'#a855f7', bg:'rgba(168,85,247,.12)',  border:'rgba(168,85,247,.4)',  icon:'👑' }
                  ];
                %>
                <div style="display:flex;flex-direction:column;gap:8px">
                  <% _lvlData.forEach(function(lv){ %>
                    <%
                      var _isCurrent = (lv.n === pageClientLevel);
                      var _isPast    = (lv.n < pageClientLevel);
                    %>
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:12px;border:1.5px solid <%= _isCurrent ? lv.border : (_isPast ? 'rgba(34,197,94,.3)' : 'var(--border-color,#e5e7eb)') %>;background:<%= _isCurrent ? lv.bg : (_isPast ? 'rgba(34,197,94,.05)' : 'transparent') %>;opacity:<%= (!_isCurrent && !_isPast) ? '0.5' : '1' %>">
