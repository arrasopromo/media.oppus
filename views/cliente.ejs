<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Área do Cliente</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
  <link href="/css/perfil.css" rel="stylesheet" />
  <style>
    body, button, input, select, textarea { font-family: var(--font-family) !important; }
    .client-actions-top { position:relative; justify-content: center; align-items:center; margin-bottom: 0.75rem; display:grid; grid-template-columns: 1fr auto 1fr; }
    #clientPageBackBtn { grid-column: 2; margin: 0 !important; }
    @media (max-width: 640px) {
      .client-actions-top { grid-template-columns: 1fr auto 1fr; gap: 10px; }
      .client-actions-top { margin-top: -10px; margin-bottom: 0.4rem; }
      #clientLogoutBtn { margin-top: -22px !important; }
      main { padding-top: 1rem !important; }
    }

    #clientLogoutBtn.continue-button { background: transparent !important; color: #dc2626 !important; box-shadow:none !important; transform:none !important; animation:none !important; padding: 6px 8px !important; min-width: auto !important; font-size: 0.9rem !important; }
    #clientLogoutBtn.continue-button::before { display:none !important; }
    #clientLogoutBtn.continue-button:hover { box-shadow:none !important; transform:none !important; filter: brightness(0.9); }
    #clientLogoutBtn.continue-button:active { transform:none !important; }
    #clientLogoutBtn { grid-column: 3; justify-self: end; }

    .client-filter { display:flex; gap:8px; justify-content:center; flex-wrap:wrap; margin: 10px 0 8px 0; }
    .client-filter-btn { padding:7px 12px; border-radius:999px; border:1px solid var(--border-color); background: var(--bg-secondary); color: var(--text-secondary); font-weight:600; font-size:0.9rem; line-height:1; box-shadow: var(--shadow-sm); }
    body.theme-light .client-filter-btn { background:#ffffff; }
    .client-filter-btn.is-active { background: #e9d5ff; border-color: var(--primary-purple); color:#000000; }
    .client-filter-title { text-align:center; font-size: 0.9rem; font-weight: 700; color: var(--text-secondary); margin: 12px 0 6px 0; letter-spacing: 0; }
    .client-filter-sub { text-align:center; font-size: 0.9rem; font-weight: 700; color: var(--text-secondary); margin: 12px 0 6px 0; letter-spacing: 0; }

    .client-overview { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin: 10px 0 12px 0; }
    .client-overview-card { min-width:140px; flex:1 1 140px; max-width:220px; background: var(--bg-secondary); border:1px solid var(--border-color); border-radius:14px; padding:12px; box-shadow: var(--shadow-sm); }
    body.theme-light .client-overview-card { background:#ffffff; }
    .client-overview-value { font-size:20px; font-weight:700; color: var(--text-primary); line-height:1.15; }
    .client-overview-label { margin-top:4px; font-size:12px; color: var(--text-secondary); font-weight:600; }
    @media (max-width: 640px) {
      .client-overview { flex-direction: column; }
      .client-overview { width: calc(100% - 32px); margin-left: auto; margin-right: auto; }
      .client-overview-card { max-width: none; width: 100%; }
      .client-overview-card { flex: none !important; flex-basis: auto !important; padding: 12px 14px; border-radius: 12px; min-height: 76px; display:flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 12px; }
      .client-overview-value { font-size: 16px; line-height: 1.05; }
      .client-overview-label { margin-top: 0; font-size: 11px; text-align: right; }
    }
    .client-orders-summary { text-align:center; color: var(--text-secondary); font-size:0.95rem; margin: 2px 0 0 0; }
    .client-order-card { background: var(--bg-secondary) !important; }
    body.theme-light .client-order-card { background:#ffffff !important; }
    .client-order-title { font-weight:700; color: var(--text-primary); font-size:1.02rem; }
    .client-order-meta { margin-top:8px; color: var(--text-secondary); font-size:0.92rem; line-height:1.35; display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; }
    .client-order-meta strong { font-weight:600; color: var(--text-primary); }
    .client-details-btn { padding:10px 14px !important; border-radius:999px !important; min-width: 170px; font-size: 0.95rem; }

    .client-refil-wrap { display:flex; justify-content:center; margin: 8px 0 0 0; }
    .client-refil-link { width:100%; max-width: 520px; display:flex; align-items:center; justify-content:center; padding: 12px 14px; border-radius: 14px; border: none; background: var(--instagram-gradient); color: #ffffff; font-weight: 800; text-decoration: none; box-shadow: var(--shadow-md); }
    .client-refil-link:hover { filter: brightness(0.98); transform: translateY(-1px); }
    .client-refil-link:active { transform: translateY(0); }
    @media (max-width: 640px) {
      .client-refil-link { padding: 11px 14px; font-size: 0.98rem; border-radius: 14px; }
    }

    /* ── Cupom retorno — estilo OFERTA ÚNICA ── */
    .client-coupon { margin: 10px auto 14px auto; width:100%; max-width: 860px; padding: 0 16px; }
    .client-coupon-card { position:relative; width:100%; border-radius: 16px; border: 1.5px solid rgba(107,70,193,.35); background: linear-gradient(135deg,#f5f3ff 0%,#ede9fe 100%); padding: 14px 16px 14px 16px; font-family: var(--font-family); box-shadow: 0 4px 18px rgba(107,70,193,.12); }
    body:not(.theme-light) .client-coupon-card { background: linear-gradient(135deg,rgba(107,70,193,.12) 0%,rgba(139,92,246,.08) 100%); border-color: rgba(107,70,193,.35); box-shadow: 0 4px 18px rgba(107,70,193,.1); }
    .client-coupon-header { display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:8px; }
    .client-coupon-pill { display:inline-flex; align-items:center; gap:6px; padding: 4px 10px; border-radius: 999px; background: rgba(107,70,193,.15); border: 1px solid rgba(107,70,193,.3); color: #5b21b6; font-weight: 800; font-size: 11px; letter-spacing: .07em; text-transform: uppercase; font-family: var(--font-family); }
    body:not(.theme-light) .client-coupon-pill { background: rgba(139,92,246,.18); border-color: rgba(139,92,246,.4); color: #c4b5fd; }
    .client-coupon-validity { font-size: 12px; font-weight: 700; color: #16a34a; font-family: var(--font-family); }
    body:not(.theme-light) .client-coupon-validity { color: #4ade80; }
    .client-coupon-headline { font-weight: 900; color: #1c1917; font-size: 17px; line-height: 1.25; letter-spacing: -.02em; font-family: var(--font-family); margin-bottom: 4px; }
    body:not(.theme-light) .client-coupon-headline { color: #ede9fe; }
    .client-coupon-off-wrap { background: var(--instagram-gradient); -webkit-background-clip: text; background-clip: text; color: transparent; font-weight: 900; }
    .client-coupon-off { font-weight: 900; }
    .client-coupon-grad { background: linear-gradient(90deg,#7c3aed,#a78bfa); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .client-coupon-sub { color: #6d28d9; font-weight: 500; font-size: .83rem; line-height: 1.45; font-family: var(--font-family); margin-bottom: 10px; }
    body:not(.theme-light) .client-coupon-sub { color: #a78bfa; }
    .client-coupon-benefits { display:flex; flex-direction:column; gap: 8px; margin-bottom: 14px; }
    .client-coupon-benefit { display:flex; align-items:center; gap:7px; font-size: .82rem; color: #5b21b6; font-family: var(--font-family); font-weight: 600; }
    body:not(.theme-light) .client-coupon-benefit { color: #c4b5fd; }
    .client-coupon-benefit-icon { width: 22px; height: 22px; border-radius: 50%; display:flex; align-items:center; justify-content:center; flex-shrink: 0; font-size: 12px; background: rgba(107,70,193,.12); }
    .client-coupon-divider { height:1px; background: rgba(251,191,36,.3); margin: 12px 0; }
    .client-coupon-bottom { display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; }
    .client-coupon-price-block { display:flex; align-items:baseline; gap:8px; flex-wrap:wrap; }
    .client-coupon-price-val { font-size: 26px; font-weight: 900; color: #16a34a; font-family: var(--font-family); line-height: 1; }
    body:not(.theme-light) .client-coupon-price-val { color: #4ade80; }
    .client-coupon-badge { display:inline-flex; align-items:center; padding: 3px 8px; border-radius: 6px; background: #dcfce7; color: #166534; font-size: 11px; font-weight: 800; }
    body:not(.theme-light) .client-coupon-badge { background: rgba(34,197,94,.2); color: #4ade80; }
    .client-coupon-btns { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .client-coupon-link { display:inline-flex; align-items:center; justify-content:center; flex-direction:column; gap:2px; padding: 10px 20px; border-radius: 12px; background: var(--instagram-gradient); color: #fff; font-weight: 800; font-size: .9rem; text-decoration:none; font-family: var(--font-family); line-height:1.2; box-shadow: 0 4px 12px rgba(220,39,67,.3); transition: filter .15s; }
    .client-coupon-link:hover { filter: brightness(1.06); }
    .client-coupon-link-timer { font-size: 11px; font-weight: 600; opacity: .85; letter-spacing: .04em; font-variant-numeric: tabular-nums; }
    .client-coupon-dismiss { font-size: .85rem; color: #78716c; font-weight: 600; background: none; border: 1px solid #e7e5e4; border-radius: 10px; cursor: pointer; font-family: var(--font-family); padding: 9px 16px; }
    body:not(.theme-light) .client-coupon-dismiss { color: #a8a29e; border-color: rgba(255,255,255,.15); }
    .client-coupon-dismiss:hover { background: rgba(0,0,0,.04); }
    .client-coupon-box { display:none; }
    .client-coupon-foot { display:none; }
    .client-coupon-footnote { display:none; }
    .client-welcome-card { margin: 0 auto 12px auto; width:100%; max-width: 860px; padding: 0 16px; }
    .client-welcome-inner { border-radius: 16px; border: 1px solid rgba(139, 92, 246, 0.25); background: rgba(139, 92, 246, 0.07); padding: 14px 16px 12px 16px; font-family: var(--font-family); }
    body.theme-light .client-welcome-inner { background: rgba(107, 70, 193, 0.05); border-color: rgba(107, 70, 193, 0.18); }
    .client-welcome-top { display:flex; align-items:center; justify-content:space-between; gap: 12px; flex-wrap: wrap; }
    .client-welcome-greeting { font-size: 0.95rem; font-weight: 700; color: var(--text-primary); }
    .client-welcome-email { font-size: 0.82rem; color: var(--text-secondary); font-weight: 500; margin-top: 2px; }
    .client-welcome-divider { margin: 11px 0 10px 0; height: 1px; background: rgba(139, 92, 246, 0.15); }
    body.theme-light .client-welcome-divider { background: rgba(107, 70, 193, 0.12); }
    .client-welcome-refil { display:inline-flex; align-items:center; gap:8px; padding: 8px 14px; border-radius: 10px; background: rgba(139, 92, 246, 0.12); border: 1px solid rgba(139, 92, 246, 0.25); color: #8B5CF6; font-size: 0.85rem; font-weight: 700; font-family: var(--font-family); text-decoration: none; transition: background 0.15s; }
    body.theme-light .client-welcome-refil { background: rgba(107, 70, 193, 0.08); border-color: rgba(107, 70, 193, 0.2); color: #6B46C1; }
    .client-welcome-refil:hover { background: rgba(139, 92, 246, 0.2); }
    .client-welcome-refil svg { flex-shrink: 0; opacity: 0.85; }
    @media (max-width: 640px) {
      .client-coupon-card { padding: 16px 14px 14px 14px; border-radius: 18px; }
      .client-coupon-headline { font-size: 22px; }
      .client-coupon-box { padding: 12px 12px; border-radius: 12px; }
      .client-coupon-box-icon { width: 36px; height: 36px; border-radius: 10px; }
      .client-coupon-box-code { font-size: 18px; }
      .client-coupon-box-copy { padding: 9px 12px; }
      .client-coupon-link { width: 100%; justify-content: center; }
    }

    .client-order-head { display:flex; justify-content:space-between; gap:10px; align-items:flex-start; }
    .client-order-left { display:flex; gap:10px; align-items:center; min-width:0; }
    .client-order-avatar { width:38px; height:38px; border-radius:999px; overflow:hidden; background: #e5e7eb; border: 1px solid rgba(0,0,0,0.06); flex-shrink:0; display:flex; align-items:center; justify-content:center; }
    body:not(.theme-light) .client-order-avatar { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.14); }
    .client-order-avatar img { width:100%; height:100%; object-fit:cover; display:block; }
    .client-order-head-text { min-width:0; }
    .client-order-ig { margin-top:2px; color: var(--text-secondary); font-size:0.86rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width: 220px; }
    @media (max-width: 640px) {
      .client-order-card { padding: 12px !important; border-radius: 14px !important; }
      .client-order-avatar { width:30px; height:30px; }
      .client-order-title { font-size: 0.95rem; }
      .client-order-ig { font-size: 0.8rem; max-width: 180px; }
      .client-order-meta { font-size: 0.85rem; margin-top: 6px; }
      .client-details-btn { min-width: 150px; padding: 9px 12px !important; font-size: 0.92rem; }
    }
  </style>
</head>
<body class="theme-light has-fixed-menu" data-disable-sale-toasts="1">
  <%- include('partials/menu') %>
  <%
    const pageMode = (typeof mode !== 'undefined' && mode) ? String(mode) : 'login';
    const pageEmail = (typeof email !== 'undefined' && email) ? String(email) : '';
    const pageToken = (typeof token !== 'undefined' && token) ? String(token) : '';
    const pageOrders = (typeof orders !== 'undefined' && Array.isArray(orders)) ? orders : [];
    const pageClientCoupon = (typeof clientCoupon !== 'undefined' && clientCoupon) ? clientCoupon : null;
    const pageClientLevel = (typeof clientLevel !== 'undefined' && Number.isFinite(Number(clientLevel))) ? Math.min(7, Math.max(1, Number(clientLevel))) : 1;
    const esc = (s) => String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const formatDatePtBR = (iso) => {
      try {
        const d = iso ? new Date(String(iso)) : null;
        if (!d || isNaN(d.getTime())) return '-';
        return d.toLocaleDateString('pt-BR');
      } catch (_) {
        return '-';
      }
    };
    const prettyText = (raw) => {
      const s0 = String(raw == null ? '' : raw).trim();
      if (!s0) return '-';
      const s = s0.toLowerCase().replace(/-/g, '_').replace(/\s+/g, '_');
      const dict = {
        'seguidores_mistos': 'Seguidores Mistos',
        'seguidores_organicos': 'Seguidores Orgânicos',
        'seguidores_brasileiros': 'Seguidores Brasileiros',
        'mistos': 'Mistos',
        'organicos': 'Orgânicos',
        'brasileiros': 'Brasileiros',
        'brasileiras': 'Brasileiras',
        'curtidas': 'Curtidas',
        'visualizacoes': 'Visualizações',
        'comentarios': 'Comentários'
      };
      if (dict[s]) return dict[s];
      return s.split('_').filter(Boolean).map(w => dict[w] || (w.charAt(0).toUpperCase() + w.slice(1))).join(' ');
    };
    const inferCategoriaKey = (o) => {
      const c = String(o && o.categoria ? o.categoria : '').toLowerCase();
      const t = String(o && o.tipo ? o.tipo : '').toLowerCase();
      const s = (c || t).replace(/\s+/g, '_');
      if (s.includes('curtid') || s.includes('likes')) return 'curtidas';
      if (s.includes('visual') || s.includes('views')) return 'visualizacoes';
      if (s.includes('coment') || s.includes('comments')) return 'comentarios';
      return 'seguidores';
    };
    const inferInstagramUsernameLoose = (o) => {
      try {
        let u = '';
        const direct = (o && (o.instagramUsername || o.instauser || o.instagram || o.ig || o.username || o.user || o.perfil || o.profile || o.instagram_user)) || '';
        u = String(direct || '').trim();
        if (!u && o && o.additionalInfoMapPaid && typeof o.additionalInfoMapPaid === 'object') {
          u = String(o.additionalInfoMapPaid.instagram_username || o.additionalInfoMapPaid.ig || o.additionalInfoMapPaid.username || '').trim();
        }
        if (!u && o && o.additionalInfoMap && typeof o.additionalInfoMap === 'object') {
          u = String(o.additionalInfoMap.instagram_username || o.additionalInfoMap.ig || o.additionalInfoMap.username || '').trim();
        }
        if (!u && o && Array.isArray(o.additionalInfoPaid)) {
          const f = o.additionalInfoPaid.find(it => it && it.key === 'instagram_username' && String(it.value || '').trim());
          if (f) u = String(f.value || '').trim();
        }
        if (!u && o && Array.isArray(o.additionalInfo)) {
          const f = o.additionalInfo.find(it => it && it.key === 'instagram_username' && String(it.value || '').trim());
          if (f) u = String(f.value || '').trim();
        }
        u = String(u || '').trim();
        if (!u) return '';
        if (u.startsWith('@')) u = u.slice(1).trim();
        try {
          const cleaned = u.replace(/\s/g, '');
          const match = cleaned.match(/^https?:\/\/(www\.)?instagram\.com\/([^\/\?\s]+)/i);
          if (match && match[2]) u = match[2];
        } catch (_) {}
        u = String(u || '').trim().replace(/^@/, '');
        return u;
      } catch (_) {
        return '';
      }
    };
  %>
  <main style="padding: 1rem 0; font-family: var(--font-family);">
    <div id="clientPage" class="client-page" style="position: static; display: block;">
      <div class="client-page-inner">
        <div class="client-actions client-actions-top">
          <button id="clientPageBackBtn" class="continue-button btn-back" style="min-width: 120px; margin: 0 auto; display:flex; align-items:center; justify-content:center;">
            <span class="button-text" style="width:100%; text-align:center;">Voltar</span>
          </button>
          <% if (pageMode === 'orders' || pageMode === 'change') { %>
            <button id="clientLogoutBtn" class="continue-button" style="display:flex; align-items:center; justify-content:center;">
              <span class="button-text" style="width:100%; text-align:center;">Sair</span>
            </button>
          <% } %>
        </div>

        <h2 class="client-title">Área do Cliente</h2>
        <% if (pageMode === 'orders') { %>
          <%# email exibido no card de boas-vindas abaixo %>
        <% } else if (pageMode === 'change') { %>
          <p class="client-desc">No primeiro acesso, você precisa trocar sua senha para continuar.</p>
        <% } else if (pageMode === 'setup') { %>
          <p class="client-desc">Crie sua senha para acessar sua conta.</p>
        <% } else if (pageMode === 'forgot' || pageMode === 'forgot_sent' || pageMode === 'reset' || pageMode === 'reset_invalid') { %>
          <p class="client-desc">Recuperação de senha</p>
        <% } else { %>
          <p class="client-desc">Acesse com e-mail e senha para consultar seus pedidos.</p>
        <% } %>

        <% if (pageMode === 'login') { %>
          <div class="client-form">
            <input id="clientEmailInput" type="email" class="select-input" placeholder="Seu e-mail" autocomplete="email" />
            <!-- Senha (login) — aparece quando o e-mail já tem conta -->
            <input id="clientPasswordInput" type="password" class="select-input" placeholder="Sua senha" autocomplete="current-password" style="margin-top:10px; display:none;" />
            <!-- Criação de senha — aparece quando comprou mas não tem senha -->
            <input id="clientNewPwInput" type="password" class="select-input" placeholder="Criar senha (mínimo 8 caracteres)" autocomplete="new-password" style="margin-top:10px; display:none;" />
            <input id="clientNewPwInput2" type="password" class="select-input" placeholder="Confirmar senha" autocomplete="new-password" style="margin-top:10px; display:none;" />
            <div id="clientAuthHint" style="display:none; margin-top:10px; font-size:0.85rem; color: var(--text-secondary);"></div>
            <div id="clientAuthMsg" class="status-message" style="display:none; margin-top:10px;"></div>
            <div class="client-actions" style="justify-content: center; margin-top:10px;">
              <button id="clientLoginBtn" class="continue-button" style="width:100%; max-width:320px; display:flex; align-items:center; justify-content:center;"><span class="button-text" style="width:100%; text-align:center;">Continuar</span></button>
            </div>

            <div style="display:flex; align-items:center; gap:10px; margin-top:14px;">
              <div style="height:1px; background: var(--border-color); flex:1;"></div>
              <div style="font-size:12px; color: var(--text-secondary); font-weight:600;">OU</div>
              <div style="height:1px; background: var(--border-color); flex:1;"></div>
            </div>
            <div style="text-align:center; margin-top:12px;">
              <a href="/cliente/esqueci-senha" id="clientForgotLink" style="color: var(--primary-purple); font-weight: 600; text-decoration: none;">Esqueci minha senha</a>
            </div>
          </div>

        <% } %>

        <% if (pageMode === 'forgot') { %>
          <div class="client-form">
            <p class="client-desc">Informe seu e-mail para receber o link de redefinição.</p>
            <input id="clientForgotEmailStandaloneInput" type="email" class="select-input" placeholder="seu@email.com" autocomplete="email" value="<%= esc(pageEmail) %>" />
            <div id="clientForgotMsg" class="status-message" style="display:none; margin-top:10px;"></div>
            <div class="client-actions" style="justify-content: center; margin-top:10px;">
              <button id="clientForgotStandaloneBtn" class="continue-button" style="width:100%; max-width:420px; display:flex; align-items:center; justify-content:center;">
                <span class="button-text" style="width:100%; text-align:center;">Enviar link</span>
              </button>
            </div>
            <div style="text-align:center; margin-top:12px;">
              <a href="/cliente" style="color: var(--text-secondary); font-weight: 600; text-decoration: none;">Voltar pro login</a>
            </div>
          </div>
        <% } %>

        <% if (pageMode === 'forgot_sent') { %>
          <div style="display:flex; flex-direction:column; align-items:center; gap:10px; margin-top:12px;">
            <div style="width:64px;height:64px;border-radius:999px;background:#16a34a;display:flex;align-items:center;justify-content:center;color:#ffffff;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6L9 17l-5-5"></path>
              </svg>
            </div>
            <div style="font-size:28px; font-weight:800; color: var(--text-primary);">Tudo certo!</div>
            <div style="text-align:center; color: var(--text-secondary); max-width:520px; line-height:1.5;">
              Se o e-mail informado estiver cadastrado, vamos enviar as instruções por e-mail em alguns instantes.
            </div>

            <div style="width:100%; max-width:520px; margin-top:10px; padding:14px; border:1px solid var(--border-color); border-radius:14px; background: var(--bg-secondary);">
              <div style="color: var(--text-primary); font-weight:700; margin-bottom:8px;">Não recebeu?</div>
              <div style="color: var(--text-secondary); font-size:0.95rem; line-height:1.45;">
                Aguarde alguns minutos e verifique sua caixa de spam.
              </div>
              <div id="clientResendHint" style="margin-top:10px; color: var(--text-secondary); font-size:0.9rem;"></div>
              <div class="client-actions" style="justify-content:center; margin-top:12px; flex-direction:column; gap:10px;">
                <button id="clientResendBtn" class="continue-button" style="width:100%; background:#e5e7eb; color:#111827; display:flex; align-items:center; justify-content:center;">
                  <span class="button-text" style="width:100%; text-align:center;">Tentar de novo</span>
                </button>
                <a href="/cliente" class="continue-button" style="width:100%; text-decoration:none; display:flex; align-items:center; justify-content:center;">
                  <span class="button-text" style="width:100%; text-align:center;">Voltar pro login</span>
                </a>
              </div>
            </div>
          </div>
        <% } %>

        <% if (pageMode === 'change') { %>
          <div class="client-form">
            <input id="clientCurrentPasswordInput" type="password" class="select-input" placeholder="Senha atual" autocomplete="current-password" />
            <input id="clientNewPasswordInput" type="password" class="select-input" placeholder="Nova senha (mínimo 8 caracteres)" autocomplete="new-password" style="margin-top:10px;" />
            <input id="clientNewPasswordInput2" type="password" class="select-input" placeholder="Confirmar nova senha" autocomplete="new-password" style="margin-top:10px;" />
            <div id="clientChangeMsg" class="status-message" style="display:none; margin-top:10px;"></div>
            <div class="client-actions" style="justify-content: center;">
              <button id="clientChangePasswordBtn" class="continue-button"><span class="button-text">Atualizar senha</span></button>
            </div>
          </div>
        <% } %>

        <% if (pageMode === 'reset') { %>
          <div class="client-form">
            <p class="client-desc">Redefinir senha para <strong><%= esc(pageEmail) %></strong></p>
            <input id="clientResetPasswordInput" type="password" class="select-input" placeholder="Nova senha (mínimo 8 caracteres)" autocomplete="new-password" />
            <input id="clientResetPasswordInput2" type="password" class="select-input" placeholder="Confirmar nova senha" autocomplete="new-password" style="margin-top:10px;" />
            <div id="clientResetMsg" class="status-message" style="display:none; margin-top:10px;"></div>
            <div class="client-actions" style="justify-content:center;">
              <button id="clientResetBtn" class="continue-button"><span class="button-text">Redefinir</span></button>
            </div>
          </div>
        <% } %>

        <% if (pageMode === 'reset_invalid') { %>
          <div style="margin-top:14px;padding:12px;border:1px solid #fecaca;background:#fef2f2;border-radius:12px;color:#991b1b;">
            Link inválido ou expirado. Solicite um novo link em "Esqueci a senha".
          </div>
        <% } %>

        <% if (pageMode === 'setup') { %>
          <div class="client-form">
            <p style="font-size:0.82rem;color:#6b7280;margin-bottom:10px;text-align:center;">Conta: <strong><%= esc(pageEmail) %></strong></p>
            <input id="clientSetupPasswordInput" type="password" class="select-input" placeholder="Criar senha (mínimo 8 caracteres)" autocomplete="new-password" />
            <input id="clientSetupPasswordInput2" type="password" class="select-input" placeholder="Confirmar senha" autocomplete="new-password" style="margin-top:10px;" />
            <div id="clientSetupMsg" class="status-message" style="display:none; margin-top:10px;"></div>
            <div class="client-actions" style="justify-content:center;">
              <button id="clientSetupBtn" class="continue-button"><span class="button-text">Criar senha e entrar</span></button>
            </div>
          </div>
          <script>
          (function(){
            var btn = document.getElementById('clientSetupBtn');
            var p1  = document.getElementById('clientSetupPasswordInput');
            var p2  = document.getElementById('clientSetupPasswordInput2');
            var msg = document.getElementById('clientSetupMsg');
            var email = '<%= esc(pageEmail) %>';
            function showMsg(text, ok){ msg.style.display=''; msg.style.color = ok ? '#166534' : '#991b1b'; msg.textContent = text; }
            if(!btn) return;
            btn.addEventListener('click', async function(){
              var pw1 = p1 ? p1.value.trim() : '';
              var pw2 = p2 ? p2.value.trim() : '';
              if(pw1.length < 8){ showMsg('A senha deve ter pelo menos 8 caracteres.', false); return; }
              if(pw1 !== pw2){ showMsg('As senhas não coincidem.', false); return; }
              btn.disabled = true;
              try {
                var r = await fetch('/cliente/setup-password', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email: email, password: pw1 })
                });
                var d = await r.json();
                if(d && d.ok){
                  showMsg('Senha criada! Entrando...', true);
                  setTimeout(function(){ window.location.href = '/cliente'; }, 1000);
                } else {
                  showMsg(d && d.message ? d.message : 'Erro ao criar senha. Tente novamente.', false);
                  btn.disabled = false;
                }
              } catch(e){
                showMsg('Erro de rede. Tente novamente.', false);
                btn.disabled = false;
              }
            });
          })();
          </script>
        <% } %>

        <% if (pageMode === 'orders') { %>
