<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Crescer Perfil no Instagram</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <link href="/css/style.css" rel="stylesheet" />
  <link href="/css/perfil.css" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/images/logo.png" />
</head>
<body class="theme-light">
  <div class="container checkout-page" style="min-height: 100vh; display:flex; flex-direction:column;">
    <main class="main-content" style="flex:1; display:flex; align-items:center; justify-content:center; padding-top:0;">
      <section class="section-block" style="width:100%; max-width:720px;">
        <div class="service-card" style="max-width:720px; margin:0 auto;">
          <div class="card-content" style="text-align:center;">
            <div style="display:flex; justify-content:center; margin-bottom:12px;">
              <img src="/images/logo%20escura.png" alt="Agência Oppus" width="56" height="56" style="border-radius:14px; border:1px solid var(--border-color); background: var(--bg-secondary); padding:10px;" />
            </div>
            <h1 class="card-title" style="font-size:1.8rem; margin-bottom:8px;">Impulsione seu Instagram</h1>
            <div class="card-desc" style="font-size:1.05rem; opacity:0.95; max-width:520px; margin:0 auto 16px auto;">
              Escolha um serviço e finalize em poucos cliques.
            </div>
            <div style="display:flex; justify-content:center; margin-top:12px;">
              <a class="continue-button" href="/engajamento<%= queryString ? ('?' + queryString) : '' %>" style="text-decoration:none; width:min(420px, 100%);">
                <span class="button-text" style="width:100%; text-align:center;">Começar agora</span>
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <footer class="footer">
      <div class="footer-row" style="justify-content:center; text-align:center;">
        <span class="footer-center">&copy; 2026 Agência OPPUS. Todos os direitos reservados.</span>
      </div>
    </footer>
  </div>
</body>
</html>
